    return branch_ref.raw == branch_ref.work_id


def run_git(args: list[str], dry_run: bool) -> None:
    print(f"$ git {' '.join(args)}")
    if not dry_run:
        git_output(args)


def remote_branch_ref(branch: str) -> str:
    return f"origin/{branch}"


def remote_branch_exists(branch: str) -> bool:
    return git_ref_exists(f"refs/remotes/{remote_branch_ref(branch)}")


def ensure_ref_exists(ref: str) -> None:
    if not git_ref_exists(ref):
        raise RuntimeError(f"git ref {ref} does not exist; pass --base or update local refs first")


def create_or_switch_branch(branch: str, base_ref: str, dry_run: bool, assume_base_ref_exists: bool = False) -> None:
    if git_branch_exists(branch):
        run_git(["switch", branch], dry_run)
        return
    if remote_branch_exists(branch):
        run_git(["switch", "-c", branch, remote_branch_ref(branch)], dry_run)
        return
    if not assume_base_ref_exists:
        ensure_ref_exists(base_ref)
    run_git(["switch", "-c", branch, base_ref], dry_run)


def ensure_feature_branch(feature_branch: str, base_ref: str, dry_run: bool) -> None:
    if git_branch_exists(feature_branch):
        return
    if remote_branch_exists(feature_branch):
        run_git(["switch", "-c", feature_branch, remote_branch_ref(feature_branch)], dry_run)
        return
    ensure_ref_exists(base_ref)
    run_git(["switch", "-c", feature_branch, base_ref], dry_run)


