def semantic_context_payload(args: argparse.Namespace) -> tuple[dict[str, object], int]:
    if args.limit < 0:
        raise ValueError("--limit must be zero or greater")
    if args.long_file_lines < 0:
        raise ValueError("--long-file-lines must be zero or greater")
    model = load_model()
    workflow = args.workflow
    payload: dict[str, object] = {
        "schema_version": "1.0",
        "workflow": workflow,
        "signal_policy": {
            "observations_are_deterministic": True,
            "candidate_signals_are_not_semantic_conclusions": True,
            "human_authority": "Requirements changes and final acceptance remain with the human owner.",
        },
        "snapshot": {
            "branch": current_branch_or_none(),
            "head": git_output(["rev-parse", "HEAD"]),
            "base_ref": args.base or "origin/main",
        },
        "validation": {
            "errors": [issue_json(issue) for issue in model.errors],
            "warnings": [issue_json(issue) for issue in model.warnings],
        },
    }
    if model.errors:
        payload["error"] = "management model validation failed"
        return payload, 1

    all_links = traceability_links()
    all_area_acknowledgements = unmapped_requirement_area_acknowledgements()
    limit = args.limit
    reference = args.reference
    if workflow in {"plan", "review", "verification"}:
        if not reference:
            payload["error"] = f"{workflow} requires a work item or branch reference"
            return payload, 1
        try:
            raw_ref, item = resolve_work_item(model, reference)
            branch_ref = parse_branch_ref(raw_ref)
        except (KeyError, RuntimeError, ValueError) as err:
            payload["error"] = str(err)
            return payload, 1
        requirement = model.requirements[item.requirement_id]
        payload["focus"] = {
            "reference": raw_ref,
            "work_item": work_item_json(item),
            "requirement": requirement_json(requirement),
            "traceability": [traceability_json(link) for link in traceability_links_for(requirement, all_links)],
        }
        if workflow == "plan":
            owner_findings = [] if branch_reference_is_plain_work_item(branch_ref) else branch_owner_errors(item, branch_ref)
            payload["observations"] = {
                "branch_syntax_valid": True,
                "owner_findings": owner_findings,
                "sibling_work": [work_item_json(sibling) for sibling in same_requirement_items(model, item)],
                "description_present": bool(item.body),
                "current_state": item.state,
                "blocked": item.blocked,
            }
            payload["candidate_signals"] = [
                "Confirm motivation against completed sibling work.",
                "Confirm scope, dependencies, acceptance evidence, and product or technical value semantically.",
            ]
        else:
            base_ref = args.base or "origin/main"
            files, file_notes = changed_files(base_ref)
            payload["observations"] = {
                "current_branch": current_branch(),
                "requested_reference": raw_ref,
                "reference_is_plain_work_item": branch_reference_is_plain_work_item(branch_ref),
                "reference_matches_current_branch": None if branch_reference_is_plain_work_item(branch_ref) else raw_ref == current_branch(),
                "changed_files": limited(files, limit),
                "change_detection_notes": file_notes,
                "evidence_candidates": verification_candidate_map(files, limit),
            }
            if workflow == "review":
                stat_sections, stat_notes = diff_stat(base_ref)
                payload["observations"]["diff_stats"] = stat_sections
                payload["observations"]["change_detection_notes"] = [*file_notes, *stat_notes]
                payload["candidate_signals"] = REVIEW_CHECKLIST
            else:
                payload["candidate_signals"] = [
                    "Candidate evidence paths are classified by filename and local content only; establish semantic coverage before acceptance.",
                    *REVIEW_CHECKLIST[:3],
                ]
        return payload, 0

    if workflow in {"estimate", "sync"}:
        if not reference:
            payload["error"] = f"{workflow} requires a requirement id"
            return payload, 1
        requirement = model.requirements.get(reference)
        if requirement is None:
            payload["error"] = f"unknown requirement: {reference}"
            return payload, 1
        work_items = requirement_work_items(model, requirement)
        links = traceability_links_for(requirement, all_links)
        payload["focus"] = {
            "requirement": requirement_json(requirement),
            "descendant_requirements": [requirement_json(child) for child in descendant_requirements(model, requirement)],
            "work_items": [work_item_json(item) for item in work_items],
            "traceability": [traceability_json(link) for link in links],
        }
        if workflow == "estimate":
            all_requirements = sorted(model.requirements.values(), key=lambda candidate: candidate.id)
            findings = audit_requirement(
                model,
                requirement,
                (MANAGEMENT_DIR / "TRACEABILITY.md").read_text(encoding="utf-8"),
                duplicate_requirement_groups(all_requirements, lambda candidate: " ".join(words_in(candidate.title))),
                duplicate_requirement_groups(all_requirements, lambda candidate: " ".join(words_in(candidate.body))),
            )
            prompts = requirement_semantic_prompts(requirement)
            active_prompts = [prompt for prompt in prompts if prompt.status == "active"]
            acknowledged_prompts = [prompt for prompt in prompts if prompt.status == "acknowledged"]
            estimate = requirement_estimate_decision(requirement, findings, prompts)
            payload["observations"] = {
                "explicit_requirement_references": requirement_references(requirement_text(requirement)),
                "local_complexity_score": estimate.structural_score,
                "heuristic_effort_band": estimate.structural_effort_band,
                "estimate_decision": dataclasses.asdict(estimate),
                "quality_findings": [audit_finding_json(finding) for finding in findings],
                "semantic_prompts": [semantic_prompt_json(prompt) for prompt in active_prompts],
                "acknowledged_semantic_prompts": [semantic_prompt_json(prompt) for prompt in acknowledged_prompts],
                "work_coverage": requirement_work_coverage(model, requirement),
                "evidence_coverage": requirement_evidence_coverage(model, requirement, all_links),
                "acknowledged_unmapped_coverage": requirement_coverage_acknowledgements(requirement, all_area_acknowledgements),
            }
            payload["candidate_signals"] = [
                *[prompt.format() for prompt in active_prompts],
                (
                    "The structural effort band is not a delivery estimate; resolve the listed uncertainty drivers before making a commitment."
                    if estimate.uncertainty_drivers
                    else "The delivery range is a structural heuristic; inspect implementation scope, dependencies, risks, and market context before committing."
                ),
            ]
        else:
            paths = sorted({path for link in links for path in evidence_paths(link)})
            payload["observations"] = {
                "evidence_path_status": [{"path": path, "status": status} for path, status in evidence_path_statuses(paths)],
                "exact_requirement_id_mentions": source_files_mentioning([requirement.id], limit, implementation_only=True),
                "requirement_term_mentions": source_files_mentioning(requirement_source_terms(requirement), limit, implementation_only=True),
                "work_coverage": requirement_work_coverage(model, requirement),
                "evidence_coverage": requirement_evidence_coverage(model, requirement, all_links),
                "acknowledged_unmapped_coverage": requirement_coverage_acknowledgements(requirement, all_area_acknowledgements),
            }
            payload["candidate_signals"] = ["Compare the requirement semantically with implementation, tests, evidence, and relevant git history; lexical mentions do not prove conformance."]
        return payload, 0

    if workflow == "audit":
        all_requirements = sorted(model.requirements.values(), key=lambda candidate: candidate.id)
        requirements = all_requirements
        if reference:
            requirement = model.requirements.get(reference)
            if requirement is None:
                payload["error"] = f"unknown requirement: {reference}"
                return payload, 1
            requirements = [requirement, *descendant_requirements(model, requirement)]
        traceability_text = (MANAGEMENT_DIR / "TRACEABILITY.md").read_text(encoding="utf-8")
        duplicate_titles = duplicate_requirement_groups(all_requirements, lambda requirement: " ".join(words_in(requirement.title)))
        duplicate_bodies = duplicate_requirement_groups(all_requirements, lambda requirement: " ".join(words_in(requirement.body)))
        payload["observations"] = {
            "requirements": [requirement_json(requirement) for requirement in requirements],
            "work_items": [
                work_item_json(item)
                for item in sorted(model.work_items.values(), key=lambda item: item.id)
                if any(requirement_matches_id(requirement, item.requirement_id) for requirement in requirements)
            ],
            "traceability": [
                traceability_json(link)
                for link in all_links
                if any(requirement_matches_id(requirement, link.requirement_id) for requirement in requirements)
            ],
        }
        quality_findings = [
            finding
            for requirement in requirements
            for finding in audit_requirement(model, requirement, traceability_text, duplicate_titles, duplicate_bodies)
        ]
        prompts = [prompt for requirement in requirements for prompt in requirement_semantic_prompts(requirement)]
        active_prompts = [prompt for prompt in prompts if prompt.status == "active"]
        acknowledged_prompts = [prompt for prompt in prompts if prompt.status == "acknowledged"]
        payload["observations"]["quality_findings"] = [audit_finding_json(finding) for finding in quality_findings]
        payload["observations"]["semantic_prompts"] = [semantic_prompt_json(prompt) for prompt in active_prompts]
        payload["observations"]["acknowledged_semantic_prompts"] = [
            semantic_prompt_json(prompt) for prompt in acknowledged_prompts
        ]
        payload["observations"]["work_coverage"] = [
            {
                "requirement_id": requirement.id,
                **requirement_work_coverage(model, requirement),
            }
            for requirement in requirements
        ]
        payload["observations"]["evidence_coverage"] = [
            {
                "requirement_id": requirement.id,
                **requirement_evidence_coverage(model, requirement, all_links),
            }
            for requirement in requirements
        ]
        payload["observations"]["acknowledged_unmapped_coverage"] = [
            {
                "requirement_id": requirement.id,
                "acknowledgements": requirement_coverage_acknowledgements(requirement, all_area_acknowledgements),
            }
            for requirement in requirements
            if requirement_coverage_acknowledgements(requirement, all_area_acknowledgements)
        ]
        candidate_signals = [prompt.format() for prompt in active_prompts]
        payload["candidate_signals"] = candidate_signals if limit <= 0 else candidate_signals[:limit]
        return payload, 0

    findings = chase_tech_debts(0, args.long_file_lines)
    path_prefix = None
    if reference:
        try:
            path_prefix = canonical_repo_path(reference, allow_missing=False)
        except ValueError as err:
            payload["error"] = str(err)
            return payload, 1
        findings = [finding for finding in findings if finding.path == path_prefix or finding.path.startswith(f"{path_prefix.rstrip('/')}/")]
    payload["observations"] = {
        "tracked_text_files_scanned": len(tracked_text_files()),
        "path_prefix": path_prefix,
        "candidates": [dataclasses.asdict(finding) for finding in (findings if limit <= 0 else findings[:limit])],
    }
    payload["candidate_signals"] = ["Each candidate requires semantic inspection before it is accepted as technical debt."]
    return payload, 0


def cmd_semantic_context(args: argparse.Namespace) -> int:
    try:
        payload, exit_code = semantic_context_payload(args)
    except (OSError, RuntimeError, ValueError) as err:
        payload = {"schema_version": "1.0", "workflow": args.workflow, "error": str(err)}
        exit_code = 1
    print(json.dumps(payload, indent=2, sort_keys=True))
    return exit_code


def lifecycle_next_commands(item: WorkItem) -> tuple[list[str], str | None]:
    if item.state == "Under Planning":
        return (
            [
                f"scripts/management/evaluate_plan {item.id}",
                f"scripts/management/advance_state {item.id} --to Planned --dry-run",
            ],
            None,
        )
    if item.state == "Planned":
        return (
            [
                f"scripts/management/advance_state {item.id} --engineer <ENGINEER> --dry-run",
                f"scripts/management/advance_state {item.id} --engineer <ENGINEER>",
            ],
            None,
        )
    if item.state == "Started":
        owner = item.owner if item.owner and re.fullmatch(r"[A-Za-z0-9_.-]+", item.owner) else "<ENGINEER>"
        branch = f"{owner}/{item.id}"
        return (
            [
                f"scripts/management/start_work {branch} --dry-run",
                f"scripts/management/start_work {branch}",
                f"scripts/management/chat_about {item.id}",
            ],
            None,
        )
    if item.state == "In Code Review":
        return (
            [
                f"scripts/management/verification_check {item.id}",
                f"scripts/management/review {item.id}",
                f"scripts/management/advance_state {item.id} --to QA --dry-run",
            ],
            "QA is optional; choose Integrated or Merged only when that path matches the work.",
        )
    if item.state == "Integrated":
        return (
            [
                f"scripts/management/link_evidence {item.id} <EXISTING_REPO_PATH> [MORE_EXISTING_PATHS ...]",
                f"scripts/management/trace_requirement {item.requirement_id}",
                f"scripts/management/advance_state {item.id} --to Merged --dry-run",
            ],
            None,
        )
    if item.state == "QA":
        return (
            [
                f"scripts/management/acceptance_packet {item.id}",
                f"scripts/management/link_evidence {item.id} <EXISTING_REPO_PATH> [MORE_EXISTING_PATHS ...]",
                f"scripts/management/trace_requirement {item.requirement_id}",
                f"scripts/management/advance_state {item.id} --to Merged --dry-run",
            ],
            None,
        )
    if item.state == "Merged":
        return (
            [
                "scripts/management/prepare_release <VERSION> --strict",
                "scripts/management/create_release_tag <VERSION>",
                "scripts/management/create_release_tag <VERSION> --execute",
                (
                    f"scripts/management/record_release <VERSION> {item.id} --decision Released "
                    '--verification "<PASSED_CHECKS>" --rollback "<ROLLBACK_OR_MITIGATION>" '
                    '--notes "<RELEASE_NOTES>"'
                ),
                f"scripts/management/link_evidence {item.id} management/RELEASES.md",
                f"scripts/management/advance_state {item.id} --dry-run",
            ],
            "Create and push a production tag only after release-owner approval; record the actual outcome after deployment checks.",
        )
    if item.state == "Rolled Out":
        return (
            [
                f"scripts/management/trace_requirement {item.requirement_id}",
                f"scripts/management/sync_requirement {item.requirement_id}",
            ],
            "The lifecycle is complete; these commands inspect the final requirement and evidence state.",
        )
    if terminal_state(item.state):
        return [], f"{item.state} is terminal; no further lifecycle command applies."
    return [], None


def print_lifecycle_next_commands(item: WorkItem, *, stream=None) -> None:
    output = stream or sys.stdout
    commands, note = lifecycle_next_commands(item)
    if commands:
        print("Next commands:", file=output)
        for command in commands:
            print(f"  {command}", file=output)
    if note:
        print(f"Note: {note}", file=output)


def cmd_advance_state(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    try:
        raw_ref, item = resolve_work_item(model, args.ref)
        target_state = target_state_for(item, args.to)
        state_date = validate_iso_date(args.date or date.today().isoformat())
        validate_state_transition(model, item, target_state, state_date)
    except (KeyError, RuntimeError, ValueError) as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    engineer = args.engineer
    if engineer:
        try:
            validate_single_line_markdown_field(engineer, "--engineer", forbidden_characters=".:;")
        except ValueError as err:
            print(f"error: {err}", file=sys.stderr)
            return 1
    if item.state == "Planned" and target_state == "Started" and not (engineer or item.owner):
        print("error: --engineer is required when moving Planned to Started", file=sys.stderr)
        print(
            f"error: retry first with: scripts/management/advance_state {item.id} "
            "--engineer <ENGINEER> --dry-run",
            file=sys.stderr,
        )
        return 1

    override_reason = args.override_gate.strip() if args.override_gate else None
    if override_reason and any(character in override_reason for character in "\r\n"):
        print("error: --override-gate must be one non-empty line", file=sys.stderr)
        return 1
    gate_failures = deterministic_gate_failures(item, target_state)
    if gate_failures and not override_reason:
        for failure in gate_failures:
            print(f"error: readiness gate failed: {failure}", file=sys.stderr)
        if any(
            "no TRACEABILITY.md row" in failure or "no existing concrete evidence path" in failure
            for failure in gate_failures
        ):
            print("error: add or update concrete evidence with:", file=sys.stderr)
            print(
                f"error:   scripts/management/link_evidence {item.id} "
                "<EXISTING_REPO_PATH> [MORE_EXISTING_PATHS ...]",
                file=sys.stderr,
            )
            print(f"error: inspect it with: scripts/management/trace_requirement {item.requirement_id}", file=sys.stderr)
        if any("schema-valid Released entry" in failure for failure in gate_failures):
            print("error: prepare, execute, and record the production release with:", file=sys.stderr)
            print("error:   scripts/management/prepare_release <VERSION> --strict", file=sys.stderr)
            print("error:   scripts/management/create_release_tag <VERSION>", file=sys.stderr)
            print("error:   scripts/management/create_release_tag <VERSION> --execute", file=sys.stderr)
            print(
                f"error:   scripts/management/record_release <VERSION> {item.id} "
                '--decision Released --verification "<PASSED_CHECKS>" '
                '--rollback "<ROLLBACK_OR_MITIGATION>" --notes "<RELEASE_NOTES>"',
                file=sys.stderr,
            )
        if any("no linked operational or release evidence path" in failure for failure in gate_failures):
            print("error: link the release record and any additional operational evidence with:", file=sys.stderr)
            print(
                f"error:   scripts/management/link_evidence {item.id} management/RELEASES.md "
                "[<OPERATIONAL_EVIDENCE_PATH> ...]",
                file=sys.stderr,
            )
            print(f"error: inspect it with: scripts/management/trace_requirement {item.requirement_id}", file=sys.stderr)
        print("error: satisfy the deterministic gates or pass --override-gate with an auditable reason", file=sys.stderr)
        return 1
    if override_reason and not gate_failures:
        print("error: --override-gate was supplied, but no deterministic readiness gate failed", file=sys.stderr)
        return 1

    print("Before:")
    if raw_ref != item.id:
        print(f"Reference:   {raw_ref}")
    print_work_item(model, item)

    if target_state == item.state and target_state in item.timeline:
        print()
        print(f"No change: {item.id} already has {target_state}: {item.timeline[target_state]}")
        print()
        print_lifecycle_next_commands(item)
        return 0

    try:
        require_main_for_mutation(args.dry_run)
    except RuntimeError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    if args.dry_run:
        print()
        print(f"Dry run: would move {item.id} from {item.state} to {target_state} using date {state_date}.")
        print()
        print_lifecycle_next_commands(dataclasses.replace(item, state=target_state))
        return 0

    try:
        with management_write_lock():
            updates = {
                item.path: render_work_item_transition(item, target_state, state_date, engineer, override_reason),
            }
            traceability_content = render_traceability_work_state(item.id, target_state)
            if traceability_content is not None:
                updates[MANAGEMENT_DIR / "TRACEABILITY.md"] = traceability_content
            atomic_write_many(updates)
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    updated_model = load_model()
    updated_item = updated_model.work_items[item.id]
    print()
    print("After:")
    print_work_item(updated_model, updated_item)
    print()
    print_lifecycle_next_commands(updated_item)
    return 0


