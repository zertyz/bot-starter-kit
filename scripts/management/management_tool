        print("error: worktree has uncommitted changes; use --allow-dirty only if you intentionally want to carry them", file=sys.stderr)
        return 1

    base_ref = args.base or "origin/main"
    print_work_item(model, item)
    print()
    print("Branch operations:")

    try:
        if branch_ref.is_feature:
            create_or_switch_branch(branch_ref.raw, base_ref, args.dry_run)
        elif args.from_feature:
            feature_branch = args.feature_branch or f"feature/{branch_ref.work_id}"
