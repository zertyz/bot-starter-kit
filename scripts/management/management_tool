def branch_owner_errors(item: WorkItem, branch_ref: BranchRef, explicit_user: str | None = None) -> list[str]:
    errors: list[str] = []
    if not branch_ref.is_feature and branch_ref.owner is None:
        errors.append("ordinary work branches must use `<developer_username>/<work item id>`")
    if branch_ref.is_feature:
        if explicit_user and item.owner and explicit_user.lower() != item.owner.lower():
            errors.append(f"--user {explicit_user} does not match backlog owner {item.owner}")
        return errors
    if item.owner is None:
        errors.append(f"{item.id} has no backlog owner")
    elif branch_ref.owner and branch_ref.owner.lower() != item.owner.lower():
        errors.append(f"branch owner {branch_ref.owner} does not match backlog owner {item.owner}")
    if explicit_user and item.owner and explicit_user.lower() != item.owner.lower():
        errors.append(f"--user {explicit_user} does not match backlog owner {item.owner}")
    return errors


def started_work_errors(model: ManagementModel, item: WorkItem, branch_ref: BranchRef, explicit_user: str | None = None) -> list[str]:
    errors: list[str] = []
    if item.requirement_id not in model.requirements:
        errors.append(f"{item.id} references missing requirement {item.requirement_id}")
    if item.state != "Started":
        errors.append(f"{item.id} is in state {item.state}; engineering work branches must reference a Started work item")
    errors.extend(branch_owner_errors(item, branch_ref, explicit_user))
    return errors


def same_requirement_items(model: ManagementModel, item: WorkItem) -> list[WorkItem]:
    return sorted(
        [candidate for candidate in model.work_items.values() if candidate.requirement_id == item.requirement_id and candidate.id != item.id],
        key=lambda candidate: candidate.id,
    )


def completed_work_items(items: list[WorkItem]) -> list[WorkItem]:
    return [item for item in items if item.state in {"Merged", "Rolled Out"}]


def open_work_items(items: list[WorkItem]) -> list[WorkItem]:
    return [item for item in items if item.state not in {"Merged", "Rolled Out", "Rejected", "Cancelled"}]


def words_in(text: str) -> list[str]:
    return re.findall(r"[A-Za-z0-9][A-Za-z0-9_-]*", text.lower())


def requirement_text(requirement: Requirement) -> str:
    return f"{requirement.title}\n{requirement.body}"


def normalized_requirement_text(requirement: Requirement) -> str:
    return " ".join(words_in(requirement_text(requirement)))


def requirement_work_items(model: ManagementModel, requirement: Requirement) -> list[WorkItem]:
    related_prefix = f"{requirement.id}."
    return sorted(
        [
            item
            for item in model.work_items.values()
            if item.requirement_id == requirement.id or (not requirement.subtopics and item.requirement_id.startswith(related_prefix))
        ],
        key=lambda item: item.id,
    )


def requirement_matches_id(requirement: Requirement, candidate_id: str) -> bool:
    return candidate_id == requirement.id or (not requirement.subtopics and candidate_id.startswith(f"{requirement.id}."))


def traceability_status(requirement: Requirement, traceability: str) -> str:
    if requirement.id in traceability:
        return "direct"
    if not requirement.subtopics and f"{requirement.id}." in traceability:
        return "child"
    if f"{requirement.document}.{requirement.section}.*" in traceability:
        return "area"
    return "missing"


def contains_term(text: str, term: str) -> bool:
    if any(character in term for character in "/-"):
        return term in text
    return re.search(rf"\b{re.escape(term)}\b", text) is not None


def matching_terms(text: str, terms: list[str]) -> list[str]:
    lowered = text.lower()
    return [term for term in terms if contains_term(lowered, term)]


def likely_compound_requirement(requirement: Requirement) -> bool:
    body = requirement.body
    bullet_lines = [line for line in body.splitlines() if re.match(r"\s*(?:[-*]|\d+\.)\s+", line)]
    obligation_markers = len(re.findall(r"\b(?:and|also|or)\b", body.lower()))
    return len(bullet_lines) >= 4 or obligation_markers >= 5


def audit_requirement(
    model: ManagementModel,
    requirement: Requirement,
    traceability: str,
    duplicate_titles: dict[str, list[Requirement]],
    duplicate_bodies: dict[str, list[Requirement]],
) -> list[AuditFinding]:
    findings: list[AuditFinding] = []
    text = requirement_text(requirement)
    body = requirement.body.strip()
    body_words = words_in(body)
    work_items = requirement_work_items(model, requirement)
    completed_items = completed_work_items(work_items)
    active_items = open_work_items(work_items)

    def add(severity: str, category: str, message: str) -> None:
        findings.append(AuditFinding(severity, requirement, category, message))

    if not body or body.lower() in {"tbd", "todo"}:
        add("BLOCKER", "clarity", "requirement body is empty or TBD")
    elif len(body_words) < 8:
        add("REVIEW", "clarity", "requirement body is very short")

    unbounded = matching_terms(text, UNBOUNDED_REQUIREMENT_TERMS)
    if unbounded:
        add("REVIEW", "boundedness", f"contains broad terms that need explicit bounds: {', '.join(unbounded[:5])}")

    implementation_terms = matching_terms(text, IMPLEMENTATION_REQUIREMENT_TERMS)
    if implementation_terms:
        add("REVIEW", "outcome-focus", f"mentions implementation terms; confirm this is intended: {', '.join(implementation_terms[:5])}")

    if not matching_terms(text, ACTOR_TERMS):
        add("REVIEW", "actor", "actor or responsible subject is not obvious")

    if likely_compound_requirement(requirement):
        add("REVIEW", "scope", "may combine multiple obligations that could need separate sub-requirements")

    if re.search(r"\b(?:must|should|needs?|allow|support|persist|store|route)\b", text.lower()) and not matching_terms(text, FAILURE_BEHAVIOR_TERMS):
        add("INFO", "failure-behavior", "no explicit failure or unavailable-path behavior detected")

    title_key = " ".join(words_in(requirement.title))
    title_duplicates = duplicate_titles.get(title_key, [])
    if title_key and len(title_duplicates) > 1:
        others = ", ".join(item.id for item in title_duplicates if item.id != requirement.id)
        add("REVIEW", "redundancy", f"title matches another requirement: {others}")

    body_key = " ".join(body_words)
    body_duplicates = duplicate_bodies.get(body_key, [])
    if body_key and len(body_key) > 40 and len(body_duplicates) > 1:
        others = ", ".join(item.id for item in body_duplicates if item.id != requirement.id)
        add("REVIEW", "redundancy", f"body matches another requirement: {others}")

    if not work_items:
        add("REVIEW", "planning", "no backlog work item maps to this requirement")
    elif not active_items and not completed_items:
        add("REVIEW", "planning", "only rejected or cancelled work maps to this requirement")

    status = traceability_status(requirement, traceability)
    if status == "missing":
        add("REVIEW", "traceability", "not mentioned in TRACEABILITY.md")
    elif status == "area":
        add("REVIEW", "traceability", "listed only through an unmapped requirement area in TRACEABILITY.md")

    if work_items and not completed_items:
        add("INFO", "evidence", "no merged or rolled-out work item maps to this requirement yet")

    return findings


def duplicate_requirement_groups(requirements: list[Requirement], key_func) -> dict[str, list[Requirement]]:
    groups: dict[str, list[Requirement]] = {}
    for requirement in requirements:
        key = key_func(requirement)
        if key:
            groups.setdefault(key, []).append(requirement)
    return {key: values for key, values in groups.items() if len(values) > 1}


def requirement_references(text: str) -> list[str]:
    return sorted(set(re.findall(r"\b[BEO]\.[A-Za-z][A-Za-z0-9]*\.\d{2}(?:\.[a-z]+)*\b", text)))


def traceability_links() -> list[TraceabilityLink]:
    path = MANAGEMENT_DIR / "TRACEABILITY.md"
    if not path.exists():
        return []

    links: list[TraceabilityLink] = []
    for line_number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
        stripped = line.strip()
        if not stripped.startswith("| `"):
            continue
        columns = [column.strip() for column in stripped.strip("|").split("|")]
        if len(columns) < 4:
            continue
        requirement_id_column, work_item_id_column, state, evidence = columns[:4]
        links.append(
            TraceabilityLink(
                requirement_id=requirement_id_column.strip("`"),
                work_item_id=work_item_id_column.strip("`"),
                state=state,
                evidence=evidence,
                line=line_number,
            )
        )
    return links


def traceability_links_for(requirement: Requirement, links: list[TraceabilityLink]) -> list[TraceabilityLink]:
    return [link for link in links if requirement_matches_id(requirement, link.requirement_id)]


def evidence_paths(link: TraceabilityLink) -> list[str]:
    paths = re.findall(r"`([^`]+)`", link.evidence)
    return [path for path in paths if "/" in path or "." in Path(path).name]


def requirement_source_terms(requirement: Requirement) -> list[str]:
    ignored = {
        "able",
        "also",
        "and",
        "bot",
        "can",
        "for",
        "from",
        "have",
        "into",
        "may",
        "must",
        "not",
        "our",
        "should",
        "the",
        "this",
        "user",
        "with",
    }
    words = [word for word in words_in(requirement_text(requirement)) if len(word) >= 4 and word not in ignored]
    ordered: list[str] = []
    for word in words:
        if word not in ordered:
            ordered.append(word)
    return ordered[:8]


def tracked_text_files() -> list[str]:
    ignored_suffixes = {".lock", ".png", ".jpg", ".jpeg", ".gif", ".pdf", ".wasm"}
    return [
        path
        for path in tracked_files()
        if not any(path.endswith(suffix) for suffix in ignored_suffixes)
        and not path.startswith(".git/")
        and not path.startswith("target/")
    ]


def source_files_mentioning(terms: list[str], limit: int, implementation_only: bool = False) -> list[str]:
    if not terms:
        return []
    mentions: list[str] = []
    lowered_terms = [term.lower() for term in terms]
    for path in tracked_text_files():
        if implementation_only and not path.startswith(("src/", "tests/", "benches/", "examples/", "scripts/")):
            continue
        if not (path.endswith(".rs") or path.endswith(".toml") or path.endswith(".md") or path.endswith(".py") or path.endswith(".sh")):
            continue
        content = read_repo_file(path).lower()
        if content and any(term in content for term in lowered_terms):
            mentions.append(path)
        if len(mentions) >= limit:
            break
    return mentions


def estimate_effort_band(score: int) -> str:
    for maximum, band in ESTIMATE_HOUR_BANDS:
        if score <= maximum:
            return band
    return "80+"


def requirement_complexity_score(requirement: Requirement, work_items: list[WorkItem], audit_findings: list[AuditFinding]) -> int:
    text = requirement_text(requirement)
    bullet_count = len([line for line in requirement.body.splitlines() if re.match(r"\s*(?:[-*]|\d+\.)\s+", line)])
    score = 2
    score += min(6, len(words_in(text)) // 25)
    score += min(4, bullet_count // 2)
    score += min(4, len(requirement_references(text)))
    score += 2 if not work_items else 0
    score += sum(2 for finding in audit_findings if finding.severity == "BLOCKER")
    score += min(4, sum(1 for finding in audit_findings if finding.severity == "REVIEW"))
    if matching_terms(text, IMPLEMENTATION_REQUIREMENT_TERMS):
        score += 2
    if matching_terms(text, UNBOUNDED_REQUIREMENT_TERMS):
        score += 2
    return score


def evidence_path_statuses(paths: list[str]) -> list[tuple[str, str]]:
    tracked = set(tracked_files())
    statuses: list[tuple[str, str]] = []
    for path in paths:
        full_path = REPO_ROOT / path
        if path in tracked:
            statuses.append((path, "tracked"))
        elif full_path.exists():
            statuses.append((path, "exists but is not tracked"))
        else:
            statuses.append((path, "missing"))
    return statuses


def sync_signal_counts(signals: list[str]) -> tuple[int, int]:
    blocker_count = sum(1 for signal in signals if signal.startswith("BLOCKER:"))
    review_count = sum(1 for signal in signals if signal.startswith("REVIEW:"))
    return blocker_count, review_count


def source_like_file(path: str) -> bool:
    return path.endswith((".rs", ".toml", ".yaml", ".yml", ".json", ".sh", ".py", ".md"))


def scan_file_for_tech_debt(path: str, long_file_lines: int) -> list[TechDebtFinding]:
    if not source_like_file(path):
        return []
    content = read_repo_file(path)
    if not content:
        return []

    findings: list[TechDebtFinding] = []
    lines = content.splitlines()
    test_module_depth = 0
    pending_cfg_test = False
    if long_file_lines > 0 and len(lines) > long_file_lines:
        findings.append(
            TechDebtFinding(
                "maintainability",
                "REVIEW",
                path,
                1,
                f"large file has {len(lines)} lines; consider whether responsibilities can be split",
            )
        )

    clone_count = content.count(".clone()")
    if path.startswith("src/") and path.endswith(".rs") and clone_count >= 10:
        findings.append(
            TechDebtFinding(
                "performance",
                "REVIEW",
                path,
                1,
                f"contains {clone_count} `.clone()` calls; inspect for avoidable allocations",
            )
        )

    for line_number, line in enumerate(lines, start=1):
        stripped = line.strip()
        if any(name in line for name in ["TECH_DEBT_MARKERS", "SENSITIVE_TERMS", "RISKY_RUST_SHORTCUTS"]):
            continue
        starts_test_module = False
        if path.startswith("src/") and path.endswith(".rs"):
            if "#[cfg(test)]" in stripped:
                pending_cfg_test = True
            elif pending_cfg_test and re.search(r"\bmod\s+tests\b", stripped):
                starts_test_module = True
                test_module_depth = max(1, stripped.count("{") - stripped.count("}"))
                pending_cfg_test = False
            elif stripped and not stripped.startswith("#"):
                pending_cfg_test = False

        upper_line = line.upper()
        if not path.endswith(".md"):
            for marker in TECH_DEBT_MARKERS:
                if marker in upper_line:
                    findings.append(TechDebtFinding("maintainability", "REVIEW", path, line_number, f"{marker} marker is present"))
                    break

        if path.startswith("src/") and path.endswith(".rs") and test_module_depth == 0 and not stripped.startswith("//"):
            for shortcut in RISKY_RUST_SHORTCUTS:
                if shortcut in line:
                    findings.append(TechDebtFinding("reliability", "REVIEW", path, line_number, f"Rust shortcut `{shortcut}` needs review outside tests"))
                    break

        if not path.startswith("management/") and not path.endswith(".md"):
            lowered = line.lower()
            for term in SENSITIVE_TERMS:
                if (
                    term in lowered
                    and "${{ secrets." not in lowered
                    and "env::var" not in lowered
                    and "std::env" not in lowered
                    and re.search(r"[:=]\s*[\"'][^\"']{6,}[\"']", line)
                ):
                    findings.append(TechDebtFinding("security", "REVIEW", path, line_number, f"possible hard-coded sensitive literal involving `{term}`"))
                    break

        if test_module_depth > 0 and not starts_test_module:
            test_module_depth += stripped.count("{") - stripped.count("}")
            test_module_depth = max(0, test_module_depth)

    return findings


def chase_tech_debts(limit: int, long_file_lines: int) -> list[TechDebtFinding]:
    findings: list[TechDebtFinding] = []
    for path in tracked_text_files():
        findings.extend(scan_file_for_tech_debt(path, long_file_lines))

    category_order = {"reliability": 0, "security": 1, "performance": 2, "maintainability": 3}
    findings.sort(key=lambda finding: (category_order.get(finding.category, 99), finding.path, finding.line, finding.message))
    return findings if limit <= 0 else findings[:limit]


def ledger_entries(path: Path) -> list[LedgerEntry]:
    if not path.exists():
        return []
    lines = path.read_text(encoding="utf-8").splitlines()
    starts: list[tuple[int, re.Match[str]]] = []
    for index, line in enumerate(lines):
        match = LEDGER_HEADING_RE.match(line)
        if match:
            starts.append((index, match))

    entries: list[LedgerEntry] = []
    for position, (start, match) in enumerate(starts):
        if "<" in match.group("title"):
            continue
        end = starts[position + 1][0] if position + 1 < len(starts) else len(lines)
        body_lines = lines[start + 1 : end]
        body = "\n".join(body_lines).strip()
        status_match = re.search(r"^Status:\s*(?P<status>.+?)\s*$", body, flags=re.MULTILINE)
        raw_id = match.group("id").strip("`")
        entries.append(
            LedgerEntry(
                id=raw_id,
                title=match.group("title"),
                status=status_match.group("status").strip("` ") if status_match else None,
                path=path,
                line=start + 1,
                body=body,
            )
        )
    return entries


def next_ledger_id(entries: list[LedgerEntry], prefix: str) -> str:
    highest = 0
    for entry in entries:
        match = re.fullmatch(rf"{re.escape(prefix)}-(\d{{4}})", entry.id)
        if match:
            highest = max(highest, int(match.group(1)))
    return f"{prefix}-{highest + 1:04d}"


def append_markdown_entry(path: Path, entry: str) -> None:
    content = path.read_text(encoding="utf-8") if path.exists() else ""
    separator = "\n\n" if content.rstrip() else ""
    path.write_text(f"{content.rstrip()}{separator}{entry.rstrip()}\n", encoding="utf-8")


def insert_markdown_entry_before(path: Path, marker: str, entry: str) -> None:
    content = path.read_text(encoding="utf-8") if path.exists() else ""
    marker_index = content.find(marker)
    if marker_index < 0:
        append_markdown_entry(path, entry)
        return
    before = content[:marker_index].rstrip()
    after = content[marker_index:].lstrip("\n")
    path.write_text(f"{before}\n\n{entry.rstrip()}\n\n{after}", encoding="utf-8")


def replace_ledger_entry(path: Path, entry_id: str, replacement_body: str) -> bool:
    lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
    start: int | None = None
    for index, line in enumerate(lines):
        match = LEDGER_HEADING_RE.match(line.rstrip("\n"))
        if match and match.group("id").strip("`") == entry_id:
            start = index
            break
    if start is None:
        return False

    end = len(lines)
    for index in range(start + 1, len(lines)):
        if LEDGER_HEADING_RE.match(lines[index].rstrip("\n")):
            end = index
            break
    replacement_lines = [line if line.endswith("\n") else f"{line}\n" for line in replacement_body.rstrip().splitlines()]
    lines[start:end] = [*replacement_lines, "\n"]
    path.write_text("".join(lines), encoding="utf-8")
    return True


def update_ledger_status(entry: LedgerEntry, status: str, closure_lines: list[str]) -> None:
    lines = [f"### {entry.id} -- {entry.title}", *entry.body.splitlines()]
    updated: list[str] = []
    replaced = False
    for line in lines:
        if line.startswith("Status:"):
            updated.append(f"Status: {status}")
            replaced = True
        else:
            updated.append(line)
    if not replaced:
        updated.insert(1, f"Status: {status}")
    if closure_lines:
        updated.extend(["", *closure_lines])
    if not replace_ledger_entry(entry.path, entry.id, "\n".join(updated)):
        raise ValueError(f"{entry.id} was not found in {relative(entry.path)}")


def ledger_entry_by_id(path: Path, entry_id: str) -> LedgerEntry:
    for entry in ledger_entries(path):
        if entry.id == entry_id:
            return entry
    raise ValueError(f"{entry_id} was not found in {relative(path)}")


def state_counts(model: ManagementModel) -> dict[str, int]:
    counts = {state: 0 for state in VALID_STATES}
    for item in model.work_items.values():
        counts[item.state] = counts.get(item.state, 0) + 1
    return counts


def last_state_date(item: WorkItem) -> str | None:
    if item.state in item.timeline:
        return item.timeline[item.state]
    if item.timeline:
        return list(item.timeline.values())[-1]
    return None


def stale_work_items(model: ManagementModel, threshold_days: int) -> list[StaleWorkItem]:
    today = date.today()
    stale_states = {"Under Planning", "Planned", "Started", "In Code Review", "Integrated", "QA"}
    stale: list[StaleWorkItem] = []
    for item in sorted(model.work_items.values(), key=lambda candidate: candidate.id):
        if item.state not in stale_states:
            continue
        state_date = last_state_date(item)
        if not state_date:
            stale.append(StaleWorkItem(item, None, None, "missing dated state trail"))
            continue
        try:
            age_days = (today - datetime.strptime(state_date, "%Y-%m-%d").date()).days
        except ValueError:
            stale.append(StaleWorkItem(item, state_date, None, "invalid state date"))
            continue
        if age_days >= threshold_days:
            stale.append(StaleWorkItem(item, state_date, age_days, f"{age_days} days in or since current state"))
    return stale


def open_ledger_entries(path: Path) -> list[LedgerEntry]:
    closed_statuses = {"Closed", "Adopted", "Rejected", "Expired", "Released", "Rolled back"}
    return [entry for entry in ledger_entries(path) if (entry.status or "Open") not in closed_statuses]


def traceability_gaps(model: ManagementModel) -> list[Requirement]:
    links = traceability_links()
    return [
        requirement
        for requirement in sorted(model.requirements.values(), key=lambda candidate: candidate.id)
        if not traceability_links_for(requirement, links)
    ]


def unmapped_requirements(model: ManagementModel) -> list[Requirement]:
    return [
        requirement
        for requirement in sorted(model.requirements.values(), key=lambda candidate: candidate.id)
        if not requirement_work_items(model, requirement)
    ]


