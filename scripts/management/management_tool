def branch_owner_errors(item: WorkItem, branch_ref: BranchRef, explicit_user: str | None = None) -> list[str]:
    errors: list[str] = []
    if not branch_ref.is_feature and branch_ref.owner is None:
        errors.append("ordinary work branches must use `<developer_username>/<work item id>`")
    if branch_ref.is_feature:
        if explicit_user and item.owner and explicit_user.lower() != item.owner.lower():
            errors.append(f"--user {explicit_user} does not match backlog owner {item.owner}")
        return errors
    if item.owner is None:
        errors.append(f"{item.id} has no backlog owner")
    elif branch_ref.owner and branch_ref.owner.lower() != item.owner.lower():
        errors.append(f"branch owner {branch_ref.owner} does not match backlog owner {item.owner}")
    if explicit_user and item.owner and explicit_user.lower() != item.owner.lower():
        errors.append(f"--user {explicit_user} does not match backlog owner {item.owner}")
    return errors


def started_work_errors(model: ManagementModel, item: WorkItem, branch_ref: BranchRef, explicit_user: str | None = None) -> list[str]:
    errors: list[str] = []
    if item.requirement_id not in model.requirements:
        errors.append(f"{item.id} references missing requirement {item.requirement_id}")
    if item.state != "Started":
        errors.append(f"{item.id} is in state {item.state}; engineering work branches must reference a Started work item")
    errors.extend(branch_owner_errors(item, branch_ref, explicit_user))
    return errors


def same_requirement_items(model: ManagementModel, item: WorkItem) -> list[WorkItem]:
    return sorted(
        [candidate for candidate in model.work_items.values() if candidate.requirement_id == item.requirement_id and candidate.id != item.id],
        key=lambda candidate: candidate.id,
    )


def completed_work_items(items: list[WorkItem]) -> list[WorkItem]:
    return [item for item in items if item.state in {"Merged", "Rolled Out"}]


def open_work_items(items: list[WorkItem]) -> list[WorkItem]:
    return [item for item in items if item.state != "Merged" and not terminal_state(item.state)]


def words_in(text: str) -> list[str]:
    return re.findall(r"[A-Za-z0-9][A-Za-z0-9_-]*", text.lower())


def requirement_text(requirement: Requirement) -> str:
    return f"{requirement.title}\n{requirement.body}"


def normalized_requirement_text(requirement: Requirement) -> str:
    return " ".join(words_in(requirement_text(requirement)))


def requirement_work_items(model: ManagementModel, requirement: Requirement) -> list[WorkItem]:
    related_prefix = f"{requirement.id}."
    return sorted(
        [
            item
            for item in model.work_items.values()
            if item.requirement_id == requirement.id or (not requirement.subtopics and item.requirement_id.startswith(related_prefix))
        ],
        key=lambda item: item.id,
    )


def requirement_matches_id(requirement: Requirement, candidate_id: str) -> bool:
    return candidate_id == requirement.id or (not requirement.subtopics and candidate_id.startswith(f"{requirement.id}."))


def descendant_requirements(model: ManagementModel, requirement: Requirement) -> list[Requirement]:
    if requirement.subtopics:
        return []
    return sorted(
        [candidate for candidate in model.requirements.values() if candidate.id.startswith(f"{requirement.id}.")],
        key=lambda candidate: candidate.id,
    )


def traceability_status(requirement: Requirement, links_or_text: list[TraceabilityLink] | str | None = None) -> str:
    if links_or_text is None:
        links = traceability_links()
    elif isinstance(links_or_text, str):
        links = traceability_links_from_text(links_or_text)
    else:
        links = links_or_text
    if any(link.requirement_id == requirement.id for link in links):
        return "direct"
    if not requirement.subtopics and any(link.requirement_id.startswith(f"{requirement.id}.") for link in links):
        return "child"
    return "missing"


def contains_term(text: str, term: str) -> bool:
    if any(character in term for character in "/-"):
        return term in text
    return re.search(rf"\b{re.escape(term)}\b", text) is not None


def matching_terms(text: str, terms: list[str]) -> list[str]:
    lowered = text.lower()
    return [term for term in terms if contains_term(lowered, term)]


def term_occurrence_pattern(term: str) -> str:
    escaped = re.escape(term)
    if any(character in term for character in "/-"):
        return escaped
    return rf"\b{escaped}\b"


def broad_term_occurrence_statuses(text: str) -> tuple[list[str], list[str], list[str]]:
    active: list[str] = []
    acknowledged: list[str] = []
    mixed: list[str] = []
    for term in UNBOUNDED_REQUIREMENT_TERMS:
        term_pattern = term_occurrence_pattern(term)
        occurrences = [match.span() for match in re.finditer(term_pattern, text, flags=re.IGNORECASE)]
        if not occurrences:
            continue
        emphasized = {
            match.span("term")
            for match in re.finditer(
                rf"(?<!\*)\*(?!\*)(?P<term>{term_pattern})\*(?!\*)",
                text,
                flags=re.IGNORECASE,
            )
        }
        if emphasized:
            acknowledged.append(term)
            if any(span not in emphasized for span in occurrences):
                mixed.append(term)
        else:
            active.append(term)
    return active, acknowledged, mixed


def likely_compound_requirement(requirement: Requirement) -> bool:
    body = requirement.body
    bullet_lines = [line for line in body.splitlines() if re.match(r"\s*(?:[-*]|\d+\.)\s+", line)]
    obligation_markers = len(re.findall(r"\b(?:and|also|or)\b", body.lower()))
    return len(bullet_lines) >= 4 or obligation_markers >= 5


def audit_requirement(
    model: ManagementModel,
    requirement: Requirement,
    _traceability: str,
    duplicate_titles: dict[str, list[Requirement]],
    duplicate_bodies: dict[str, list[Requirement]],
) -> list[AuditFinding]:
    findings: list[AuditFinding] = []
    body = requirement.body.strip()
    body_words = words_in(body)

    def add(severity: str, category: str, message: str) -> None:
        findings.append(AuditFinding(severity, requirement, category, message))

    if not body or body.lower() in {"tbd", "todo"}:
        add("BLOCKER", "clarity", "requirement body is empty or TBD")

    title_key = " ".join(words_in(requirement.title))
    title_duplicates = duplicate_titles.get(title_key, [])
    if title_key and len(title_duplicates) > 1:
        others = ", ".join(item.id for item in title_duplicates if item.id != requirement.id)
        add("REVIEW", "redundancy", f"title matches another requirement: {others}")

    body_key = " ".join(body_words)
    body_duplicates = duplicate_bodies.get(body_key, [])
    if body_key and len(body_key) > 40 and len(body_duplicates) > 1:
        others = ", ".join(item.id for item in body_duplicates if item.id != requirement.id)
        add("REVIEW", "redundancy", f"body matches another requirement: {others}")

    return findings


def requirement_semantic_prompts(requirement: Requirement) -> list[SemanticPrompt]:
    text = requirement_text(requirement)
    body = requirement.body.strip()
    if not body or body.lower() in {"tbd", "todo"}:
        return []

    prompts: list[SemanticPrompt] = []

    def add(
        category: str,
        message: str,
        terms: list[str] | tuple[str, ...] = (),
        status: str = "active",
        mixed_terms: list[str] | tuple[str, ...] = (),
    ) -> None:
        prompts.append(SemanticPrompt(status, requirement, category, message, tuple(terms), tuple(mixed_terms)))

    if len(words_in(body)) < 8:
        add("clarity", "requirement body is very short; confirm that it is sufficiently articulated")

    active_broad_terms, acknowledged_broad_terms, mixed_broad_terms = broad_term_occurrence_statuses(text)
    if active_broad_terms:
        add(
            "boundedness",
            f"broad terms need semantic bounds review: {', '.join(active_broad_terms[:5])}",
            active_broad_terms[:5],
        )
    if acknowledged_broad_terms:
        mixed_note = (
            f"; the requirement-level acknowledgement also covers plain occurrences of: {', '.join(mixed_broad_terms[:5])}"
            if mixed_broad_terms
            else ""
        )
        add(
            "boundedness",
            f"author emphasis acknowledges intentional broad terms: {', '.join(acknowledged_broad_terms[:5])}{mixed_note}",
            acknowledged_broad_terms[:5],
            status="acknowledged",
            mixed_terms=mixed_broad_terms[:5],
        )

    implementation_terms = matching_terms(text, IMPLEMENTATION_REQUIREMENT_TERMS)
    if implementation_terms:
        add(
            "outcome-focus",
            f"implementation terms need semantic outcome review: {', '.join(implementation_terms[:5])}",
            implementation_terms[:5],
        )

    if not matching_terms(text, ACTOR_TERMS):
        add("actor", "confirm that the actor or responsible subject is clear in context")

    if likely_compound_requirement(requirement):
        add("scope", "confirm whether the combined obligations should remain coordinated or become sub-requirements")

    if re.search(r"\b(?:must|should|needs?|allow|support|persist|store|route)\b", text.lower()) and not matching_terms(text, FAILURE_BEHAVIOR_TERMS):
        add("failure-behavior", "no explicit failure clause was detected; determine semantically whether one is applicable or defined elsewhere")

    return prompts


def duplicate_requirement_groups(requirements: list[Requirement], key_func) -> dict[str, list[Requirement]]:
    groups: dict[str, list[Requirement]] = {}
    for requirement in requirements:
        key = key_func(requirement)
        if key:
            groups.setdefault(key, []).append(requirement)
    return {key: values for key, values in groups.items() if len(values) > 1}


def requirement_references(text: str) -> list[str]:
    return sorted(set(re.findall(r"\b[BEO]\.[A-Za-z][A-Za-z0-9]*\.\d{2}(?:\.[a-z]+)*\b", text)))


def traceability_current_links_section_bounds(lines: list[str]) -> tuple[int, int] | None:
    headings = [
        index
        for index, line in enumerate(lines)
        if line.strip() == TRACEABILITY_CURRENT_LINKS_HEADING
    ]
    if len(headings) != 1:
        return None
    heading_index = headings[0]
    end_index = next(
        (
            index
            for index in range(heading_index + 1, len(lines))
            if LEVEL_TWO_HEADING_RE.match(lines[index].strip())
        ),
        len(lines),
    )
    return heading_index, end_index


def traceability_table_cells(line: str) -> list[str] | None:
    stripped = line.strip()
    if not stripped.startswith("|") or not stripped.endswith("|"):
        return None
    return [cell.strip() for cell in stripped[1:-1].split("|")]


def is_traceability_table_header(line: str) -> bool:
    cells = traceability_table_cells(line)
    return cells is not None and tuple(cells) == TRACEABILITY_TABLE_COLUMNS


def is_traceability_table_separator(line: str) -> bool:
    cells = traceability_table_cells(line)
    return (
        cells is not None
        and len(cells) == len(TRACEABILITY_TABLE_COLUMNS)
        and all(TRACEABILITY_TABLE_SEPARATOR_CELL_RE.fullmatch(cell) for cell in cells)
    )


def traceability_current_links_table_bounds(lines: list[str]) -> tuple[int, int, int, int] | None:
    section = traceability_current_links_section_bounds(lines)
    if section is None:
        return None
    heading_index, end_index = section
    nonblank = [index for index in range(heading_index + 1, end_index) if lines[index].strip()]
    if len(nonblank) < 2:
        return None
    header_index, separator_index = nonblank[:2]
    if (
        not is_traceability_table_header(lines[header_index])
        or not is_traceability_table_separator(lines[separator_index])
        or separator_index != header_index + 1
    ):
        return None
    return heading_index, header_index, separator_index, end_index


def traceability_current_link_lines(text: str) -> list[tuple[int, str]]:
    lines = text.splitlines()
    table = traceability_current_links_table_bounds(lines)
    if table is None:
        return []
    _, _, separator_index, end_index = table
    return [
        (index + 1, lines[index])
        for index in range(separator_index + 1, end_index)
    ]


def traceability_links_from_text(text: str) -> list[TraceabilityLink]:
    links: list[TraceabilityLink] = []
    for line_number, line in traceability_current_link_lines(text):
        columns = traceability_table_cells(line)
        if columns is None or len(columns) != 4:
            continue
        requirement_id_column, work_item_id_column, state, evidence = columns
        requirement_match = re.fullmatch(r"`([^`]+)`", requirement_id_column)
        work_item_match = re.fullmatch(r"`([^`]+)`", work_item_id_column)
        if requirement_match is None or work_item_match is None:
            continue
        links.append(
            TraceabilityLink(
                requirement_id=requirement_match.group(1),
                work_item_id=work_item_match.group(1),
                state=state,
                evidence=evidence,
                line=line_number,
            )
        )
    return links


def traceability_links() -> list[TraceabilityLink]:
    path = MANAGEMENT_DIR / "TRACEABILITY.md"
    if not path.exists():
        return []
    return traceability_links_from_text(path.read_text(encoding="utf-8"))


def traceability_links_for(requirement: Requirement, links: list[TraceabilityLink]) -> list[TraceabilityLink]:
    return [link for link in links if requirement_matches_id(requirement, link.requirement_id)]


def evidence_paths(link: TraceabilityLink) -> list[str]:
    paths = re.findall(r"`([^`]+)`", link.evidence)
    return [path for path in paths if "/" in path or "." in Path(path).name]


def unmapped_requirement_area_acknowledgements_from_text(text: str) -> list[CoverageAcknowledgement]:
    acknowledgements: list[CoverageAcknowledgement] = []
    in_unmapped_areas = False
    for line_number, line in enumerate(text.splitlines(), start=1):
        stripped = line.strip()
        if stripped.startswith("## ") and not stripped.startswith("### "):
            in_unmapped_areas = stripped == "## Unmapped Requirement Areas"
            continue
        if not in_unmapped_areas:
            continue
        match = re.match(
            r"^(?:[-*]|\d+\.)\s+`(?P<pattern>[BEO]\.[A-Za-z][A-Za-z0-9]*\.(?:\d{2}(?:\.[a-z]+)*|\*))`\s*(?:--\s*)?(?P<description>.*)$",
            stripped,
        )
        if match:
            acknowledgements.append(
                CoverageAcknowledgement(
                    pattern=match.group("pattern"),
                    description=match.group("description").strip(),
                    line=line_number,
                )
            )
    return acknowledgements


def unmapped_requirement_area_acknowledgements() -> list[CoverageAcknowledgement]:
    path = MANAGEMENT_DIR / "TRACEABILITY.md"
    if not path.exists():
        return []
    return unmapped_requirement_area_acknowledgements_from_text(path.read_text(encoding="utf-8"))


def coverage_acknowledgement_matches(requirement: Requirement, acknowledgement: CoverageAcknowledgement) -> bool:
    if acknowledgement.pattern.endswith(".*"):
        return requirement.id.startswith(f"{acknowledgement.pattern[:-2]}.")
    return requirement.id == acknowledgement.pattern


def requirement_coverage_acknowledgements(
    requirement: Requirement,
    acknowledgements: list[CoverageAcknowledgement] | None = None,
) -> list[dict[str, object]]:
    candidates = acknowledgements if acknowledgements is not None else unmapped_requirement_area_acknowledgements()
    return [
        {
            "pattern": acknowledgement.pattern,
            "description": acknowledgement.description,
            "line": acknowledgement.line,
        }
        for acknowledgement in candidates
        if coverage_acknowledgement_matches(requirement, acknowledgement)
    ]


def requirement_work_coverage(model: ManagementModel, requirement: Requirement) -> dict[str, object]:
    items = requirement_work_items(model, requirement)
    completed = completed_work_items(items)
    abandoned = [
        item
        for item in items
        if item.state in {"Rejected", "Cancelled"} or superseded_work_id(item.state) is not None
    ]
    active = [item for item in items if item not in completed and item not in abandoned]
    if not items:
        status = "unplanned"
    elif active:
        status = "active"
    elif completed and abandoned:
        status = "mixed"
    elif completed:
        status = "completed"
    else:
        status = "abandoned"

    by_state = {
        state: sum(1 for item in items if item.state == state)
        for state in sorted({item.state for item in items})
    }
    by_motivation = {
        motivation: sum(1 for item in items if item.motivation == motivation)
        for motivation in VALID_MOTIVATIONS
        if any(item.motivation == motivation for item in items)
    }
    item_payloads = [
        {
            "id": item.id,
            "requirement_id": item.requirement_id,
            "relation": "direct" if item.requirement_id == requirement.id else "descendant",
            "state": item.state,
            "motivation": item.motivation,
        }
        for item in items
    ]
    return {
        "status": status,
        "count": len(items),
        "direct_count": sum(1 for item in items if item.requirement_id == requirement.id),
        "descendant_count": sum(1 for item in items if item.requirement_id != requirement.id),
        "active_count": len(active),
        "completed_count": len(completed),
        "abandoned_count": len(abandoned),
        "by_state": by_state,
        "by_motivation": by_motivation,
        "items": item_payloads,
    }


def existing_evidence_paths_for_link(link: TraceabilityLink) -> list[str]:
    existing: list[str] = []
    for path in evidence_paths(link):
        try:
            canonical = canonical_repo_path(path)
        except ValueError:
            continue
        if (REPO_ROOT / canonical).exists():
            existing.append(canonical)
    return sorted(set(existing))


def requirement_evidence_coverage(
    model: ManagementModel,
    requirement: Requirement,
    links: list[TraceabilityLink] | None = None,
) -> dict[str, object]:
    all_links = links if links is not None else traceability_links()
    requirement_links = traceability_links_for(requirement, all_links)
    work_coverage = requirement_work_coverage(model, requirement)
    item_ids = {item["id"] for item in work_coverage["items"]}
    completed_ids = {
        item["id"]
        for item in work_coverage["items"]
        if item["state"] in {"Merged", "Rolled Out"}
    }
    active_ids = {
        item["id"]
        for item in work_coverage["items"]
        if item["state"] not in {"Merged", "Rolled Out", "Rejected", "Cancelled"}
        and not str(item["state"]).startswith("Superseded by ")
    }
    links_by_work: dict[str, list[TraceabilityLink]] = {
        work_item_id: [link for link in requirement_links if link.work_item_id == work_item_id]
        for work_item_id in item_ids
    }
    missing_rows = sorted(work_item_id for work_item_id in completed_ids if not links_by_work[work_item_id])
    missing_evidence = sorted(
        work_item_id
        for work_item_id in completed_ids
        if links_by_work[work_item_id]
        and not any(existing_evidence_paths_for_link(link) for link in links_by_work[work_item_id])
    )
    if not item_ids or work_coverage["status"] == "abandoned":
        status = "not_applicable"
    elif missing_rows or missing_evidence:
        status = "gap"
    elif active_ids:
        status = "pending"
    elif completed_ids:
        status = "evidenced"
    else:
        status = "not_applicable"
    return {
        "status": status,
        "completed_work_item_ids": sorted(completed_ids),
        "pending_work_item_ids": sorted(active_ids),
        "missing_traceability_work_item_ids": missing_rows,
        "missing_evidence_work_item_ids": missing_evidence,
        "links": [
            {
                "requirement_id": link.requirement_id,
                "work_item_id": link.work_item_id,
                "state": link.state,
                "evidence": link.evidence,
                "line": link.line,
                "existing_evidence_paths": existing_evidence_paths_for_link(link),
            }
            for link in requirement_links
        ],
    }


def requirement_source_terms(requirement: Requirement) -> list[str]:
    ignored = {
        "able",
        "also",
        "and",
        "bot",
        "can",
        "for",
        "from",
        "have",
        "into",
        "may",
        "must",
        "not",
        "our",
        "should",
        "the",
        "this",
        "user",
        "with",
    }
    words = [word for word in words_in(requirement_text(requirement)) if len(word) >= 4 and word not in ignored]
    ordered: list[str] = []
    for word in words:
        if word not in ordered:
            ordered.append(word)
    return ordered[:8]


def tracked_text_files() -> list[str]:
    ignored_suffixes = {".lock", ".png", ".jpg", ".jpeg", ".gif", ".pdf", ".wasm"}
    return [
        path
        for path in tracked_files()
        if not any(path.endswith(suffix) for suffix in ignored_suffixes)
        and not path.startswith(".git/")
        and not path.startswith("target/")
    ]


def source_files_mentioning(terms: list[str], limit: int, implementation_only: bool = False) -> list[str]:
    if not terms:
        return []
    mentions: list[str] = []
    lowered_terms = [term.lower() for term in terms]
    for path in tracked_text_files():
        if implementation_only and not path.startswith(("src/", "tests/", "benches/", "examples/", "scripts/")):
            continue
        if not (path.endswith(".rs") or path.endswith(".toml") or path.endswith(".md") or path.endswith(".py") or path.endswith(".sh")):
            continue
        content = read_repo_file(path).lower()
        if content and any(term in content for term in lowered_terms):
            mentions.append(path)
        if limit > 0 and len(mentions) >= limit:
            break
    return mentions


def estimate_effort_band(score: int) -> str:
    for maximum, band in ESTIMATE_HOUR_BANDS:
        if score <= maximum:
            return band
    return "80+"


def requirement_structural_complexity_score(requirement: Requirement) -> int:
    text = requirement_text(requirement)
    bullet_count = len([line for line in requirement.body.splitlines() if re.match(r"\s*(?:[-*]|\d+\.)\s+", line)])
    score = 2
    score += min(6, len(words_in(text)) // 25)
    score += min(4, bullet_count // 2)
    score += min(4, len(requirement_references(text)))
    return score


def requirement_estimate_decision(
    requirement: Requirement,
    quality_findings: list[AuditFinding],
    prompts: list[SemanticPrompt],
) -> EstimateDecision:
    blockers = [finding for finding in quality_findings if finding.severity == "BLOCKER"]
    reviews = [finding for finding in quality_findings if finding.severity == "REVIEW"]
    active_prompts = [prompt for prompt in prompts if prompt.status == "active"]
    acknowledged_sizing_prompts = [
        prompt
        for prompt in prompts
        if prompt.status == "acknowledged" and prompt.category in {"boundedness", "scope"}
    ]

    if blockers:
        readiness = "NOT READY"
    elif active_prompts:
        readiness = "SEMANTIC REVIEW REQUIRED"
    elif reviews:
        readiness = "NEEDS REFINEMENT"
    else:
        readiness = "READY FOR PLANNING"

    uncertainty_drivers = [
        "deterministic structural signals do not establish delivery scope, dependencies, or effort"
    ]
    if blockers:
        uncertainty_drivers.append("deterministic quality blockers must be resolved before delivery sizing")
    uncertainty_drivers.extend(
        f"active {prompt.category} prompt requires semantic disposition"
        for prompt in active_prompts
    )
    for prompt in acknowledged_sizing_prompts:
        detail = f": {', '.join(prompt.terms)}" if prompt.terms else ""
        uncertainty_drivers.append(f"intentional {prompt.category} is acknowledged{detail}")

    structural_score = requirement_structural_complexity_score(requirement)
    structural_effort_band = estimate_effort_band(structural_score)
    delivery_estimate = "WITHHELD -- semantic sizing required"
    confidence = "NOT ASSESSED"
    return EstimateDecision(
        readiness=readiness,
        delivery_estimate=delivery_estimate,
        structural_score=structural_score,
        structural_effort_band=structural_effort_band,
        confidence=confidence,
        uncertainty_drivers=tuple(uncertainty_drivers),
    )


def evidence_path_statuses(paths: list[str]) -> list[tuple[str, str]]:
    tracked = set(tracked_files())
    statuses: list[tuple[str, str]] = []
    for path in paths:
        full_path = REPO_ROOT / path
        if path in tracked:
            statuses.append((path, "tracked"))
        elif full_path.exists():
            statuses.append((path, "exists but is not tracked"))
        else:
            statuses.append((path, "missing"))
    return statuses


def sync_signal_counts(signals: list[str]) -> tuple[int, int]:
    blocker_count = sum(1 for signal in signals if signal.startswith("BLOCKER:"))
    review_count = sum(1 for signal in signals if signal.startswith("REVIEW:"))
    return blocker_count, review_count


def source_like_file(path: str) -> bool:
    return path.endswith((".rs", ".toml", ".yaml", ".yml", ".json", ".sh", ".py", ".md"))


def scan_file_for_tech_debt(path: str, long_file_lines: int) -> list[TechDebtFinding]:
    if not source_like_file(path):
        return []
    content = read_repo_file(path)
    if not content:
        return []

    findings: list[TechDebtFinding] = []
    lines = content.splitlines()
    test_module_depth = 0
    pending_cfg_test = False
    if long_file_lines > 0 and len(lines) > long_file_lines:
        findings.append(
            TechDebtFinding(
                "maintainability",
                "REVIEW",
                path,
                1,
                f"large file has {len(lines)} lines; consider whether responsibilities can be split",
            )
        )

    clone_count = content.count(".clone()")
    if path.startswith("src/") and path.endswith(".rs") and clone_count >= 10:
        findings.append(
            TechDebtFinding(
                "performance",
                "REVIEW",
                path,
                1,
                f"contains {clone_count} `.clone()` calls; inspect for avoidable allocations",
            )
        )

    for line_number, line in enumerate(lines, start=1):
        stripped = line.strip()
        if any(name in line for name in ["TECH_DEBT_MARKERS", "SENSITIVE_TERMS", "RISKY_RUST_SHORTCUTS"]):
            continue
        starts_test_module = False
        if path.startswith("src/") and path.endswith(".rs"):
            if "#[cfg(test)]" in stripped:
                pending_cfg_test = True
            elif pending_cfg_test and re.search(r"\bmod\s+tests\b", stripped):
                starts_test_module = True
                test_module_depth = max(1, stripped.count("{") - stripped.count("}"))
                pending_cfg_test = False
            elif stripped and not stripped.startswith("#"):
                pending_cfg_test = False

        upper_line = line.upper()
        if not path.endswith(".md"):
            for marker in TECH_DEBT_MARKERS:
                if marker in upper_line:
                    findings.append(TechDebtFinding("maintainability", "REVIEW", path, line_number, f"{marker} marker is present"))
                    break

        if path.startswith("src/") and path.endswith(".rs") and test_module_depth == 0 and not stripped.startswith("//"):
            for shortcut in RISKY_RUST_SHORTCUTS:
                if shortcut in line:
                    findings.append(TechDebtFinding("reliability", "REVIEW", path, line_number, f"Rust shortcut `{shortcut}` needs review outside tests"))
                    break

        if not path.startswith("management/") and not path.endswith(".md"):
            lowered = line.lower()
            for term in SENSITIVE_TERMS:
                if (
                    term in lowered
                    and "${{ secrets." not in lowered
                    and "env::var" not in lowered
                    and "std::env" not in lowered
                    and re.search(r"[:=]\s*[\"'][^\"']{6,}[\"']", line)
                ):
                    findings.append(TechDebtFinding("security", "REVIEW", path, line_number, f"possible hard-coded sensitive literal involving `{term}`"))
                    break

        if test_module_depth > 0 and not starts_test_module:
            test_module_depth += stripped.count("{") - stripped.count("}")
            test_module_depth = max(0, test_module_depth)

    return findings


def chase_tech_debts(limit: int, long_file_lines: int) -> list[TechDebtFinding]:
    findings: list[TechDebtFinding] = []
    for path in tracked_text_files():
        findings.extend(scan_file_for_tech_debt(path, long_file_lines))

    category_order = {"reliability": 0, "security": 1, "performance": 2, "maintainability": 3}
    findings.sort(key=lambda finding: (category_order.get(finding.category, 99), finding.path, finding.line, finding.message))
    return findings if limit <= 0 else findings[:limit]


def validate_ledger_entry_headings(model: ManagementModel, path: Path) -> None:
    expected_level = LEDGER_ENTRY_LEVELS[path.name]
    for line_number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
        candidate = structured_ledger_heading_id(line)
        if candidate is None:
            continue
        level, entry_id = candidate
        if level != expected_level:
            model.error(
                path,
                line_number,
                f"ledger entry {entry_id} uses Markdown heading level {level}; expected level {expected_level}",
            )
        elif LEDGER_HEADING_RE.fullmatch(line) is None:
            model.error(path, line_number, f"malformed ledger entry heading for {entry_id}; expected `<ID> -- <title>`")


def is_documentation_template_entry(
    path: Path,
    lines: list[str],
    start: int,
    match: re.Match[str],
    body: str,
) -> bool:
    template = LEDGER_DOCUMENTATION_TEMPLATES.get(path.name)
    if template is None:
        return False
    enclosing_section = None
    for line in reversed(lines[:start]):
        section_match = LEVEL_TWO_HEADING_RE.match(line)
        if section_match:
            enclosing_section = section_match.group("title")
            break
    raw_id = match.group("id").strip("`")
    title = match.group("title").strip().strip("`")
    body_lines = tuple(line for line in body.splitlines() if line)
    return (
        enclosing_section == template["section"]
        and raw_id == template["id"]
        and title == template["title"]
        and body_lines == template["body_lines"]
    )


def _ledger_entries(path: Path, section_heading: str | None = None) -> list[LedgerEntry]:
    if not path.exists():
        return []
    lines = path.read_text(encoding="utf-8").splitlines()
    scope_start = 0
    scope_end = len(lines)
    if section_heading:
        headings = [index for index, line in enumerate(lines) if line.strip() == section_heading]
        if len(headings) != 1:
            return []
        scope_start = headings[0] + 1
        scope_end = next(
            (
                index
                for index in range(scope_start, len(lines))
                if LEVEL_TWO_HEADING_RE.match(lines[index].strip())
            ),
            len(lines),
        )
    starts: list[tuple[int, re.Match[str]]] = []
    for index in range(scope_start, scope_end):
        line = lines[index]
        match = LEDGER_HEADING_RE.match(line)
        if match:
            starts.append((index, match))

    entries: list[LedgerEntry] = []
    for position, (start, match) in enumerate(starts):
        end = starts[position + 1][0] if position + 1 < len(starts) else scope_end
        body_lines = lines[start + 1 : end]
        body = "\n".join(body_lines).strip()
        if is_documentation_template_entry(path, lines, start, match, body):
            continue
        status_match = re.search(r"^Status:\s*(?P<status>.+?)\s*$", body, flags=re.MULTILINE)
        raw_id = match.group("id").strip("`")
        entries.append(
            LedgerEntry(
                id=raw_id,
                title=match.group("title"),
                status=status_match.group("status").strip("` ") if status_match else None,
                path=path,
                line=start + 1,
                body=body,
            )
        )
    return entries


def ledger_entries(path: Path) -> list[LedgerEntry]:
    return _ledger_entries(path)


def open_bug_report_entries(path: Path | None = None) -> list[LedgerEntry]:
    return _ledger_entries(path or MANAGEMENT_DIR / "BUGS.md", BUGS_OPEN_REPORTS_HEADING)


def validate_traceability(model: ManagementModel) -> None:
    path = MANAGEMENT_DIR / "TRACEABILITY.md"
    if not path.exists():
        return
    text = path.read_text(encoding="utf-8")
    lines = text.splitlines()
    current_link_headings = [
        index
        for index, line in enumerate(lines)
        if line.strip() == TRACEABILITY_CURRENT_LINKS_HEADING
    ]
    if len(current_link_headings) != 1:
        if not current_link_headings:
            model.error(path, 1, "traceability must contain exactly one `## Current Links` section")
        else:
            model.error(
                path,
                current_link_headings[1] + 1,
                "traceability contains more than one `## Current Links` section",
            )
        return

    table = traceability_current_links_table_bounds(lines)
    if table is None:
        model.error(
            path,
            current_link_headings[0] + 1,
            "Current Links must begin with the canonical four-column header and a valid Markdown separator",
        )
        return

    _, _, separator_index, end_index = table
    seen_pairs: dict[tuple[str, str], int] = {}
    for index in range(separator_index + 1, end_index):
        line_number = index + 1
        line = lines[index]
        stripped = line.strip()
        if not stripped:
            continue
        if not stripped.startswith("|"):
            model.error(path, line_number, "Current Links may contain only traceability table rows")
            continue
        columns = traceability_table_cells(line)
        if columns is None or len(columns) != 4:
            model.error(path, line_number, "traceability row must contain exactly four Markdown-table fields")
            continue
        requirement_column, work_column, state, evidence = columns
        requirement_match = re.fullmatch(r"`([^`]+)`", requirement_column)
        work_match = re.fullmatch(r"`([^`]+)`", work_column)
        if not requirement_match or not work_match:
            model.error(path, line_number, "traceability requirement and work item ids must each use one backtick-delimited value")
            continue
        requirement_id_value = requirement_match.group(1)
        work_item_id = work_match.group(1)
        pair = (requirement_id_value, work_item_id)
        if pair in seen_pairs:
            model.error(path, line_number, f"duplicate traceability pair {requirement_id_value} -> {work_item_id}; first used at line {seen_pairs[pair]}")
        else:
            seen_pairs[pair] = line_number
        requirement = model.requirements.get(requirement_id_value)
        work_item = model.work_items.get(work_item_id)
        if requirement is None:
            model.error(path, line_number, f"traceability references missing requirement {requirement_id_value}")
        if work_item is None:
            model.error(path, line_number, f"traceability references missing work item {work_item_id}")
        if requirement and work_item and work_item.requirement_id != requirement_id_value:
            model.error(path, line_number, f"{work_item_id} maps to {work_item.requirement_id}, not {requirement_id_value}")
        if work_item and state != work_item.state:
            model.error(path, line_number, f"traceability state {state} does not match {work_item_id} backlog state {work_item.state}")
        for evidence_path in re.findall(r"`([^`]+)`", evidence):
            if "/" not in evidence_path and "." not in Path(evidence_path).name:
                continue
            try:
                canonical = canonical_repo_path(evidence_path)
            except ValueError as err:
                model.error(path, line_number, str(err))
                continue
            if canonical != evidence_path:
                model.error(path, line_number, f"evidence path is not canonical: {evidence_path}; use {canonical}")
            elif not (REPO_ROOT / canonical).exists():
                model.warning(path, line_number, f"traceability evidence path does not exist: {canonical}")


def _ledger_has_label(entry: LedgerEntry, label: str) -> bool:
    return re.search(rf"^{re.escape(label)}:\s*(?:.*|\n.+)$", entry.body, flags=re.MULTILINE) is not None


def _ledger_field(entry: LedgerEntry, label: str) -> str | None:
    match = re.search(rf"^{re.escape(label)}:\s*(?P<value>.*?)\s*$", entry.body, flags=re.MULTILINE)
    return match.group("value").strip("` ") if match else None


def _ledger_section(entry: LedgerEntry, label: str) -> str:
    match = re.search(
        rf"^{re.escape(label)}:\s*(?P<value>.*(?:\n(?![A-Z][A-Za-z ]+:).*)*)",
        entry.body,
        flags=re.MULTILINE,
    )
    return match.group("value").strip() if match else ""


def _structured_references(text: str) -> set[str]:
    candidates = set(re.findall(r"`([^`]+)`", text))
    return {
        candidate
        for candidate in candidates
        if re.fullmatch(r"(?:[BEO]\.[A-Za-z][A-Za-z0-9]*\.\d{2}(?:\.[a-z]+)*|[BEO][NRFX]\.[A-Za-z][A-Za-z0-9]*\.\d{2}(?:\.[a-z]+)*-\d{3}|(?:BUG|DEC|RISK|INCIDENT|EXP)-\d{4})", candidate)
    }


def release_entry_schema_errors(entry: LedgerEntry) -> list[str]:
    errors: list[str] = []
    try:
        validate_release_version(entry.id)
        validate_iso_date(entry.title.strip("`"))
    except ValueError as err:
        errors.append(str(err))
    for label in RELEASE_REQUIRED_LABELS:
        if not _ledger_has_label(entry, label):
            errors.append(f"release {entry.id} is missing `{label}:`")
    production_decision = _ledger_section(entry, "Production decision").splitlines()[0].strip("` ") if _ledger_section(entry, "Production decision") else ""
    if production_decision not in set(RELEASE_DECISIONS):
        errors.append(f"release {entry.id} has invalid production decision {production_decision!r}")
    elif release_candidate(entry.id) and production_decision == "Released":
        errors.append(f"release candidate {entry.id} cannot have production decision Released")
    return errors


def release_entry_work_ids(entry: LedgerEntry) -> set[str]:
    return set(
        re.findall(
            r"\b[BEO][NRFX]\.[A-Za-z][A-Za-z0-9]*\.\d{2}(?:\.[a-z]+)*-\d{3}\b",
            _ledger_section(entry, "Included work"),
        )
    )


def validate_supporting_ledgers(model: ManagementModel) -> None:
    required_labels = {
        "BUGS.md": ["Reported", "Reporter", "Related work", "Report"],
        "DECISIONS.md": ["Context", "Decision", "Consequences", "Related"],
        "RISKS.md": ["Owner", "Related", "Risk", "Impact", "Mitigation"],
        "INCIDENTS.md": ["Detected", "Affected environment", "Impact", "Timeline", "Root cause", "Mitigation", "Follow-up work", "Requirement or decision changes"],
        "EXPERIMENTS.md": ["Branch", "Hypothesis", "Expires", "Success criteria", "Failure criteria", "Result", "Follow-up"],
    }
    prefixes = {
        "BUGS.md": "BUG-",
        "DECISIONS.md": "DEC-",
        "RISKS.md": "RISK-",
        "INCIDENTS.md": "INCIDENT-",
        "EXPERIMENTS.md": "EXP-",
    }
    for filename in LEDGER_ENTRY_LEVELS:
        path = MANAGEMENT_DIR / filename
        if path.exists():
            validate_ledger_entry_headings(model, path)
    bugs_path = MANAGEMENT_DIR / "BUGS.md"
    if bugs_path.exists():
        open_report_headings = [
            line_number
            for line_number, line in enumerate(bugs_path.read_text(encoding="utf-8").splitlines(), start=1)
            if line.strip() == BUGS_OPEN_REPORTS_HEADING
        ]
        if len(open_report_headings) != 1:
            line = open_report_headings[1] if len(open_report_headings) > 1 else 1
            model.error(bugs_path, line, "BUGS.md must contain exactly one `## Open Reports` section")
    entries_by_file = {
        filename: (
            open_bug_report_entries(MANAGEMENT_DIR / filename)
            if filename == "BUGS.md"
            else ledger_entries(MANAGEMENT_DIR / filename)
        )
        for filename in SAFE_LEDGER_STATUSES
        if (MANAGEMENT_DIR / filename).exists()
    }
    known_ledger_ids = {entry.id for entries in entries_by_file.values() for entry in entries}
    for filename, statuses in SAFE_LEDGER_STATUSES.items():
        path = MANAGEMENT_DIR / filename
        if not path.exists():
            continue
        seen_ids: set[str] = set()
        for entry in entries_by_file[filename]:
            if entry.id in seen_ids:
                model.error(path, entry.line, f"duplicate ledger id {entry.id}")
            seen_ids.add(entry.id)
            if re.fullmatch(rf"{re.escape(prefixes[filename])}\d{{4}}", entry.id) is None:
                model.error(path, entry.line, f"unexpected {filename} entry id {entry.id}")
            if entry.status not in statuses:
                model.error(path, entry.line, f"{entry.id} has invalid or missing status {entry.status!r}; expected one of: {', '.join(sorted(statuses))}")
            for label in required_labels[filename]:
                if not _ledger_has_label(entry, label):
                    model.error(path, entry.line, f"{entry.id} is missing `{label}:`")
            if filename == "DECISIONS.md":
                raw_date = _ledger_field(entry, "Date")
                if raw_date is None:
                    model.error(path, entry.line, f"{entry.id} is missing `Date:`")
                else:
                    try:
                        validate_iso_date(raw_date)
                    except ValueError as err:
                        model.error(path, entry.line, str(err))
            if filename == "BUGS.md":
                reported = _ledger_field(entry, "Reported")
                if reported:
                    try:
                        validate_iso_date(reported)
                    except ValueError as err:
                        model.error(path, entry.line, str(err))
                if entry.status == "Validated":
                    if not _ledger_has_label(entry, "Assessment"):
                        model.error(path, entry.line, f"{entry.id} is missing `Assessment:`")
                    related_work = {
                        reference
                        for reference in _structured_references(_ledger_section(entry, "Related work"))
                        if WORK_ITEM_ID_RE.fullmatch(reference)
                    }
                    if not related_work:
                        model.error(path, entry.line, f"validated report {entry.id} must link at least one F-motivation work item in `Related work:`")
                    for work_id in related_work:
                        work_item = model.work_items.get(work_id)
                        if work_item is not None and work_item.motivation != "F":
                            model.error(path, entry.line, f"validated report {entry.id} links non-F work item {work_id}")
            if filename == "EXPERIMENTS.md":
                expires = _ledger_field(entry, "Expires")
                if expires:
                    try:
                        validate_iso_date(expires)
                    except ValueError as err:
                        model.error(path, entry.line, str(err))
            reference_labels = ["Related", "Related work", "Follow-up", "Follow-up work", "Requirement or decision changes"]
            for label in reference_labels:
                for reference in _structured_references(_ledger_section(entry, label)):
                    if reference.startswith(("BUG-", "DEC-", "RISK-", "INCIDENT-", "EXP-")):
                        exists = reference in known_ledger_ids
                    elif WORK_ITEM_ID_RE.fullmatch(reference):
                        exists = reference in model.work_items
                    else:
                        exists = reference in model.requirements
                    if not exists:
                        model.error(path, entry.line, f"{entry.id} {label} references missing structured id {reference}")

    bug_entries = {entry.id: entry for entry in entries_by_file.get("BUGS.md", [])}
    for entry in bug_entries.values():
        if entry.status != "Validated":
            continue
        for work_id in _structured_references(_ledger_section(entry, "Related work")):
            work_item = model.work_items.get(work_id)
            if work_item is not None and entry.id not in _structured_references(work_item.body):
                model.error(entry.path, entry.line, f"validated report {entry.id} links {work_id}, but that work item does not link back to the report")
    for work_item in model.work_items.values():
        if work_item.motivation == "F" and work_item.state != "Rolled Out":
            open_reports = [
                entry
                for entry in bug_entries.values()
                if entry.status == "Validated"
                and work_item.id in _structured_references(_ledger_section(entry, "Related work"))
            ]
            if not open_reports:
                model.error(work_item.path, work_item.line, f"corrective work {work_item.id} has not reached Rolled Out and has no open validated bug report")
        related_bug_lines = re.findall(r"^Related bugs?:\s*(?P<value>.+)$", work_item.body, flags=re.MULTILINE)
        related_bug_ids = {
            reference
            for line in related_bug_lines
            for reference in _structured_references(line)
            if reference.startswith("BUG-")
        }
        if related_bug_ids and work_item.motivation != "F":
            model.error(work_item.path, work_item.line, f"work item {work_item.id} links a bug report but does not use motivation F")
        if work_item.state != "Rolled Out":
            for bug_id in related_bug_ids:
                if bug_id not in bug_entries:
                    model.error(work_item.path, work_item.line, f"corrective work {work_item.id} has not reached Rolled Out and references missing open report {bug_id}")

    releases_path = MANAGEMENT_DIR / "RELEASES.md"
    if releases_path.exists():
        seen_versions: set[str] = set()
        for entry in ledger_entries(releases_path):
            if entry.id in seen_versions:
                model.error(releases_path, entry.line, f"duplicate release version {entry.id}")
            seen_versions.add(entry.id)
            for error in release_entry_schema_errors(entry):
                model.error(releases_path, entry.line, error)
            included_work = release_entry_work_ids(entry)
            for work_item_id in included_work:
                if work_item_id not in model.work_items:
                    model.error(releases_path, entry.line, f"release {entry.id} references missing work item {work_item_id}")
            for requirement_id_value in requirement_references(_ledger_section(entry, "Requirements affected")):
                if requirement_id_value not in model.requirements:
                    model.error(releases_path, entry.line, f"release {entry.id} references missing requirement {requirement_id_value}")


def next_ledger_id(entries: list[LedgerEntry], prefix: str) -> str:
    highest = 0
    for entry in entries:
        match = re.fullmatch(rf"{re.escape(prefix)}-(\d{{4}})", entry.id)
        if match:
            highest = max(highest, int(match.group(1)))
    return f"{prefix}-{highest + 1:04d}"


def append_markdown_entry(path: Path, entry: str) -> None:
    with management_write_lock():
        content = path.read_text(encoding="utf-8") if path.exists() else ""
        separator = "\n\n" if content.rstrip() else ""
        atomic_write_text(path, f"{content.rstrip()}{separator}{entry.rstrip()}\n")


def insert_markdown_entry_before(path: Path, marker: str, entry: str) -> None:
    with management_write_lock():
        content = path.read_text(encoding="utf-8") if path.exists() else ""
        marker_index = content.find(marker)
        if marker_index < 0:
            append_markdown_entry(path, entry)
            return
        before = content[:marker_index].rstrip()
        after = content[marker_index:].lstrip("\n")
        atomic_write_text(path, f"{before}\n\n{entry.rstrip()}\n\n{after}")


def replace_ledger_entry(path: Path, entry_id: str, replacement_body: str) -> bool:
    with management_write_lock():
        lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
        start: int | None = None
        for index, line in enumerate(lines):
            match = LEDGER_HEADING_RE.match(line.rstrip("\n"))
            if match and match.group("id").strip("`") == entry_id:
                start = index
                break
        if start is None:
            return False

        end = len(lines)
        for index in range(start + 1, len(lines)):
            if LEDGER_HEADING_RE.match(lines[index].rstrip("\n")):
                end = index
                break
        replacement_lines = [line if line.endswith("\n") else f"{line}\n" for line in replacement_body.rstrip().splitlines()]
        lines[start:end] = [*replacement_lines, "\n"]
        atomic_write_text(path, "".join(lines))
        return True


def update_ledger_status(entry: LedgerEntry, status: str, closure_lines: list[str]) -> None:
    lines = [f"### {entry.id} -- {entry.title}", *entry.body.splitlines()]
    updated: list[str] = []
    replaced = False
    for line in lines:
        if line.startswith("Status:"):
            updated.append(f"Status: {status}")
            replaced = True
        else:
            updated.append(line)
    if not replaced:
        updated.insert(1, f"Status: {status}")
    if closure_lines:
        updated.extend(["", *closure_lines])
    if not replace_ledger_entry(entry.path, entry.id, "\n".join(updated)):
        raise ValueError(f"{entry.id} was not found in {relative(entry.path)}")


def ledger_entry_by_id(path: Path, entry_id: str) -> LedgerEntry:
    for entry in ledger_entries(path):
        if entry.id == entry_id:
            return entry
    raise ValueError(f"{entry_id} was not found in {relative(path)}")


def state_counts(model: ManagementModel) -> dict[str, int]:
    counts = {state: 0 for state in VALID_STATES}
    for item in model.work_items.values():
        counts[item.state] = counts.get(item.state, 0) + 1
    return counts


def last_state_date(item: WorkItem) -> str | None:
    if item.state in item.timeline:
        return item.timeline[item.state]
    if item.timeline:
        return list(item.timeline.values())[-1]
    return None


def stale_work_items(model: ManagementModel, threshold_days: int) -> list[StaleWorkItem]:
    today = date.today()
    stale_states = {"Under Planning", "Planned", "Started", "In Code Review", "Integrated", "QA"}
    stale: list[StaleWorkItem] = []
    for item in sorted(model.work_items.values(), key=lambda candidate: candidate.id):
        if item.state not in stale_states:
            continue
        state_date = last_state_date(item)
        if not state_date:
            stale.append(StaleWorkItem(item, None, None, "missing dated state trail"))
            continue
        try:
            age_days = (today - datetime.strptime(state_date, "%Y-%m-%d").date()).days
        except ValueError:
            stale.append(StaleWorkItem(item, state_date, None, "invalid state date"))
            continue
        if age_days >= threshold_days:
            stale.append(StaleWorkItem(item, state_date, age_days, f"{age_days} days in or since current state"))
    return stale


def open_ledger_entries(path: Path) -> list[LedgerEntry]:
    closed_statuses = {"Closed", "Adopted", "Rejected", "Expired", "Released", "Rolled back"}
    return [entry for entry in ledger_entries(path) if (entry.status or "Open") not in closed_statuses]


def traceability_gaps(model: ManagementModel) -> list[Requirement]:
    links = traceability_links()
    return [
        requirement
        for requirement in sorted(model.requirements.values(), key=lambda candidate: candidate.id)
        if requirement_evidence_coverage(model, requirement, links)["status"] == "gap"
    ]


def unmapped_requirements(model: ManagementModel) -> list[Requirement]:
    return [
        requirement
        for requirement in sorted(model.requirements.values(), key=lambda candidate: candidate.id)
        if not requirement_work_items(model, requirement)
    ]


