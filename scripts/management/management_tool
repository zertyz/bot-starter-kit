def cmd_link_evidence(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    work_item_id = args.work_item_id
    evidence_path_arguments = list(args.path)
    explicit_requirement_id = None
    if (
        work_item_id in model.requirements
        and evidence_path_arguments
        and WORK_ITEM_ID_RE.fullmatch(evidence_path_arguments[0])
    ):
        explicit_requirement_id = work_item_id
        work_item_id = evidence_path_arguments.pop(0)

    work_item = model.work_items.get(work_item_id)
    if work_item is None:
        print(f"unknown work item: {work_item_id}", file=sys.stderr)
        return 1
    if explicit_requirement_id and work_item.requirement_id != explicit_requirement_id:
        print(f"error: {work_item.id} maps to {work_item.requirement_id}, not {explicit_requirement_id}", file=sys.stderr)
        return 1
    requirement = model.requirements[work_item.requirement_id]
    if not evidence_path_arguments:
        print("error: at least one evidence path is required after the work item id", file=sys.stderr)
        return 1
    try:
        canonical_paths, missing = validate_evidence_paths(evidence_path_arguments, args.allow_missing)
        note = validate_markdown_table_field(args.note, "--note", forbid_backticks=True) if args.note else None
        if args.state:
            state = validate_markdown_table_field(args.state, "--state")
            if state != work_item.state:
                raise ValueError(f"traceability state {state} does not match backlog state {work_item.state}")
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    action = append_or_update_traceability(requirement.id, work_item, canonical_paths, note, args.state)
    print("Evidence Link")
    print("=============")
    print(f"Requirement: {requirement.id}")
    print(f"Work item:   {work_item.id}")
    print(f"Action:      {action}")
    print("Evidence:")
    for path in canonical_paths:
        print(f"  - {path}")
    if missing:
        print("Missing paths allowed:")
        for path in missing:
            print(f"  - {path}")
    print("Source:      management/TRACEABILITY.md")
    print()
    print(f"Next command: scripts/management/trace_requirement {requirement.id}")
    if work_item.state in {"In Code Review", "Integrated", "QA", "Merged"} and not missing:
        print(f"Then inspect the next gate: scripts/management/advance_state {work_item.id} --dry-run")
    return 0


def validate_release_version(version: str) -> str:
    if not RELEASE_VERSION_RE.fullmatch(version):
        raise ValueError(f"invalid release version {version}; expected semver like 1.2.3 or 1.2.3-rc.1")
    return version


def release_candidate(version: str) -> bool:
    return "-rc." in version


def cmd_prepare_release(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    try:
        version = validate_release_version(args.version)
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    included = sorted(
        [item for item in model.work_items.values() if item.state == "Merged"],
        key=lambda item: item.id,
    )
    open_incidents = open_ledger_entries(MANAGEMENT_DIR / "INCIDENTS.md")
    open_risks = open_ledger_entries(MANAGEMENT_DIR / "RISKS.md")
    gaps = traceability_gaps(model)
    stale = stale_work_items(model, args.stale_days)
    blockers: list[str] = []
    reviews: list[str] = []
    if open_incidents:
        blockers.append(f"{len(open_incidents)} open incident(s)")
    if gaps:
        reviews.append(f"{len(gaps)} requirement evidence coverage gap(s)")
    if stale:
        reviews.append(f"{len(stale)} stale work item(s)")
    if open_risks:
        reviews.append(f"{len(open_risks)} open risk(s) require release-owner review")

    verdict = "BLOCKED" if blockers else "NEEDS REVIEW" if reviews else "READY TO TAG"

    print("Release Packet")
    print("==============")
    print(f"Version:          {version}")
    print(f"Type:             {'release candidate' if release_candidate(version) else 'production release'}")
    print(f"Verdict:          {verdict}")
    print()
    print("Included merged work:")
    if included:
        for item in included:
            print(f"  - {item.id}: {item.state} -- {item.title}")
    else:
        print("  - none")
    print()
    print("Blockers:")
    if blockers:
        for blocker in blockers:
            print(f"  - {blocker}")
    else:
        print("  - none")
    print()
    print("Review items:")
    if reviews:
        for review_item in reviews:
            print(f"  - {review_item}")
    else:
        print("  - none")
    print()
    print("Required checks:")
    for command in VERIFICATION_COMMANDS:
        print(f"  - {command}")
    print("  - scripts/management/management_status")
    print()
    print("Tag command:")
    print(f"  scripts/management/create_release_tag {version} --execute")
    if included:
        work_ids = " ".join(item.id for item in included)
        print()
        print("After the production outcome is known, record it:")
        print(
            f"  scripts/management/record_release {version} {work_ids} --decision Released "
            '--verification "<PASSED_CHECKS>" --rollback "<ROLLBACK_OR_MITIGATION>" '
            '--notes "<RELEASE_NOTES>"'
        )
    print("Scope note: this packet prepares a release decision. It does not create or push tags.")
    return 1 if args.strict and blockers else 0


def cmd_create_release_tag(args: argparse.Namespace) -> int:
    try:
        version = validate_release_version(args.version)
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    if git_ref_exists(f"refs/tags/{version}"):
        print(f"error: tag {version} already exists", file=sys.stderr)
        return 1
    if git_worktree_is_dirty():
        print("error: worktree has uncommitted changes; release tags require a clean tree", file=sys.stderr)
        return 1

    message = args.message or f"Release {version}"
    command = ["tag", "-a", version, "-m", message]
    print("Release Tag")
    print("===========")
    print(f"Version: {version}")
    print(f"Type:    {'release candidate' if release_candidate(version) else 'production release'}")
    print(f"Command: git {' '.join(command)}")
    if not args.execute:
        print("Dry run: pass --execute to create the local tag.")
        print(f"Next command: scripts/management/create_release_tag {version} --execute")
        return 0
    try:
        git_output(command)
    except RuntimeError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1
    print(f"Created tag {version}. Push it intentionally when the release owner approves.")
    print("After the deployment outcome and checks are known, record the release with:")
    print(
        f"  scripts/management/record_release {version} <WORK_ITEM_ID> [MORE_WORK_ITEM_IDS ...] "
        '--decision Released --verification "<PASSED_CHECKS>" '
        '--rollback "<ROLLBACK_OR_MITIGATION>" --notes "<RELEASE_NOTES>"'
    )
    return 0


def release_entry_text(
    version: str,
    release_date: str,
    work_items: list[WorkItem],
    requirements: list[Requirement],
    verification: list[str],
    decision: str,
    rollback: str,
    notes: str,
) -> str:
    work_lines = "\n".join(
        f"{index}. `{item.id}` -- {item.title}"
        for index, item in enumerate(work_items, start=1)
    )
    requirement_lines = "\n".join(
        f"{index}. `{requirement.id}` -- {requirement.title}"
        for index, requirement in enumerate(requirements, start=1)
    )
    verification_lines = "\n".join(
        f"{index}. {check}"
        for index, check in enumerate(verification, start=1)
    )
    return f"""### {version} -- {release_date}

Tag:
`{version}`

Included work:
{work_lines}

Requirements affected:
{requirement_lines}

Verification:
{verification_lines}

Production decision:
`{decision}`

Rollback or mitigation:
{rollback}

Notes:
{notes}
"""


def render_release_record(content: str, entry: str, production_released: bool) -> str:
    marker = "\n## Release Entry Format"
    marker_index = content.find(marker)
    if marker_index < 0:
        return f"{content.rstrip()}\n\n{entry.rstrip()}\n"

    before = content[:marker_index].rstrip()
    after = content[marker_index:].lstrip("\n")
    if production_released:
        before = re.sub(
            r"\n*## No Production Releases Recorded Yet\n.*?(?=\n## |\Z)",
            "",
            before,
            flags=re.DOTALL,
        ).rstrip()
    return f"{before}\n\n{entry.rstrip()}\n\n{after.rstrip()}\n"


def cmd_record_release(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    try:
        version = validate_release_version(args.version)
        release_date = validate_iso_date(args.date or date.today().isoformat())
        decision = validate_single_line_markdown_field(args.decision, "--decision")
        if release_candidate(version) and decision == "Released":
            raise ValueError(
                f"release candidate {version} cannot have production decision Released; "
                "use a production semver for rollout or record Rejected/Rolled back"
            )
        verification = []
        for check in args.verification:
            validated = validate_single_line_markdown_field(check.strip(), "--verification")
            if not validated or is_placeholder_token(validated):
                raise ValueError("--verification must contain a concrete completed check")
            verification.append(validated)
        rollback = args.rollback.strip()
        notes = args.notes.strip()
        for value, field_name in ((rollback, "--rollback"), (notes, "--notes")):
            if not value or is_placeholder_token(value):
                raise ValueError(f"{field_name} must contain concrete release information")
            validate_multiline_markdown_prose(value, field_name)
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    releases_path = MANAGEMENT_DIR / "RELEASES.md"
    if any(entry.id == version for entry in ledger_entries(releases_path)):
        print(f"error: release {version} is already recorded in management/RELEASES.md", file=sys.stderr)
        return 1

    work_item_ids = list(dict.fromkeys(args.work_item_id))
    work_items: list[WorkItem] = []
    for work_item_id in work_item_ids:
        item = model.work_items.get(work_item_id)
        if item is None:
            print(f"error: unknown work item: {work_item_id}", file=sys.stderr)
            return 1
        if item.state not in {"Merged", "Rolled Out"}:
            print(
                f"error: {item.id} is {item.state}; release records may include only Merged or Rolled Out work",
                file=sys.stderr,
            )
            return 1
        work_items.append(item)

    requirement_ids = list(dict.fromkeys(item.requirement_id for item in work_items))
    requirements = [model.requirements[requirement_id] for requirement_id in requirement_ids]
    entry = release_entry_text(
        version,
        release_date,
        work_items,
        requirements,
        verification,
        decision,
        rollback,
        notes,
    )
    content = releases_path.read_text(encoding="utf-8") if releases_path.exists() else "# Releases\n"
    atomic_write_text(
        releases_path,
        render_release_record(content, entry, production_released=decision == "Released"),
    )

    print("Release Record")
    print("==============")
    print(f"Version:  {version}")
    print(f"Date:     {release_date}")
    print(f"Decision: {decision}")
    print("Included work:")
    for item in work_items:
        print(f"  - {item.id}: {item.state} -- {item.title}")
    print("Source:   management/RELEASES.md")
    print()
    if decision == "Released":
        merged_items = [item for item in work_items if item.state == "Merged"]
        if merged_items:
            print("Next commands for each Merged work item:")
            for item in merged_items:
                print(f"  scripts/management/link_evidence {item.id} management/RELEASES.md")
                print(f"  scripts/management/advance_state {item.id} --dry-run")
                print(f"  scripts/management/advance_state {item.id}")
        else:
            print("All included work is already Rolled Out; no lifecycle transition remains.")
    else:
        print("Do not advance the included work to Rolled Out from this release decision.")
        print("Prepare a new version after the rejected or rolled-back outcome has been addressed.")
    return 0


