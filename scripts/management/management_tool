def repo_rust_source_paths() -> list[str]:
    paths = {path for path in tracked_files() if path.startswith("src/") and path.endswith(".rs")}
    src = REPO_ROOT / "src"
    if src.is_dir():
        paths.update(relative(path) for path in src.rglob("*.rs") if path.is_file())
    return sorted(paths)


def rust_crate_reference_roots() -> set[str]:
    roots = {"crate"}
    cargo_toml = REPO_ROOT / "Cargo.toml"
    if not cargo_toml.is_file():
        return roots
    in_lib_section = False
    package_name: str | None = None
    for raw_line in cargo_toml.read_text(encoding="utf-8", errors="ignore").splitlines():
        line = raw_line.strip()
        if line.startswith("[") and line.endswith("]"):
            in_lib_section = line == "[lib]"
            continue
        name_match = re.match(r'^name\s*=\s*"(?P<name>[^"]+)"\s*$', line)
        if not name_match:
            continue
        if in_lib_section:
            roots.add(name_match.group("name").replace("-", "_"))
            continue
        if package_name is None:
            package_name = name_match.group("name")
    if package_name:
        roots.add(package_name.replace("-", "_"))
    return roots


def rust_module_name(path: str) -> str:
    source = Path(path)
    parts = source.parts
    if len(parts) < 2 or parts[0] != "src":
        return path
    if len(parts) == 2 and parts[1] == "lib.rs":
        return "crate"
    if len(parts) == 2 and parts[1] == "main.rs":
        return "bin::main"
    if parts[1] == "bin":
        if len(parts) == 3:
            return f"bin::{source.stem}"
        module_parts = list(parts[2:-1])
        if parts[-1] != "mod.rs":
            module_parts.append(source.stem)
        return "bin::" + "::".join(module_parts)

    module_parts = list(parts[1:-1])
    if parts[-1] != "mod.rs":
        module_parts.append(source.stem)
    return "crate::" + "::".join(module_parts)


def rust_source_without_tests(content: str, include_tests: bool) -> str:
    if include_tests:
        return content
    return content.split("#[cfg(test)]", 1)[0]


def nearest_module(raw_crate_ref: str, module_names: set[str]) -> str | None:
    parts = raw_crate_ref.split("::")
    for length in range(len(parts), 0, -1):
        candidate = "crate::" + "::".join(parts[:length])
        if candidate in module_names:
            return candidate
    return None


def architecture_bucket(module_name: str) -> str | None:
    if module_name.startswith("bin::"):
        return "bin"
    if module_name.startswith("crate::"):
        pieces = module_name.split("::")
        return pieces[1] if len(pieces) > 1 else None
    return None


def module_palette(module_name: str) -> tuple[str, str]:
    bucket = architecture_bucket(module_name) or module_name
    palettes = {
        "bin": ("#fef3c7", "#92400e"),
        "commons": ("#f3f4f6", "#4b5563"),
        "db": ("#ede9fe", "#6d28d9"),
        "logic": ("#dcfce7", "#15803d"),
        "messaging": ("#dbeafe", "#1d4ed8"),
        "models": ("#f6f8fa", "#57606a"),
        "plot": ("#ffe4e6", "#be123c"),
        "repository": ("#ccfbf1", "#0f766e"),
        "resources": ("#ffedd5", "#c2410c"),
    }
    return palettes.get(bucket, ("#f6f8fa", "#57606a"))


def module_dependency_graph(include_tests: bool = False, scope: str | None = None) -> tuple[list[GraphNode], list[GraphEdge]]:
    path_by_module = {rust_module_name(path): path for path in repo_rust_source_paths()}
    module_names = set(path_by_module)
    reference_roots = rust_crate_reference_roots()
    edges_by_pair: dict[tuple[str, str], GraphEdge] = {}

    for module_name, path in path_by_module.items():
        content = rust_source_without_tests(read_repo_file(path), include_tests)
        def add_target(raw_path: str) -> None:
            target = nearest_module(raw_path, module_names)
            if target is None or target == module_name:
                return
            edges_by_pair[(module_name, target)] = GraphEdge(module_name, target, "uses")

        for match in RUST_MODULE_REF_RE.finditer(content):
            if match.group("root") not in reference_roots:
                continue
            add_target(match.group("path"))
        for match in RUST_GROUP_MODULE_REF_RE.finditer(content):
            if match.group("root") not in reference_roots:
                continue
            for entry in RUST_GROUP_PATH_RE.finditer(match.group("body")):
                add_target(entry.group("path"))

    selected_modules = set(module_names)
    if scope:
        selected_modules = {module for module in module_names if module_matches_scope(module, scope)}
        selected_modules.update(edge.target for edge in edges_by_pair.values() if edge.source in selected_modules)
        selected_modules.update(edge.source for edge in edges_by_pair.values() if edge.target in selected_modules)

    nodes = [
        GraphNode(module, module, path_by_module[module], *module_palette(module))
        for module in sorted(selected_modules)
    ]
    edges = [
        edge
        for edge in sorted(edges_by_pair.values(), key=lambda candidate: (candidate.source, candidate.target))
        if edge.source in selected_modules and edge.target in selected_modules
    ]
    return nodes, edges


def module_matches_scope(module_name: str, scope: str) -> bool:
    raw = scope.strip(":")
    candidates = [raw]
    if not raw.startswith(("crate::", "bin::")):
        candidates.extend([f"crate::{raw}", f"bin::{raw}"])
    return any(module_name == candidate or module_name.startswith(f"{candidate}::") for candidate in candidates)


def real_architecture_nodes() -> list[GraphNode]:
    details = {
        "bin": ("Runtime / CLI", "Executable entry points"),
        "commons": ("Shared Commons", "Reusable test and support code"),
        "db": ("Database Wrappers", "Async persistence adapters and benchmarks"),
        "logic": ("Bot Logic", "Demoscenes and application behavior"),
        "messaging": ("Messaging Layer", "Gateway contracts, routing, and adapters"),
        "models": ("Configuration Models", "Runtime configuration and typed inputs"),
        "plot": ("Plot Rendering", "Generated visual output demos"),
        "repository": ("Repository Contracts", "Persistence-facing traits and domain errors"),
        "resources": ("Embedded Resources", "Bundled runtime assets"),
    }
    module_buckets = {architecture_bucket(rust_module_name(path)) for path in repo_rust_source_paths()}
    order = ["bin", "models", "messaging", "logic", "db", "repository", "plot", "resources", "commons"]
    nodes: list[GraphNode] = []
    for bucket in order:
        if bucket not in module_buckets:
            continue
        label, detail = details[bucket]
        fill, border = module_palette(bucket)
        nodes.append(GraphNode(bucket, label, detail, fill, border))
    return nodes


def real_architecture_graph() -> tuple[list[GraphNode], list[GraphEdge]]:
    nodes = real_architecture_nodes()
    node_ids = {node.id for node in nodes}
    _, module_edges = module_dependency_graph()
    edge_keys: set[tuple[str, str]] = set()
    edges: list[GraphEdge] = []
    for edge in module_edges:
        source = architecture_bucket(edge.source)
        target = architecture_bucket(edge.target)
        if source is None or target is None or source == target:
            continue
        if source not in node_ids or target not in node_ids:
            continue
        key = (source, target)
        if key in edge_keys:
            continue
        edge_keys.add(key)
        edges.append(GraphEdge(source, target, "uses"))
    return nodes, edges


def requirement_architecture_area(requirement: Requirement | None, section: str | None = None) -> str:
    if requirement is not None:
        text = f"{requirement.section} {requirement.section_title} {requirement.title} {requirement.body}".lower()
        section = requirement.section
    else:
        text = section.lower() if section else ""
    section_map = {
        "mcp": "messaging",
        "msgp": "messaging",
        "ds": "db",
        "db": "db",
        "demo": "logic",
        "plot": "plot",
        "usrmgn": "repository",
        "arch": "logic",
    }
    if section and section.lower() in section_map:
        return section_map[section.lower()]
    if any(term in text for term in ["message", "telegram", "gateway", "routing", "user stream"]):
        return "messaging"
    if any(term in text for term in ["database", "storage", "sqlite", "redb", "heed", "repository"]):
        return "db"
    if any(term in text for term in ["configuration", "config", "environment"]):
        return "models"
    if any(term in text for term in ["plot", "chart", "render"]):
        return "plot"
    if any(term in text for term in ["operation", "release", "incident", "rollback"]):
        return "resources"
    return "requirements"


def add_overlay_area_node(nodes_by_id: dict[str, GraphNode], area: str) -> None:
    if area in nodes_by_id:
        return
    if area == "requirements":
        nodes_by_id[area] = GraphNode("requirements", "Unassigned Requirement Area", "No clear source module yet", "#f8fafc", "#64748b")
        return
    fill, border = module_palette(area)
    nodes_by_id[area] = GraphNode(area, area.title(), "Inferred from requirement wording", fill, border)


def planned_architecture_graph(model: ManagementModel) -> tuple[list[GraphNode], list[GraphEdge]]:
    real_nodes, real_edges = real_architecture_graph()
    nodes_by_id = {node.id: node for node in real_nodes}
    edges = list(real_edges)
    edge_keys = {(edge.source, edge.target, edge.label) for edge in edges}
    for item in sorted(model.work_items.values(), key=lambda candidate: candidate.id):
        if item.state == "Merged" or terminal_state(item.state):
            continue
        requirement = model.requirements.get(item.requirement_id)
        area = requirement_architecture_area(requirement, item.section)
        add_overlay_area_node(nodes_by_id, area)
        work_node_id = f"work:{item.id}"
        nodes_by_id[work_node_id] = GraphNode(work_node_id, item.id, f"{item.state}: {item.title}", "#dbeafe", "#2563eb")
        key = (area, work_node_id, item.state)
        if key not in edge_keys:
            edge_keys.add(key)
            edges.append(GraphEdge(area, work_node_id, item.state, "#2563eb"))

    for requirement in unmapped_requirements(model):
        area = requirement_architecture_area(requirement)
        add_overlay_area_node(nodes_by_id, area)
        requirement_node_id = f"req:{requirement.id}"
        nodes_by_id[requirement_node_id] = GraphNode(requirement_node_id, requirement.id, requirement.title, "#fff7ed", "#ea580c")
        key = (area, requirement_node_id, "unplanned")
        if key not in edge_keys:
            edge_keys.add(key)
            edges.append(GraphEdge(area, requirement_node_id, "unplanned", "#ea580c", dashed=True))

    ordered = list(real_nodes) + [
        node
        for node_id, node in sorted(nodes_by_id.items(), key=lambda candidate: candidate[0])
        if node_id not in {real_node.id for real_node in real_nodes}
    ]
    return ordered, edges


def svg_text_lines(text: str, max_chars: int, max_lines: int) -> list[str]:
    words = text.split()
    if not words:
        return []
    lines: list[str] = []
    current = ""
    for word in words:
        candidate = word if not current else f"{current} {word}"
        if len(candidate) <= max_chars:
            current = candidate
            continue
        if current:
            lines.append(current)
        current = word
        if len(lines) == max_lines:
            break
    if current and len(lines) < max_lines:
        lines.append(current)
    if len(lines) == max_lines and words:
        consumed = " ".join(lines)
        if len(consumed) < len(text):
            lines[-1] = lines[-1].rstrip(".") + "..."
    return lines


def render_svg_text(lines: list[str], x: float, y: float, css_class: str) -> str:
    if not lines:
        return ""
    tspans = []
    for index, line in enumerate(lines):
        dy = "0" if index == 0 else "1.25em"
        tspans.append(f'<tspan x="{x:.1f}" dy="{dy}">{html.escape(line)}</tspan>')
    return f'<text class="{css_class}" x="{x:.1f}" y="{y:.1f}">{"".join(tspans)}</text>'


def render_svg_graph(title: str, nodes: list[GraphNode], edges: list[GraphEdge], output_path: Path, legend: list[GraphNode]) -> Path:
    output_path.parent.mkdir(parents=True, exist_ok=True)
    unique_nodes: list[GraphNode] = []
    seen_nodes: set[str] = set()
    for node in nodes:
        if node.id in seen_nodes:
            continue
        seen_nodes.add(node.id)
        unique_nodes.append(node)
    if not unique_nodes:
        unique_nodes.append(GraphNode("empty", "No modules found", "The source tree did not contain Rust modules."))

    width = 1240
    margin_x = 48
    top = 112
    node_width = 250
    node_height = 86
    columns = 3 if len(unique_nodes) <= 9 else 4
    gap_x = (width - (2 * margin_x) - (columns * node_width)) / max(columns - 1, 1)
    row_gap = 54
    rows = (len(unique_nodes) + columns - 1) // columns
    legend_height = 72 if legend else 0
    height = top + rows * node_height + max(rows - 1, 0) * row_gap + legend_height + 54
    positions: dict[str, tuple[float, float]] = {}
    for index, node in enumerate(unique_nodes):
        row = index // columns
        column = index % columns
        positions[node.id] = (
            margin_x + column * (node_width + gap_x),
            top + row * (node_height + row_gap),
        )

    edge_svg: list[str] = []
    for edge in edges:
        if edge.source not in positions or edge.target not in positions:
            continue
        sx, sy = positions[edge.source]
        tx, ty = positions[edge.target]
        same_row = abs(sy - ty) < 1
        if same_row and sx < tx:
            x1, y1 = sx + node_width, sy + (node_height / 2)
            x2, y2 = tx, ty + (node_height / 2)
        elif same_row:
            x1, y1 = sx, sy + (node_height / 2)
            x2, y2 = tx + node_width, ty + (node_height / 2)
        else:
            x1, y1 = sx + (node_width / 2), sy + node_height
            x2, y2 = tx + (node_width / 2), ty
        dash = ' stroke-dasharray="7 5"' if edge.dashed else ""
        edge_svg.append(
            f'<line x1="{x1:.1f}" y1="{y1:.1f}" x2="{x2:.1f}" y2="{y2:.1f}" '
            f'stroke="{html.escape(edge.color)}" stroke-width="1.6" marker-end="url(#arrow)"{dash}/>'
        )
        if edge.label:
            edge_svg.append(
                f'<text class="edge-label" x="{((x1 + x2) / 2):.1f}" y="{((y1 + y2) / 2 - 5):.1f}">'
                f"{html.escape(edge.label)}</text>"
            )

    node_svg: list[str] = []
    for node in unique_nodes:
        x, y = positions[node.id]
        node_svg.append(
            f'<rect class="node" x="{x:.1f}" y="{y:.1f}" width="{node_width}" height="{node_height}" '
            f'rx="7" fill="{html.escape(node.fill)}" stroke="{html.escape(node.border)}"/>'
        )
        node_svg.append(render_svg_text(svg_text_lines(node.label, 28, 2), x + 14, y + 27, "node-label"))
        node_svg.append(render_svg_text(svg_text_lines(node.detail, 34, 2), x + 14, y + 60, "node-detail"))

    legend_svg: list[str] = []
    if legend:
        legend_y = height - 82
        legend_svg.append(f'<text class="legend-title" x="{margin_x}" y="{legend_y}">Legend</text>')
        for index, node in enumerate(legend):
            x = margin_x + index * 260
            y = legend_y + 18
            legend_svg.append(f'<rect x="{x}" y="{y}" width="22" height="14" rx="3" fill="{html.escape(node.fill)}" stroke="{html.escape(node.border)}"/>')
            legend_svg.append(f'<text class="legend-label" x="{x + 30}" y="{y + 12}">{html.escape(node.label)}</text>')

    svg = f"""<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}" viewBox="0 0 {width} {height}" role="img" aria-labelledby="diagram-title diagram-desc">
  <title id="diagram-title">{html.escape(title)}</title>
  <desc id="diagram-desc">Generated from repository source files and git-controlled management files.</desc>
  <defs>
    <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto" markerUnits="strokeWidth">
      <path d="M0,0 L0,6 L6,3 z" fill="#57606a"/>
    </marker>
  </defs>
  <style>
    .title {{ font: 700 24px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; fill: #17202a; }}
    .subtitle {{ font: 13px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; fill: #57606a; }}
    .node {{ stroke-width: 1.5; }}
    .node-label {{ font: 700 14px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; fill: #17202a; }}
    .node-detail {{ font: 12px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; fill: #57606a; }}
    .edge-label {{ font: 11px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; fill: #57606a; text-anchor: middle; paint-order: stroke; stroke: #ffffff; stroke-width: 4px; }}
    .legend-title {{ font: 700 13px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; fill: #17202a; }}
    .legend-label {{ font: 12px system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; fill: #17202a; }}
  </style>
  <rect width="{width}" height="{height}" fill="#ffffff"/>
  <text class="title" x="{margin_x}" y="42">{html.escape(title)}</text>
  <text class="subtitle" x="{margin_x}" y="66">Generated by scripts/management from the current checkout.</text>
  {"".join(edge_svg)}
  {"".join(node_svg)}
  {"".join(legend_svg)}
</svg>
"""
    atomic_write_text(output_path, svg)
    return output_path


