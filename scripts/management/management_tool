def cmd_advance_state(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    try:
        raw_ref, item = resolve_work_item(model, args.ref)
        target_state = target_state_for(item, args.to)
        state_date = validate_iso_date(args.date or date.today().isoformat())
    except (KeyError, RuntimeError, ValueError) as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    engineer = args.engineer
    if item.state == "Planned" and target_state == "Started" and not (engineer or item.owner):
        print("error: --engineer is required when moving Planned to Started", file=sys.stderr)
        return 1

    print("Before:")
    if raw_ref != item.id:
        print(f"Reference:   {raw_ref}")
    print_work_item(model, item)

    if target_state == item.state and target_state in item.timeline:
        print()
        print(f"No change: {item.id} already has {target_state}: {item.timeline[target_state]}")
        return 0

    if args.dry_run:
        print()
        print(f"Dry run: would move {item.id} from {item.state} to {target_state} using date {state_date}.")
        return 0

    try:
        replace_or_move_work_item(item, target_state, state_date, engineer)
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    updated_model = load_model()
    updated_item = updated_model.work_items[item.id]
    print()
    print("After:")
    print_work_item(updated_model, updated_item)
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Management requirements and backlog helper.")
    subparsers = parser.add_subparsers(dest="command", required=True)

    lint = subparsers.add_parser("lint", help="Validate management file structure and links.")
    lint.add_argument("--strict", action="store_true", help="Treat warnings as failures.")
    lint.set_defaults(func=cmd_lint)

    show_requirement = subparsers.add_parser("show-requirement", help="Print one requirement by id.")
    show_requirement.add_argument("requirement_id")
    show_requirement.set_defaults(func=cmd_show_requirement)

    show_work = subparsers.add_parser("show-work", help="Print one work item and its requirement. Defaults to the current branch.")
    show_work.add_argument("ref", nargs="?", help="Work item id or branch name.")
    show_work.add_argument("--chat-prompt", action="store_true", help="Append a short prompt for discussing the work with an AI assistant.")
    show_work.set_defaults(func=cmd_show_work)

    chat_about = subparsers.add_parser(
        "chat-about",
        aliases=["chat_about"],
        help="Print the current work item, requirement, and AI discussion prompt.",
    )
    chat_about.add_argument("ref", nargs="?", help="Work item id or branch name. Defaults to the current branch.")
    chat_about.set_defaults(func=cmd_chat_about)

    verify_branch = subparsers.add_parser("verify-branch", help="Validate that a branch references a Started work item.")
    verify_branch.add_argument("branch", nargs="?", help="Branch name. Defaults to the current branch.")
    verify_branch.set_defaults(func=cmd_verify_branch)

    advance_state = subparsers.add_parser(
        "advance-state",
        aliases=["advance_state"],
        help="Move a backlog work item to its next state or an explicit target state.",
    )
    advance_state.add_argument("ref", help="Work item id or branch name.")
    advance_state.add_argument("--to", help="Target state. Defaults to the next happy-path state.")
    advance_state.add_argument("--date", help="State-entry date in YYYY-MM-DD. Defaults to today.")
    advance_state.add_argument("--engineer", help="Responsible engineer, required for Planned to Started when the item has no owner.")
    advance_state.add_argument("--dry-run", action="store_true", help="Print the intended transition without editing the backlog.")
    advance_state.set_defaults(func=cmd_advance_state)

    start_work = subparsers.add_parser(
        "start-work",
        aliases=["start_work"],
        help="Validate a Started work item and create or switch to its branch.",
    )
    start_work.add_argument("branch", help="Branch name, such as `<developer>/EN.MCP.01-001` or `feature/EN.MCP.01-001`.")
    start_work.add_argument("--base", help="Base git ref for new branches. Default: origin/main.")
    start_work.add_argument("--user", help="Current responsible user for owner validation.")
    start_work.add_argument("--from-feature", action="store_true", help="Create an ordinary work branch from `feature/<work item id>` instead of the base ref.")
    start_work.add_argument("--feature-branch", help="Feature branch to use with --from-feature. Default: feature/<work item id>.")
    start_work.add_argument("--allow-dirty", action="store_true", help="Allow actual branch switching with uncommitted worktree changes.")
    start_work.add_argument("--dry-run", action="store_true", help="Print validation and git commands without switching branches.")
    start_work.set_defaults(func=cmd_start_work)

    evaluate_plan = subparsers.add_parser(
        "evaluate-plan",
        aliases=["evaluate_plan"],
        help="Evaluate structural planning coherence for a backlog item or branch.",
    )
    evaluate_plan.add_argument("ref", help="Work item id or branch name.")
    evaluate_plan.add_argument("--user", help="Current responsible user for owner validation.")
    evaluate_plan.set_defaults(func=cmd_evaluate_plan)

    verification_check = subparsers.add_parser(
        "verification-check",
        aliases=["verification_check"],
        help="Inventory verification evidence for a work item or branch.",
    )
    verification_check.add_argument("ref", nargs="?", help="Work item id or branch name. Defaults to the current branch.")
    verification_check.add_argument("--base", help="Base git ref for changed-file detection. Default: origin/main.")
    verification_check.add_argument("--limit", type=int, default=8, help="Maximum evidence paths to print per section. Default: 8.")
    verification_check.set_defaults(func=cmd_verification_check)

    review = subparsers.add_parser("review", help="Print a code-review packet for a work item or branch.")
    review.add_argument("ref", nargs="?", help="Work item id or branch name. Defaults to the current branch.")
    review.add_argument("--base", help="Base git ref for changed-file and diff-stat detection. Default: origin/main.")
    review.add_argument("--limit", type=int, default=8, help="Maximum changed paths to print. Default: 8.")
    review.set_defaults(func=cmd_review)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
