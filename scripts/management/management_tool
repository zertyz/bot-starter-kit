def cmd_evaluate_plan(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    try:
        branch_ref = parse_branch_ref(args.ref)
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    item = model.work_items.get(branch_ref.work_id)
    if item is None:
        print(f"error: {branch_ref.work_id} was not found in any backlog", file=sys.stderr)
        return 1

    requirement = model.requirements.get(item.requirement_id)
    siblings = same_requirement_items(model, item)
    completed_siblings = completed_work_items(siblings)
    findings: list[str] = []

    if requirement is None:
        findings.append(issue_line("BLOCKER", f"{item.id} references missing requirement {item.requirement_id}"))
    elif not requirement.body or requirement.body.strip().lower() == "tbd":
        findings.append(issue_line("REVIEW", f"{item.requirement_id} has little or no requirement detail"))
    else:
        findings.append(issue_line("OK", f"{item.id} references existing requirement {item.requirement_id}"))

    if branch_reference_is_plain_work_item(branch_ref):
        findings.append(issue_line("OK", "evaluating by work item id; branch owner is not applicable"))
    elif branch_ref.is_feature:
        findings.append(issue_line("OK", "feature branch syntax is valid"))
    else:
        owner_issues = branch_owner_errors(item, branch_ref, args.user)
        if owner_issues:
            findings.extend(issue_line("REVIEW", issue) for issue in owner_issues)
        else:
            findings.append(issue_line("OK", "ordinary branch owner matches the backlog owner"))

    if item.state in {"Under Planning", "Planned"}:
        findings.append(issue_line("OK", f"{item.state} is a normal planning state"))
    elif terminal_state(item.state):
        findings.append(issue_line("BLOCKER", f"{item.id} is {item.state}"))
    else:
        findings.append(issue_line("REVIEW", f"{item.id} is already {item.state}; confirm this is still a plan evaluation"))

    if valid_state(item.state) and item.state not in item.timeline:
        findings.append(issue_line("REVIEW", f"{item.id} has no dated state trail for {item.state}"))

    if not item.body:
        findings.append(issue_line("REVIEW", f"{item.id} has no work-item description beyond its title"))
    else:
        findings.append(issue_line("OK", f"{item.id} has a work-item description"))

    motivation_description = MOTIVATION_DESCRIPTIONS.get(item.motivation, "unknown motivation")
    if item.motivation == "N" and completed_siblings:
        findings.append(issue_line("REVIEW", "motivation N is marked as new work, but this requirement already has completed work"))
    elif item.motivation in {"R", "F"} and not completed_siblings:
        findings.append(issue_line("REVIEW", f"motivation {item.motivation} usually expects prior completed work for the requirement"))
    elif item.motivation == "X":
        findings.append(issue_line("REVIEW", "experimental work must stay out of main unless converted to normal requirement-backed work"))
    else:
        findings.append(issue_line("OK", f"motivation {item.motivation} means {motivation_description}"))

    blocker_count = sum(1 for finding in findings if finding.startswith("BLOCKER:"))
    review_count = sum(1 for finding in findings if finding.startswith("REVIEW:"))
    if blocker_count:
        verdict = "BLOCKED"
    elif review_count:
        verdict = "NEEDS HUMAN REVIEW"
    else:
        verdict = "STRUCTURALLY SOUND"

    print("Plan Evaluation")
    print("===============")
    if branch_ref.raw != item.id:
        print(f"Reference:   {branch_ref.raw}")
    print_work_item(model, item)
    print()
    print("Sibling work for the same requirement:")
    if siblings:
        for sibling in siblings:
            print(f"  - {sibling.id}: {sibling.state} -- {sibling.title}")
    else:
        print("  - none")
    print()
    print("Findings:")
    for finding in findings:
        print(f"  - {finding}")
    print()
    print(f"Verdict: {verdict}")
    print("Scope note: this command checks structural planning coherence. Product, technical, and schedule judgment remain human decisions.")
    return 0


def next_work_sequence(items: list[WorkItem]) -> str:
    highest = 0
    for item in items:
        highest = max(highest, int(item.sequence))
    if highest >= 999:
        raise ValueError("no available three-digit work sequence remains for this requirement")
    return f"{highest + 1:03d}"


def validate_work_sequence(raw_sequence: str) -> str:
    if not re.fullmatch(r"\d{3}", raw_sequence):
        raise ValueError(f"invalid work sequence {raw_sequence}; expected three digits")
    return raw_sequence


def default_work_motivation(items: list[WorkItem]) -> str:
    if completed_work_items(items):
        return "R"
    return "N"


def default_work_title(requirement: Requirement, motivation: str) -> str:
    if motivation == "R":
        return f"Revisit {requirement.title}"
    if motivation == "F":
        return f"Fix {requirement.title}"
    if motivation == "X":
        return f"Explore {requirement.title}"
    return f"Implement {requirement.title}"


def draft_work_item_id(requirement: Requirement, motivation: str, sequence: str) -> str:
    return f"{requirement.document}{motivation}.{requirement.section}.{requirement.number}{requirement.subtopics}-{sequence}"


def draft_work_entry(requirement: Requirement, work_item_id: str, title: str, state_date: str, body_lines: list[str]) -> list[str]:
    body = body_lines or [
        f"1. Confirm the implementation boundary for `{requirement.id}`.",
        "2. Implement the smallest coherent change that satisfies that boundary.",
        "3. Update verification evidence and traceability before review.",
    ]
    return [
        f"## {work_item_id} -- {title}",
        *body,
        f"==> Under Planning: {state_date};",
    ]


def append_under_planning_entry(path: Path, entry: list[str]) -> None:
    with management_write_lock():
        lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
        lines = ensure_state_section(lines, "Under Planning")
        insert_index = insertion_index_for_state(lines, "Under Planning")
        entry_lines = [f"{line}\n" for line in entry]
        lines[insert_index:insert_index] = ["\n", *entry_lines, "\n"]
        atomic_write_text(path, "".join(lines))


def cmd_draft_plan(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    requirement = model.requirements.get(args.requirement_id)
    if requirement is None:
        print(f"unknown requirement: {args.requirement_id}", file=sys.stderr)
        return 1

    try:
        state_date = validate_iso_date(args.date or date.today().isoformat())
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    existing_items = sorted(
        [item for item in model.work_items.values() if item.requirement_id == requirement.id],
        key=lambda item: item.id,
    )
    active_items = open_work_items(existing_items)
    motivation = args.motivation or default_work_motivation(existing_items)
    try:
        sequence = validate_work_sequence(args.sequence) if args.sequence else next_work_sequence(existing_items)
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1
    work_item_id = draft_work_item_id(requirement, motivation, sequence)
    if work_item_id in model.work_items:
        print(f"error: {work_item_id} already exists", file=sys.stderr)
        return 1

    if args.write and active_items and not args.allow_existing_open:
        print(
            f"error: {requirement.id} already has open work; pass --allow-existing-open if this is an intentional sibling plan",
            file=sys.stderr,
        )
        return 1

    title = args.title or default_work_title(requirement, motivation)
    try:
        validate_single_line_markdown_field(title, "--title")
        for body_line in args.body_line:
            validate_backlog_body_line(body_line, "--body-line")
    except ValueError as err:
        print(f"error: {err}", file=sys.stderr)
        return 1
    entry = draft_work_entry(requirement, work_item_id, title, state_date, args.body_line)

    print("Draft Plan")
    print("==========")
    print_requirement(requirement)
    print()
    print("Existing work for this requirement:")
    if existing_items:
        for item in existing_items:
            print(f"  - {item.id}: {item.state} -- {item.title}")
    else:
        print("  - none")
    print()
    print(f"Backlog file: {relative(MANAGEMENT_DIR / BACKLOG_FILES[requirement.document])}")
    print(f"Motivation:  {motivation} -- {MOTIVATION_DESCRIPTIONS[motivation]}")
    print()
    print("Proposed backlog entry:")
    for line in entry:
        print(line)

    if not args.write:
        print()
        print("Dry run: no backlog file was changed. Re-run with --write to append this entry under Under Planning.")
        return 0

    append_under_planning_entry(MANAGEMENT_DIR / BACKLOG_FILES[requirement.document], entry)
    print()
    print(f"Written: {work_item_id} was appended under Under Planning.")
    print()
    print_lifecycle_next_commands(load_model().work_items[work_item_id])
    return 0


