def relative(path: Path) -> str:
    try:
        return str(path.relative_to(REPO_ROOT))
    except ValueError:
        return str(path)


def superseded_work_id(state: str) -> str | None:
    prefix = "Superseded by "
    return state[len(prefix) :] if state.startswith(prefix) else None


def supersession_cycle_from(
    model: ManagementModel,
    start_id: str,
    proposed_edge: tuple[str, str] | None = None,
) -> list[str] | None:
    positions: dict[str, int] = {}
    chain: list[str] = []
    current_id = start_id
    while current_id in model.work_items:
        if current_id in positions:
            return [*chain[positions[current_id] :], current_id]
        positions[current_id] = len(chain)
        chain.append(current_id)
        if proposed_edge and current_id == proposed_edge[0]:
            current_id = proposed_edge[1]
        else:
            next_id = superseded_work_id(model.work_items[current_id].state)
            if next_id is None:
                return None
            current_id = next_id
    return None


def normalized_supersession_cycle(cycle: list[str]) -> list[str]:
    nodes = cycle[:-1]
    start = min(range(len(nodes)), key=lambda index: nodes[index])
    ordered = [*nodes[start:], *nodes[:start]]
    return [*ordered, ordered[0]]


def validate_supersession_cycles(model: ManagementModel) -> None:
    reported: set[tuple[str, ...]] = set()
    for work_item_id in sorted(model.work_items):
        cycle = supersession_cycle_from(model, work_item_id)
        if cycle is None:
            continue
        normalized = normalized_supersession_cycle(cycle)
        key = tuple(normalized[:-1])
        if key in reported:
            continue
        reported.add(key)
        item = model.work_items[normalized[0]]
        model.error(item.path, item.line, f"supersession cycle detected: {' -> '.join(normalized)}")


def valid_state(state: str) -> bool:
    work_id = superseded_work_id(state)
    return state in VALID_STATE_SET or bool(work_id and WORK_ITEM_ID_RE.fullmatch(work_id))


def terminal_state(state: str) -> bool:
    return state in TERMINAL_STATES or superseded_work_id(state) is not None


def state_order(state: str) -> int:
    if superseded_work_id(state) is not None:
        return len(VALID_STATES)
    try:
        return VALID_STATES.index(state)
    except ValueError:
        return len(VALID_STATES) + 1


@contextlib.contextmanager
def management_write_lock():
    """Serialize management writers across threads and processes."""
    with _MANAGEMENT_THREAD_LOCK:
        depth = getattr(_MANAGEMENT_LOCK_STATE, "depth", 0)
        if depth:
            _MANAGEMENT_LOCK_STATE.depth = depth + 1
            try:
                yield
            finally:
                _MANAGEMENT_LOCK_STATE.depth -= 1
            return

        MANAGEMENT_LOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
        with MANAGEMENT_LOCK_PATH.open("a+", encoding="utf-8") as lock_file:
            fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX)
            _MANAGEMENT_LOCK_STATE.depth = 1
            try:
                yield
            finally:
                _MANAGEMENT_LOCK_STATE.depth = 0
                fcntl.flock(lock_file.fileno(), fcntl.LOCK_UN)


def atomic_write_text(path: Path, content: str) -> None:
    """Replace a text file atomically while retaining its existing mode."""
    with management_write_lock():
        path.parent.mkdir(parents=True, exist_ok=True)
        existing_mode = stat.S_IMODE(path.stat().st_mode) if path.exists() else 0o644
        descriptor, temporary_name = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=path.parent)
        temporary_path = Path(temporary_name)
        try:
            with os.fdopen(descriptor, "w", encoding="utf-8", newline="") as temporary_file:
                temporary_file.write(content)
                temporary_file.flush()
                os.fsync(temporary_file.fileno())
            os.chmod(temporary_path, existing_mode)
            os.replace(temporary_path, path)
            directory_descriptor = os.open(path.parent, os.O_RDONLY)
            try:
                os.fsync(directory_descriptor)
            finally:
                os.close(directory_descriptor)
        finally:
            if temporary_path.exists():
                temporary_path.unlink()


def atomic_write_many(updates: dict[Path, str]) -> None:
    """Commit related text replacements together, restoring every attempted path on failure."""
    with management_write_lock():
        originals = {
            path: (path.exists(), path.read_bytes().decode("utf-8") if path.exists() else "")
            for path in updates
        }
        pending = {
            path: content
            for path, content in updates.items()
            if not originals[path][0] or content != originals[path][1]
        }
        attempted: list[Path] = []
        try:
            for path, content in pending.items():
                attempted.append(path)
                atomic_write_text(path, content)
        except OSError as write_error:
            rollback_errors: list[str] = []
            for path in reversed(attempted):
                existed, original = originals[path]
                try:
                    if existed:
                        atomic_write_text(path, original)
                    elif path.exists():
                        path.unlink()
                except OSError as rollback_error:
                    rollback_errors.append(f"{relative(path)}: {rollback_error}")
            if rollback_errors:
                raise OSError(
                    f"management transaction failed ({write_error}); rollback also failed for {'; '.join(rollback_errors)}"
                ) from write_error
            raise


def canonical_repo_path(raw_path: str, allow_missing: bool = True) -> str:
    if not raw_path or any(character in raw_path for character in "\r\n|`"):
        raise ValueError(f"unsafe evidence path: {raw_path!r}")
    candidate = Path(raw_path)
    if candidate.is_absolute():
        raise ValueError(f"evidence path must be repository-relative: {raw_path}")
    normalized = Path(os.path.normpath(raw_path))
    if normalized == Path(".") or any(part == ".." for part in normalized.parts):
        raise ValueError(f"evidence path escapes the repository: {raw_path}")
    resolved_root = REPO_ROOT.resolve()
    resolved = (REPO_ROOT / normalized).resolve(strict=False)
    try:
        resolved.relative_to(resolved_root)
    except ValueError as err:
        raise ValueError(f"evidence path escapes the repository: {raw_path}") from err
    if not allow_missing and not resolved.exists():
        raise ValueError(f"evidence path does not exist: {normalized.as_posix()}")
    return normalized.as_posix()


def validate_markdown_table_field(value: str, field_name: str, *, forbid_backticks: bool = False) -> str:
    if any(character in value for character in "\r\n|"):
        raise ValueError(f"{field_name} cannot contain a newline or `|`")
    if forbid_backticks and "`" in value:
        raise ValueError(f"{field_name} cannot contain a backtick")
    return value


def is_placeholder_token(value: str) -> bool:
    return PLACEHOLDER_TOKEN_RE.fullmatch(value.strip()) is not None


def structured_ledger_heading_id(line: str) -> tuple[int, str] | None:
    heading_match = MARKDOWN_HEADING_RE.match(line)
    if heading_match is None:
        return None
    first_token = heading_match.group("body").split(maxsplit=1)[0]
    raw_id = first_token.strip("`")
    if (
        raw_id.startswith(("DEC-", "RISK-", "INCIDENT-", "EXP-"))
        or re.fullmatch(r"\d+(?:\.\d+)+(?:-[^\s]+)?", raw_id)
        or raw_id == "<version>"
    ):
        return len(heading_match.group("hashes")), raw_id
    return None


def validate_single_line_markdown_field(
    value: str,
    field_name: str,
    *,
    forbid_backticks: bool = False,
    forbidden_characters: str = "",
) -> str:
    if "\0" in value:
        raise ValueError(f"{field_name} cannot contain NUL")
    if any(character in value for character in "\r\n"):
        raise ValueError(f"{field_name} must be a single line")
    if forbid_backticks and "`" in value:
        raise ValueError(f"{field_name} cannot contain a backtick because it is stored inside backticks")
    present_delimiters = [character for character in forbidden_characters if character in value]
    if present_delimiters:
        rendered = ", ".join(f"`{character}`" for character in present_delimiters)
        raise ValueError(f"{field_name} cannot contain structural delimiter(s): {rendered}")
    return value


def validate_ledger_record_title(value: str) -> str:
    validate_single_line_markdown_field(value, "title")
    if is_placeholder_token(value):
        raise ValueError("title cannot be a placeholder-only token")
    return value


def validate_multiline_markdown_prose(value: str, field_name: str) -> str:
    if "\0" in value:
        raise ValueError(f"{field_name} cannot contain NUL")
    for line in value.splitlines():
        if MARKDOWN_HEADING_LINE_RE.match(line):
            raise ValueError(f"{field_name} cannot contain a Markdown heading")
        label, separator, _remainder = line.partition(":")
        if separator and label in LEDGER_RESERVED_LABELS:
            raise ValueError(f"{field_name} cannot contain reserved ledger label `{label}:`")
        if TIMELINE_MARKER_RE.match(line):
            raise ValueError(f"{field_name} cannot contain reserved timeline syntax")
    return value


def validate_backlog_body_line(value: str, field_name: str) -> str:
    validate_single_line_markdown_field(value, field_name)
    if (
        MARKDOWN_HEADING_LINE_RE.match(value)
        or TIMELINE_MARKER_RE.search(value)
    ):
        raise ValueError(f"{field_name} cannot contain backlog structural syntax")
    return value


def trim_blank_lines(lines: list[str]) -> str:
    start = 0
    end = len(lines)
    while start < end and not lines[start].strip():
        start += 1
    while end > start and not lines[end - 1].strip():
        end -= 1
    return "\n".join(lines[start:end])


def strip_state(raw_state: str) -> str:
    state = raw_state.strip()
    if len(state) >= 2 and state[0] == '"' and state[-1] == '"':
        return state[1:-1]
    return state


def requirement_id(document: str, section: str, number: str, subtopics: str) -> str:
    return f"{document}.{section}.{number}{subtopics}"


def parse_requirement_file(model: ManagementModel, document: str, path: Path) -> None:
    if not path.exists():
        model.error(path, 1, "missing requirement file")
        return

    section: str | None = None
    section_title: str | None = None
    seen_sections: dict[str, int] = {}
    active: Requirement | None = None

    for line_number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
        section_match = SECTION_RE.match(line)
        if section_match:
            section = section_match.group("abbr")
            section_title = section_match.group("title")
            active = None
            if section in seen_sections:
                model.error(path, line_number, f'duplicate section abbreviation "{section}"; first used at line {seen_sections[section]}')
            else:
                seen_sections[section] = line_number
            continue

        heading_match = REQUIREMENT_HEADING_RE.match(line)
        if heading_match:
            active = None
            if section is None or section_title is None:
                model.error(path, line_number, "requirement heading appears before a section heading with an abbreviation")
                continue

            req_id = requirement_id(document, section, heading_match.group("number"), heading_match.group("subtopics"))
            requirement = Requirement(
                id=req_id,
                document=document,
                section=section,
                section_title=section_title,
                number=heading_match.group("number"),
                subtopics=heading_match.group("subtopics"),
                title=heading_match.group("title"),
                path=path,
                line=line_number,
            )
            if req_id in model.requirements:
                first = model.requirements[req_id]
                model.error(path, line_number, f"duplicate requirement id {req_id}; first used at {relative(first.path)}:{first.line}")
            else:
                model.requirements[req_id] = requirement
            active = requirement
            continue

        if re.match(r"^#{2,6}\s+\d", line):
            model.error(path, line_number, "malformed numbered requirement heading; expected `## 01) Title` or `### 01.a) Title`")
            active = None
            continue

        if active is not None:
            active.body_lines.append(line)


def parse_backlog_file(model: ManagementModel, document: str, path: Path) -> None:
    if not path.exists():
        model.error(path, 1, "missing backlog file")
        return

    current_state: str | None = None
    active: WorkItem | None = None

    for line_number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
        work_match = WORK_ITEM_RE.match(line)
        if work_match:
            active = None
            if current_state is None:
                model.error(path, line_number, "work item appears before a backlog state heading")
                continue
            work_document = work_match.group("doc")
            if work_document != document:
                model.error(path, line_number, f"work item belongs to {work_document}, but is listed in {path.name}")

            req_id = requirement_id(work_document, work_match.group("section"), work_match.group("number"), work_match.group("subtopics"))
            item = WorkItem(
                id=work_match.group("id"),
                requirement_id=req_id,
                document=work_document,
                motivation=work_match.group("motivation"),
                section=work_match.group("section"),
                number=work_match.group("number"),
                subtopics=work_match.group("subtopics"),
                sequence=work_match.group("sequence"),
                title=work_match.group("title"),
                state=current_state,
                path=path,
                line=line_number,
            )
            if item.id in model.work_items:
                first = model.work_items[item.id]
                model.error(path, line_number, f"duplicate work item id {item.id}; first used at {relative(first.path)}:{first.line}")
            else:
                model.work_items[item.id] = item
            active = item
            continue

        if WORK_ITEM_HEADING_LIKE_RE.match(line) or line.startswith("## "):
            model.error(path, line_number, "invalid work item heading; expected `## <ID> -- <title>`")
            active = None
            continue

        state_match = STATE_HEADING_RE.match(line)
        if state_match and not line.startswith("##"):
            current_state = strip_state(state_match.group("state"))
            active = None
            if not valid_state(current_state):
                model.warning(path, line_number, f'unknown backlog state "{current_state}"')
            continue

        if active is not None:
            active.body_lines.append(line)

    for item in [work for work in model.work_items.values() if work.path == path]:
        parse_work_timeline(model, item)


def parse_work_timeline(model: ManagementModel, item: WorkItem) -> None:
    blocked = False
    previous_block_date: str | None = None
    previous_timeline_date: str | None = None
    for offset, body_line in enumerate(item.body_lines, start=1):
        history_exception_match = HISTORY_EXCEPTION_RE.search(body_line)
        if history_exception_match:
            entered_at = history_exception_match.group("date")
            reason = history_exception_match.group("reason").strip()
            missing_states = tuple(state.strip() for state in history_exception_match.group("missing").split(",") if state.strip())
            try:
                validate_iso_date(entered_at)
            except ValueError as err:
                model.error(item.path, item.line + offset, str(err))
            if not missing_states or any(state not in VALID_STATE_SET or terminal_state(state) for state in missing_states):
                model.error(item.path, item.line + offset, "history exception names an invalid missing lifecycle state")
            if not reason:
                model.error(item.path, item.line + offset, "history exception requires a reason")
            item.history_exceptions.append(HistoryException(entered_at, missing_states, reason, item.line + offset))
            continue
        if HISTORY_EXCEPTION_PREFIX_RE.search(body_line):
            model.error(item.path, item.line + offset, "malformed history exception")
            continue
        override_match = GATE_OVERRIDE_RE.search(body_line)
        if override_match:
            entered_at = override_match.group("date")
            reason = override_match.group("reason").strip()
            try:
                validate_iso_date(entered_at)
            except ValueError as err:
                model.error(item.path, item.line + offset, str(err))
            if not reason:
                model.error(item.path, item.line + offset, "gate override requires a reason")
            item.gate_overrides.append(
                GateOverride(override_match.group("state"), entered_at, reason, item.line + offset)
            )
            continue
        if GATE_OVERRIDE_PREFIX_RE.search(body_line):
            model.error(item.path, item.line + offset, "malformed gate override history")
            continue
        block_match = BLOCK_EVENT_RE.search(body_line)
        if block_match:
            action = block_match.group("action")
            entered_at = block_match.group("date")
            reason = block_match.group("reason").strip()
            line = item.line + offset
            try:
                validate_iso_date(entered_at)
            except ValueError as err:
                model.error(item.path, line, str(err))
            if previous_block_date and entered_at < previous_block_date:
                model.error(item.path, line, "block history dates must be append-only and nondecreasing")
            if action == "Blocked" and blocked:
                model.error(item.path, line, "work item is already blocked; append Unblocked before another Blocked event")
            if action == "Unblocked" and not blocked:
                model.error(item.path, line, "work item is not blocked; Unblocked has no preceding Blocked event")
            blocked = action == "Blocked"
            previous_block_date = entered_at
            if not reason:
                model.error(item.path, line, "block history event requires a reason")
            item.block_events.append(BlockEvent(action, entered_at, reason, line))
            continue
        if BLOCK_EVENT_PREFIX_RE.search(body_line):
            model.error(item.path, item.line + offset, "malformed block history; expected `==> Blocked|Unblocked: YYYY-MM-DD; Reason: ...`")
            continue
        marker_match = TIMELINE_MARKER_RE.search(body_line)
        if not marker_match:
            continue
        trail = marker_match.group("trail")
        owner_match = TIMELINE_OWNER_RE.match(trail)
        if owner_match and TIMELINE_STATE_RE.search(trail[owner_match.end() :]):
            item.owner = owner_match.group("owner").strip()
        for state_match in TIMELINE_STATE_RE.finditer(trail):
            state = state_match.group("state")
            entered_at = state_match.group("date")
            if state in item.timeline:
                model.error(item.path, item.line + offset, f"duplicate timeline state {state}")
            try:
                validate_iso_date(entered_at)
            except ValueError as err:
                model.error(item.path, item.line + offset, str(err))
            if previous_timeline_date and entered_at < previous_timeline_date:
                model.error(item.path, item.line + offset, "lifecycle state dates must be nondecreasing")
            previous_timeline_date = entered_at
            item.timeline[state] = entered_at

    if valid_state(item.state) and item.state not in item.timeline:
        model.warning(item.path, item.line, f"{item.id} is in state {item.state}, but has no dated `{item.state}: YYYY-MM-DD` status trail")
    validate_recorded_work_history(model, item)


def lifecycle_path(start: str, target: str) -> list[str] | None:
    if start == target:
        return [start]
    queue: list[list[str]] = [[start]]
    seen = {start}
    while queue:
        path = queue.pop(0)
        for next_state in sorted(ALLOWED_STATE_TRANSITIONS.get(path[-1], set()), key=state_order):
            if next_state in seen:
                continue
            candidate = [*path, next_state]
            if next_state == target:
                return candidate
            seen.add(next_state)
            queue.append(candidate)
    return None


def validate_recorded_work_history(model: ManagementModel, item: WorkItem) -> None:
    states = list(item.timeline)
    required_missing_states: list[str] = []
    for previous, current in zip(states, states[1:]):
        if terminal_state(previous):
            model.error(item.path, item.line, f"terminal lifecycle state {previous} is followed by {current}")
            continue
        if current in {"Rejected", "Cancelled"} or superseded_work_id(current):
            continue
        if current in ALLOWED_STATE_TRANSITIONS.get(previous, set()):
            continue
        path = lifecycle_path(previous, current)
        if path is None:
            model.error(item.path, item.line, f"recorded lifecycle transition {previous} -> {current} is backward or invalid")
            continue
        required_missing_states.extend(path[1:-1])

    if states and item.state in item.timeline and states[-1] != item.state:
        model.error(item.path, item.line, f"current backlog state {item.state} is not the final recorded lifecycle state {states[-1]}")

    exception_states = [state for exception in item.history_exceptions for state in exception.missing_states]
    if sorted(exception_states) != sorted(required_missing_states):
        if required_missing_states:
            missing = ", ".join(required_missing_states)
            model.error(item.path, item.line, f"recorded lifecycle history skips {missing}; add an exact History exception marker")
        if exception_states:
            extra = ", ".join(exception_states)
            model.error(item.path, item.line, f"history exception is unneeded or does not match the skipped lifecycle states: {extra}")

    latest_timeline_date = max(item.timeline.values(), default=None)
    for exception in item.history_exceptions:
        if latest_timeline_date and exception.entered_at < latest_timeline_date:
            model.error(item.path, exception.line, f"history exception date {exception.entered_at} predates lifecycle history through {latest_timeline_date}")

    seen_overrides: set[str] = set()
    for override in item.gate_overrides:
        if override.target_state in seen_overrides:
            model.error(item.path, override.line, f"duplicate gate override for {override.target_state}")
        seen_overrides.add(override.target_state)
        target_date = item.timeline.get(override.target_state)
        if target_date is None:
            model.error(item.path, override.line, f"gate override targets unrecorded lifecycle state {override.target_state}")
        elif target_date != override.entered_at:
            model.error(item.path, override.line, f"gate override date {override.entered_at} does not match {override.target_state}: {target_date}")


def load_model() -> ManagementModel:
    model = ManagementModel()

    for document, name in REQUIREMENT_FILES.items():
        parse_requirement_file(model, document, MANAGEMENT_DIR / name)

    for document, name in BACKLOG_FILES.items():
        parse_backlog_file(model, document, MANAGEMENT_DIR / name)

    for name in [*SUPPORTING_FILES, *GOVERNANCE_FILES]:
        path = MANAGEMENT_DIR / name
        if not path.exists():
            model.error(path, 1, "missing supporting management file")

    for item in model.work_items.values():
        if item.requirement_id not in model.requirements:
            model.error(item.path, item.line, f"{item.id} references missing requirement {item.requirement_id}")
        for state in {item.state, *item.timeline.keys()}:
            superseding_id = superseded_work_id(state)
            if not superseding_id:
                continue
            if superseding_id == item.id:
                model.error(item.path, item.line, f"{item.id} cannot supersede itself")
            elif superseding_id not in model.work_items:
                model.error(item.path, item.line, f"superseding work item {superseding_id} was not found in any backlog")

    validate_supersession_cycles(model)
    validate_traceability(model)
    validate_supporting_ledgers(model)

    return model


def current_branch() -> str:
    branch = git_output(["branch", "--show-current"])
    if not branch:
        raise RuntimeError("git is in detached HEAD; pass a branch or work item explicitly")
    return branch


def current_branch_or_none() -> str | None:
    branch = git_output(["branch", "--show-current"])
    return branch or None


def git_result(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", *args],
        cwd=REPO_ROOT,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def git_output(args: list[str]) -> str:
    result = git_result(args)
    if result.returncode != 0:
        detail = result.stderr.strip() or result.stdout.strip() or f"git {' '.join(args)} failed"
        raise RuntimeError(detail)
    return result.stdout.strip()


def git_ref_exists(ref: str) -> bool:
    return git_result(["rev-parse", "--verify", "--quiet", ref]).returncode == 0


def git_branch_exists(branch: str) -> bool:
    return git_ref_exists(f"refs/heads/{branch}")


def git_worktree_is_dirty() -> bool:
    return bool(git_output(["status", "--porcelain"]))


def git_name_list(args: list[str]) -> set[str]:
    result = git_result(args)
    if result.returncode != 0:
        return set()
    return {line.strip() for line in result.stdout.splitlines() if line.strip()}


def changed_files(base_ref: str | None) -> tuple[list[str], list[str]]:
    files: set[str] = set()
    notes: list[str] = []
    if base_ref:
        if git_ref_exists(base_ref):
            files.update(git_name_list(["diff", "--name-only", "--diff-filter=ACMRTUXB", f"{base_ref}...HEAD"]))
        else:
            notes.append(f"Base ref {base_ref} does not exist locally; committed branch diff was skipped.")
    files.update(git_name_list(["diff", "--name-only", "--diff-filter=ACMRTUXB", "HEAD"]))
    files.update(git_name_list(["diff", "--cached", "--name-only", "--diff-filter=ACMRTUXB"]))

    status = git_output(["status", "--porcelain", "-uall"])
    for line in status.splitlines():
        if len(line) < 4:
            continue
        if line.startswith("?? "):
            files.add(line[3:])
        elif " -> " in line:
            files.add(line.split(" -> ", maxsplit=1)[1])
        else:
            files.add(line[3:])
    tracked = set(tracked_files())
    current_files = [
        path
        for path in files
        if path
        and "__pycache__/" not in path
        and (path in tracked or (REPO_ROOT / path).exists())
    ]
    return sorted(current_files), notes


def diff_stat(base_ref: str | None) -> tuple[list[str], list[str]]:
    sections: list[str] = []
    notes: list[str] = []
    if base_ref:
        if git_ref_exists(base_ref):
            branch_stat = git_output(["diff", "--stat", "--compact-summary", f"{base_ref}...HEAD"])
            if branch_stat:
                sections.append(f"Committed branch diff against {base_ref}:\n{branch_stat}")
        else:
            notes.append(f"Base ref {base_ref} does not exist locally; committed branch diff stat was skipped.")

    worktree_stat = git_output(["diff", "--stat", "--compact-summary", "HEAD"])
    if worktree_stat:
        sections.append(f"Uncommitted worktree diff against HEAD:\n{worktree_stat}")
    staged_stat = git_output(["diff", "--cached", "--stat", "--compact-summary"])
    if staged_stat:
        sections.append(f"Staged diff:\n{staged_stat}")
    return sections, notes


def tracked_files() -> list[str]:
    return sorted(git_name_list(["ls-files"]))


def read_repo_file(path: str) -> str:
    full_path = REPO_ROOT / path
    if not full_path.is_file():
        return ""
    try:
        return full_path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return ""


def file_contains_any(path: str, patterns: list[str]) -> bool:
    content = read_repo_file(path)
    return any(pattern in content for pattern in patterns)


def rust_source_file(path: str) -> bool:
    return path.startswith("src/") and path.endswith(".rs")


def test_evidence_file(path: str) -> bool:
    return (
        path.startswith("tests/")
        or Path(path).name.startswith("test_")
        or path.endswith("_test.rs")
        or (path.endswith(".rs") and file_contains_any(path, ["#[test]", "#[tokio::test]", "#[async_std::test]", "#[cfg(test)]"]))
    )


def benchmark_evidence_file(path: str) -> bool:
    return path.startswith("benches/") or "benchmark" in path.lower() or (path.endswith(".rs") and file_contains_any(path, ["criterion_group!", "Criterion"]))


def operations_evidence_file(path: str) -> bool:
    return path.startswith(".github/") or path.startswith("scripts/operations/") or path in {
        "management/OPERATIONS.md",
        "management/OPERATIONS.backlog.md",
        "management/RELEASES.md",
        "management/INCIDENTS.md",
        "management/RISKS.md",
    }


def security_evidence_file(path: str) -> bool:
    lowered = path.lower()
    return (
        "security" in lowered
        or "secret" in lowered
        or "tls" in lowered
        or path in {"management/RISKS.md", "management/INCIDENTS.md"}
        or path.startswith("scripts/operations/")
    )


def recovery_evidence_file(path: str) -> bool:
    lowered = path.lower()
    return (
        "recovery" in lowered
        or "rollback" in lowered
        or "backup" in lowered
        or path in {"management/RELEASES.md", "management/INCIDENTS.md", "management/OPERATIONS.md"}
    )


def product_evidence_file(path: str) -> bool:
    return path in {"management/BUSINESS.md", "management/BUSINESS.backlog.md"} or path.startswith("README")


def print_evidence_line(title: str, evidence: list[str], status_if_missing: str, reason: str) -> None:
    if evidence:
        print(f"{title}: FOUND")
        for path in evidence:
            print(f"  - {path}")
        return
    print(f"{title}: {status_if_missing}")
    print(f"  - {reason}")


def limited(paths: list[str], limit: int = 8) -> list[str]:
    if limit <= 0:
        return paths
    if len(paths) <= limit:
        return paths
    remaining = len(paths) - limit
    return [*paths[:limit], f"... {remaining} more"]


def parse_branch_or_work_ref(raw_ref: str) -> tuple[str | None, str]:
    branch_ref = parse_branch_ref(raw_ref)
    return branch_ref.owner, branch_ref.work_id


def parse_branch_ref(raw_ref: str) -> BranchRef:
    match = BRANCH_RE.match(raw_ref)
    if not match:
        raise ValueError(f"invalid branch or work item reference: {raw_ref}")
    return BranchRef(
        raw=raw_ref,
        work_id=match.group("work_id"),
        owner=match.group("owner"),
        is_feature=raw_ref.startswith("feature/"),
    )


def resolve_work_item(model: ManagementModel, raw_ref: str | None) -> tuple[str, WorkItem]:
    ref = raw_ref if raw_ref else current_branch()
    _owner, work_id = parse_branch_or_work_ref(ref)
    if work_id not in model.work_items:
        raise KeyError(f"{work_id} was not found in any backlog")
    return ref, model.work_items[work_id]


def validate_iso_date(raw_date: str) -> str:
    if not re.fullmatch(r"\d{4}-\d{2}-\d{2}", raw_date):
        raise ValueError(f"invalid date {raw_date}; expected YYYY-MM-DD")
    try:
        parsed = datetime.strptime(raw_date, "%Y-%m-%d")
    except ValueError as err:
        raise ValueError(f"invalid date {raw_date}; expected YYYY-MM-DD") from err
    if parsed.strftime("%Y-%m-%d") != raw_date:
        raise ValueError(f"invalid date {raw_date}; expected YYYY-MM-DD")
    return raw_date


def target_state_for(item: WorkItem, raw_state: str | None) -> str:
    if raw_state:
        state = strip_state(raw_state)
        if not valid_state(state):
            valid = ", ".join([*VALID_STATES, "Superseded by <existing work item id>"])
            raise ValueError(f"invalid target state {raw_state}; expected one of: {valid}")
        return state

    state = STATE_FLOW.get(item.state)
    if state is None:
        raise ValueError(f"{item.id} is in state {item.state}; no default next state is defined")
    return state


def validate_state_transition(model: ManagementModel, item: WorkItem, target_state: str, state_date: str) -> None:
    if target_state == item.state:
        return
    if item.blocked:
        raise ValueError(
            f"{item.id} is blocked; run scripts/management/unblock_work {item.id} "
            '--reason "<RESOLUTION>" before advancing its lifecycle state'
        )
    if terminal_state(item.state):
        raise ValueError(f"{item.id} is in terminal state {item.state}; it cannot transition to {target_state}")
    superseding_id = superseded_work_id(target_state)
    if superseding_id:
        if superseding_id == item.id:
            raise ValueError(f"{item.id} cannot supersede itself")
        if superseding_id not in model.work_items:
            raise ValueError(f"superseding work item {superseding_id} was not found in any backlog")
        cycle = supersession_cycle_from(model, item.id, (item.id, superseding_id))
        if cycle:
            raise ValueError(f"supersession cycle detected: {' -> '.join(cycle)}")
    elif target_state not in {"Rejected", "Cancelled"} and target_state not in ALLOWED_STATE_TRANSITIONS.get(item.state, set()):
        allowed = sorted(ALLOWED_STATE_TRANSITIONS.get(item.state, set()))
        allowed.extend(["Rejected", "Cancelled", "Superseded by <existing work item id>"])
        raise ValueError(f"invalid transition {item.state} -> {target_state}; allowed targets: {', '.join(allowed)}")

    historical_dates = [
        *item.timeline.values(),
        *(event.entered_at for event in item.block_events),
        *(event.entered_at for event in item.gate_overrides),
    ]
    if historical_dates and state_date < max(historical_dates):
        raise ValueError(f"state date {state_date} predates existing history through {max(historical_dates)}")


def deterministic_gate_failures(item: WorkItem, target_state: str) -> list[str]:
    if target_state not in {"Merged", "Rolled Out"}:
        return []
    links = [link for link in traceability_links() if link.work_item_id == item.id]
    failures: list[str] = []
    paths = sorted({path for link in links for path in evidence_paths(link)})
    existing_paths: list[str] = []
    for path in paths:
        try:
            canonical = canonical_repo_path(path)
        except ValueError:
            continue
        if (REPO_ROOT / canonical).exists():
            existing_paths.append(canonical)
    if not links:
        failures.append(f"{item.id} has no TRACEABILITY.md row")
    if not existing_paths:
        failures.append(f"{item.id} has no existing concrete evidence path")
    if target_state == "Rolled Out":
        releases_path = MANAGEMENT_DIR / "RELEASES.md"
        released_entries = []
        if releases_path.exists():
            for entry in ledger_entries(releases_path):
                production_decision = _ledger_section(entry, "Production decision").splitlines()[0].strip("` ") if _ledger_section(entry, "Production decision") else ""
                if (
                    not release_entry_schema_errors(entry)
                    and production_decision == "Released"
                    and item.id in release_entry_work_ids(entry)
                ):
                    released_entries.append(entry)
        if not released_entries:
            failures.append(f"{item.id} is not included in a schema-valid Released entry in RELEASES.md")
        operational_paths = [path for path in existing_paths if operations_evidence_file(path)]
        if not operational_paths:
            failures.append(f"{item.id} has no linked operational or release evidence path")
    return failures


def require_main_for_mutation(dry_run: bool) -> None:
    if dry_run:
        return
    branch = current_branch()
    if branch != "main":
        raise RuntimeError(f"management mutation requires branch main; current branch is {branch}. Use --dry-run to inspect it here.")


def state_heading(state: str) -> str:
    return STATE_HEADINGS.get(state, f"# {state}")


def backlog_sections(lines: list[str]) -> list[tuple[str, int, int]]:
    starts: list[tuple[str, int]] = []
    for index, line in enumerate(lines):
        match = STATE_HEADING_RE.match(line.rstrip("\n"))
        if match and not line.startswith("##"):
            starts.append((strip_state(match.group("state")), index))

    sections: list[tuple[str, int, int]] = []
    for index, (state, start) in enumerate(starts):
        end = starts[index + 1][1] if index + 1 < len(starts) else len(lines)
        sections.append((state, start, end))
    return sections


def find_work_block(lines: list[str], work_item_id: str) -> tuple[int, int]:
    start: int | None = None
    for index, line in enumerate(lines):
        match = WORK_ITEM_RE.match(line.rstrip("\n"))
        if match and match.group("id") == work_item_id:
            start = index
            break
    if start is None:
        raise ValueError(f"{work_item_id} was not found in its backlog file")

    end = len(lines)
    for index in range(start + 1, len(lines)):
        line = lines[index]
        if line.startswith("# ") or line.startswith("## "):
            end = index
            break
    return start, end


def timeline_entries(item: WorkItem, target_state: str, state_date: str) -> list[tuple[str, str]]:
    entries = list(item.timeline.items())
    if target_state not in item.timeline:
        entries.append((target_state, state_date))
    return entries


def timeline_line(item: WorkItem, target_state: str, state_date: str, engineer: str | None, indent: str = "") -> str:
    owner = engineer or item.owner
    prefix = f"{indent}==> "
    if owner:
        prefix += f"{owner}. "
    states = "; ".join(f"{state}: {entered_at}" for state, entered_at in timeline_entries(item, target_state, state_date))
    return f"{prefix}{states};\n"


def update_work_block_timeline(block: list[str], item: WorkItem, target_state: str, state_date: str, engineer: str | None) -> list[str]:
    updated = list(block)
    timeline_index: int | None = None
    indent = ""

    for index, line in enumerate(updated):
        marker_match = TIMELINE_MARKER_RE.search(line)
        if marker_match and TIMELINE_STATE_RE.search(marker_match.group("trail")):
            timeline_index = index
            indent = line[: marker_match.start()]

    if timeline_index is None:
        insert_index = len(updated)
        while insert_index > 0 and not updated[insert_index - 1].strip():
            insert_index -= 1
        updated.insert(insert_index, timeline_line(item, target_state, state_date, engineer))
        return updated

    updated[timeline_index] = timeline_line(item, target_state, state_date, engineer, indent)
    return updated


def ensure_state_section(lines: list[str], state: str) -> list[str]:
    if any(section_state == state for section_state, _start, _end in backlog_sections(lines)):
        return lines

    heading = f"{state_heading(state)}\n"
    target_order = state_order(state)

    insert_index = len(lines)
    for section_state, start, _end in backlog_sections(lines):
        if state_order(section_state) > target_order:
            insert_index = start
            break

    section_lines = [heading, "\n"]
    if insert_index == len(lines):
        while lines and not lines[-1].strip():
            lines.pop()
        if lines:
            lines.extend(["\n", "\n", *section_lines])
        else:
            lines.extend(section_lines)
        return lines

    if insert_index > 0 and lines[insert_index - 1].strip():
        section_lines.insert(0, "\n")
    lines[insert_index:insert_index] = section_lines
    return lines


def insertion_index_for_state(lines: list[str], state: str) -> int:
    for section_state, start, end in backlog_sections(lines):
        if section_state != state:
            continue
        insert_index = end
        while insert_index > start + 1 and not lines[insert_index - 1].strip():
            insert_index -= 1
        return insert_index
    raise ValueError(f"missing state section {state}")


def normalize_moved_block(block: list[str]) -> list[str]:
    start = 0
    end = len(block)
    while start < end and not block[start].strip():
        start += 1
    while end > start and not block[end - 1].strip():
        end -= 1
    normalized = block[start:end]
    if normalized and not normalized[-1].endswith("\n"):
        normalized[-1] += "\n"
    return normalized


def render_work_item_transition(
    item: WorkItem,
    target_state: str,
    state_date: str,
    engineer: str | None,
    override_reason: str | None,
) -> str:
    lines = item.path.read_text(encoding="utf-8").splitlines(keepends=True)
    start, end = find_work_block(lines, item.id)
    block = update_work_block_timeline(lines[start:end], item, target_state, state_date, engineer)
    if override_reason:
        insert_index = len(block)
        while insert_index > 1 and not block[insert_index - 1].strip():
            insert_index -= 1
        block.insert(insert_index, f"==> Gate override for {target_state}: {state_date}; Reason: {override_reason}\n")

    if target_state == item.state:
        lines[start:end] = block
        return "".join(lines)

    del lines[start:end]
    lines = ensure_state_section(lines, target_state)
    insert_index = insertion_index_for_state(lines, target_state)
    normalized_block = normalize_moved_block(block)
    insertion = ["\n", *normalized_block, "\n"]
    lines[insert_index:insert_index] = insertion
    return "".join(lines)


def render_traceability_work_state(work_item_id: str, target_state: str) -> str | None:
    path = MANAGEMENT_DIR / "TRACEABILITY.md"
    if not path.exists():
        return None
    text = path.read_text(encoding="utf-8")
    lines = text.splitlines()
    current_link_indexes = {line_number - 1 for line_number, _ in traceability_current_link_lines(text)}
    changed = False
    for index, line in enumerate(lines):
        if index not in current_link_indexes:
            continue
        columns = traceability_table_cells(line)
        if columns is None or len(columns) != 4 or columns[1].strip("`") != work_item_id:
            continue
        lines[index] = f"| {columns[0]} | {columns[1]} | {target_state} | {columns[3]} |"
        changed = True
    return "\n".join(lines).rstrip() + "\n" if changed else None


def append_block_event(item: WorkItem, action: str, event_date: str, reason: str) -> None:
    with management_write_lock():
        lines = item.path.read_text(encoding="utf-8").splitlines(keepends=True)
        start, end = find_work_block(lines, item.id)
        insert_index = end
        while insert_index > start + 1 and not lines[insert_index - 1].strip():
            insert_index -= 1
        lines.insert(insert_index, f"==> {action}: {event_date}; Reason: {reason}\n")
        atomic_write_text(item.path, "".join(lines))


