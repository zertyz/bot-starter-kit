def cmd_audit_requirements(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    requirements = sorted(model.requirements.values(), key=lambda requirement: requirement.id)
    if args.document:
        requirements = [requirement for requirement in requirements if requirement.document == args.document]

    traceability_path = MANAGEMENT_DIR / "TRACEABILITY.md"
    traceability = traceability_path.read_text(encoding="utf-8") if traceability_path.exists() else ""
    duplicate_titles = duplicate_requirement_groups(requirements, lambda requirement: " ".join(words_in(requirement.title)))
    duplicate_bodies = duplicate_requirement_groups(requirements, lambda requirement: " ".join(words_in(requirement.body)))

    findings: list[AuditFinding] = []
    prompts: list[SemanticPrompt] = []
    work_coverage: list[tuple[Requirement, dict[str, object]]] = []
    evidence_coverage: list[tuple[Requirement, dict[str, object]]] = []
    coverage_acknowledgements: list[tuple[Requirement, list[dict[str, object]]]] = []
    all_links = traceability_links()
    all_area_acknowledgements = unmapped_requirement_area_acknowledgements()
    for requirement in requirements:
        findings.extend(audit_requirement(model, requirement, traceability, duplicate_titles, duplicate_bodies))
        prompts.extend(requirement_semantic_prompts(requirement))
        work_coverage.append((requirement, requirement_work_coverage(model, requirement)))
        evidence_coverage.append((requirement, requirement_evidence_coverage(model, requirement, all_links)))
        acknowledgements = requirement_coverage_acknowledgements(requirement, all_area_acknowledgements)
        if acknowledgements:
            coverage_acknowledgements.append((requirement, acknowledgements))

    severity_order = {severity: index for index, severity in enumerate(AUDIT_SEVERITIES)}
    findings.sort(key=lambda finding: (severity_order.get(finding.severity, 99), finding.requirement.id, finding.category))
    prompts.sort(key=lambda prompt: (prompt.status, prompt.requirement.id, prompt.category))
    counts = {severity: sum(1 for finding in findings if finding.severity == severity) for severity in AUDIT_SEVERITIES}
    active_prompts = [prompt for prompt in prompts if prompt.status == "active"]
    acknowledged_prompts = [prompt for prompt in prompts if prompt.status == "acknowledged"]
    work_status_counts = {
        status: sum(1 for _, coverage in work_coverage if coverage["status"] == status)
        for status in ("unplanned", "active", "completed", "mixed", "abandoned")
    }
    evidence_status_counts = {
        status: sum(1 for _, coverage in evidence_coverage if coverage["status"] == status)
        for status in ("not_applicable", "pending", "evidenced", "gap")
    }

    print("Requirement Audit")
    print("=================")
    if args.document:
        print(f"Document:             {args.document} -- {REQUIREMENT_FILES[args.document]}")
    print(f"Requirements checked: {len(requirements)}")
    print(f"Work items:           {len(model.work_items)}")
    print(f"Traceability source:  {relative(traceability_path)}")
    print()
    print("Quality summary:")
    for severity in AUDIT_SEVERITIES:
        print(f"  {severity}: {counts[severity]}")
    print(f"Semantic prompts:      {len(active_prompts)} active; {len(acknowledged_prompts)} acknowledged")
    print(
        "Planning coverage:     "
        + "; ".join(
            f"{status} {work_status_counts[status]}"
            for status in ("unplanned", "active", "completed", "mixed", "abandoned")
        )
    )
    print(
        "Evidence coverage:     "
        + "; ".join(f"{status} {evidence_status_counts[status]}" for status in ("not_applicable", "pending", "evidenced", "gap"))
    )
    print()
    print("Quality findings:")
    if not findings:
        print("  - none")
    else:
        printable = findings if args.limit <= 0 else findings[: args.limit]
        for finding in printable:
            print(f"  - {finding.format()}")
        if args.limit > 0 and len(findings) > args.limit:
            print(f"  - ... {len(findings) - args.limit} more")
    print()
    print("Semantic prompts:")
    printable_prompts = active_prompts if args.limit <= 0 else active_prompts[: args.limit]
    if printable_prompts:
        for prompt in printable_prompts:
            print(f"  - {prompt.format()}")
        if args.limit > 0 and len(active_prompts) > args.limit:
            print(f"  - ... {len(active_prompts) - args.limit} more")
    else:
        print("  - none")
    if acknowledged_prompts:
        print("Acknowledged semantic prompts:")
        printable_acknowledged = acknowledged_prompts if args.limit <= 0 else acknowledged_prompts[: args.limit]
        for prompt in printable_acknowledged:
            print(f"  - {prompt.format()}")
        if args.limit > 0 and len(acknowledged_prompts) > args.limit:
            print(f"  - ... {len(acknowledged_prompts) - args.limit} more")
    if coverage_acknowledgements:
        print("Acknowledged unmapped coverage:")
        for requirement, acknowledgements in coverage_acknowledgements:
            for acknowledgement in acknowledgements:
                print(
                    f"  - {requirement.id}: {acknowledgement['pattern']} at management/TRACEABILITY.md:{acknowledgement['line']}: "
                    f"{acknowledgement['description'] or 'no description'}"
                )
    print()
    print("Scope note: quality findings are deterministic observations. Semantic prompts are lexical review leads, while planning and evidence coverage report lifecycle facts. Market fit, code-semantic drift, and final requirement wording remain human decisions.")

    if args.strict and (counts["BLOCKER"] or counts["REVIEW"]):
        return 1
    return 0


