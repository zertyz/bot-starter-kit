def cmd_sync_requirement(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    requirement = model.requirements.get(args.requirement_id)
    if requirement is None:
        print(f"unknown requirement: {args.requirement_id}", file=sys.stderr)
        return 1

    work_items = requirement_work_items(model, requirement)
    completed_items = completed_work_items(work_items)
    all_links = traceability_links()
    links = traceability_links_for(requirement, all_links)
    work_coverage = requirement_work_coverage(model, requirement)
    evidence_coverage = requirement_evidence_coverage(model, requirement, all_links)
    coverage_acknowledgements = requirement_coverage_acknowledgements(requirement)
    paths = sorted({path for link in links for path in evidence_paths(link)})
    path_statuses = evidence_path_statuses(paths)
    missing_paths = [path for path, status in path_statuses if status == "missing"]
    untracked_paths = [path for path, status in path_statuses if status == "exists but is not tracked"]
    exact_mentions = source_files_mentioning([requirement.id], args.limit, implementation_only=True)
    term_mentions = source_files_mentioning(requirement_source_terms(requirement), args.limit, implementation_only=True)
    signals: list[str] = []

    if work_coverage["status"] == "unplanned":
        signals.append(issue_line("INFO", "requirement is not yet mapped to backlog work"))
    elif work_coverage["status"] == "abandoned":
        signals.append(issue_line("INFO", "only rejected, cancelled, or superseded work maps to this requirement"))
    if evidence_coverage["status"] == "pending":
        signals.append(issue_line("INFO", "mapped work has not reached Merged or Rolled Out; evidence coverage is pending"))
    elif evidence_coverage["status"] == "gap":
        if evidence_coverage["missing_traceability_work_item_ids"]:
            signals.append(
                issue_line(
                    "REVIEW",
                    "completed work has no TRACEABILITY.md row: "
                    + ", ".join(evidence_coverage["missing_traceability_work_item_ids"]),
                )
            )
        if evidence_coverage["missing_evidence_work_item_ids"]:
            signals.append(
                issue_line(
                    "REVIEW",
                    "completed work has no existing concrete evidence path: "
                    + ", ".join(evidence_coverage["missing_evidence_work_item_ids"]),
                )
            )
    if missing_paths:
        signals.append(issue_line("BLOCKER", f"traceability references missing evidence paths: {', '.join(missing_paths[:4])}"))
    if untracked_paths:
        signals.append(issue_line("REVIEW", f"traceability references untracked evidence paths: {', '.join(untracked_paths[:4])}"))
    if completed_items and not exact_mentions and not paths:
        signals.append(issue_line("REVIEW", "completed work exists, but no exact requirement-id mention or evidence path was found"))
    if not signals:
        signals.append(issue_line("OK", "local traceability structure is coherent"))

    blocker_count, review_count = sync_signal_counts(signals)
    if blocker_count:
        verdict = "DRIFT RISK"
    elif review_count:
        verdict = "NEEDS REVIEW"
    else:
        verdict = "LOCALLY COHERENT"

    print("Requirement Sync")
    print("================")
    print_requirement(requirement)
    print()
    print("Mapped work:")
    if work_items:
        for item in work_items:
            print(f"  - {item.id}: {item.state} -- {item.title}")
    else:
        print("  - none")
    print(f"Planning coverage: {work_coverage['status']}")
    print()
    print("Traceability rows:")
    if links:
        for link in links:
            print(f"  - line {link.line}: {link.requirement_id} -> {link.work_item_id}: {link.state}; {link.evidence}")
    else:
        print("  - none")
    print(f"Evidence coverage: {evidence_coverage['status']}")
    if coverage_acknowledgements:
        print("Acknowledged unmapped coverage:")
        for acknowledgement in coverage_acknowledgements:
            print(
                f"  - {acknowledgement['pattern']} at management/TRACEABILITY.md:{acknowledgement['line']}: "
                f"{acknowledgement['description'] or 'no description'}"
            )
    print()
    print("Evidence path status:")
    if path_statuses:
        for path, status in path_statuses:
            print(f"  - {path}: {status}")
    else:
        print("  - no concrete evidence paths listed")
    print()
    print("Source mentions:")
    if exact_mentions:
        print("  Exact requirement id:")
        for path in exact_mentions:
            print(f"    - {path}")
    else:
        print("  Exact requirement id: none")
    if term_mentions:
        print("  Requirement terms:")
        for path in term_mentions:
            print(f"    - {path}")
    else:
        print("  Requirement terms: none")
    print()
    print("Signals:")
    for signal in signals:
        print(f"  - {signal}")
    print()
    print(f"Verdict: {verdict}")
    print("Scope note: this command checks local traceability and evidence references. It does not prove runtime behavior satisfies the requirement.")

    if args.strict and (blocker_count or review_count):
        return 1
    return 0


