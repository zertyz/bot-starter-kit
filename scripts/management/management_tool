def configure_subcommand_help(subparsers) -> None:
    canonical_actions = {action.dest: action for action in subparsers._choices_actions}
    missing = sorted(set(canonical_actions) - set(COMMAND_GUIDANCE))
    unknown = sorted(set(COMMAND_GUIDANCE) - set(canonical_actions))
    if missing or unknown:
        raise RuntimeError(f"command guidance mismatch; missing={missing}, unknown={unknown}")

    for command, action in canonical_actions.items():
        when, examples = COMMAND_GUIDANCE[command]
        command_parser = subparsers.choices[command]
        command_parser.formatter_class = argparse.RawDescriptionHelpFormatter
        purpose_text = textwrap.fill(action.help, width=88)
        when_text = textwrap.fill(when, width=88, initial_indent="  ", subsequent_indent="  ")
        command_parser.description = f"{purpose_text}\n\nWhen to use:\n{when_text}"
        command_parser.epilog = (
            "Examples:\n"
            + "\n".join(f"  {example}" for example in examples)
            + "\n\nSee management/TOOLING.md for the complete workflow documentation."
        )


