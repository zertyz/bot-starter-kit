def cmd_estimate_requirement(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    requirement = model.requirements.get(args.requirement_id)
    if requirement is None:
        print(f"unknown requirement: {args.requirement_id}", file=sys.stderr)
        return 1

    all_requirements = sorted(model.requirements.values(), key=lambda candidate: candidate.id)
    traceability_text = (MANAGEMENT_DIR / "TRACEABILITY.md").read_text(encoding="utf-8") if (MANAGEMENT_DIR / "TRACEABILITY.md").exists() else ""
    duplicate_titles = duplicate_requirement_groups(all_requirements, lambda candidate: " ".join(words_in(candidate.title)))
    duplicate_bodies = duplicate_requirement_groups(all_requirements, lambda candidate: " ".join(words_in(candidate.body)))
    findings = audit_requirement(model, requirement, traceability_text, duplicate_titles, duplicate_bodies)
    work_items = requirement_work_items(model, requirement)
    links = traceability_links_for(requirement, traceability_links())
    references = [reference for reference in requirement_references(requirement_text(requirement)) if reference != requirement.id]
    child_requirements = [
        candidate
        for candidate in all_requirements
        if candidate.id.startswith(f"{requirement.id}.") and candidate.id != requirement.id
    ]
    score = requirement_complexity_score(requirement, work_items, findings)
    effort_band = estimate_effort_band(score)
    blockers = [finding for finding in findings if finding.severity == "BLOCKER"]
    reviews = [finding for finding in findings if finding.severity == "REVIEW"]

    if blockers:
        readiness = "NOT READY"
    elif reviews:
        readiness = "NEEDS REFINEMENT"
    else:
        readiness = "READY FOR PLANNING"

    print("Requirement Estimate")
    print("====================")
    print_requirement(requirement)
    print()
    print(f"Readiness:          {readiness}")
    print(f"Estimated effort:   {effort_band} senior engineer-hours")
    print(f"Complexity score:   {score}")
    print()
    print("Existing work:")
    if work_items:
        for item in work_items:
            print(f"  - {item.id}: {item.state} -- {item.title}")
    else:
        print("  - none")
    print()
    print("Traceability:")
    if links:
        for link in links:
            print(f"  - {link.requirement_id} -> {link.work_item_id}: {link.state}; {link.evidence}")
    else:
        print("  - no direct traceability link")
    print()
    print("Dependency signals:")
    if references:
        for reference in references:
            known = "known" if reference in model.requirements else "missing"
            print(f"  - explicit reference: {reference} ({known})")
    if child_requirements:
        for child in child_requirements:
            print(f"  - child requirement: {child.id} -- {child.title}")
    if not references and not child_requirements:
        print("  - none detected")
    print()
    print("Quality signals:")
    if findings:
        for finding in findings:
            print(f"  - {finding.severity}: {finding.category}: {finding.message}")
    else:
        print("  - no local audit findings")
    print()
    print("Planning prompt:")
    print(
        f"Assess {requirement.id} for product value, market timing, dependencies, and acceptance boundaries. "
        "Use this estimate as local repo context, not as market or delivery certainty."
    )
    return 0


def cmd_sync_requirement(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    requirement = model.requirements.get(args.requirement_id)
    if requirement is None:
        print(f"unknown requirement: {args.requirement_id}", file=sys.stderr)
        return 1

    work_items = requirement_work_items(model, requirement)
    completed_items = completed_work_items(work_items)
    links = traceability_links_for(requirement, traceability_links())
    paths = sorted({path for link in links for path in evidence_paths(link)})
    path_statuses = evidence_path_statuses(paths)
    missing_paths = [path for path, status in path_statuses if status == "missing"]
    untracked_paths = [path for path, status in path_statuses if status == "exists but is not tracked"]
    exact_mentions = source_files_mentioning([requirement.id], args.limit, implementation_only=True)
    term_mentions = source_files_mentioning(requirement_source_terms(requirement), args.limit, implementation_only=True)
    signals: list[str] = []

    if not work_items:
        signals.append(issue_line("REVIEW", "no backlog work item maps to this requirement"))
    if work_items and not completed_items:
        signals.append(issue_line("REVIEW", "no merged or rolled-out work item maps to this requirement yet"))
    if not links:
        signals.append(issue_line("REVIEW", "no TRACEABILITY.md row maps to this requirement"))
    if links and not paths:
        signals.append(issue_line("REVIEW", "traceability rows do not list concrete evidence paths"))
    if missing_paths:
        signals.append(issue_line("BLOCKER", f"traceability references missing evidence paths: {', '.join(missing_paths[:4])}"))
    if untracked_paths:
        signals.append(issue_line("REVIEW", f"traceability references untracked evidence paths: {', '.join(untracked_paths[:4])}"))
    if completed_items and not exact_mentions and not paths:
        signals.append(issue_line("REVIEW", "completed work exists, but no exact requirement-id mention or evidence path was found"))
    if not signals:
        signals.append(issue_line("OK", "local traceability structure is coherent"))

    blocker_count, review_count = sync_signal_counts(signals)
    if blocker_count:
        verdict = "DRIFT RISK"
    elif review_count:
        verdict = "NEEDS REVIEW"
    else:
        verdict = "LOCALLY COHERENT"

    print("Requirement Sync")
    print("================")
    print_requirement(requirement)
    print()
    print("Mapped work:")
    if work_items:
        for item in work_items:
            print(f"  - {item.id}: {item.state} -- {item.title}")
    else:
        print("  - none")
    print()
    print("Traceability rows:")
    if links:
        for link in links:
            print(f"  - line {link.line}: {link.requirement_id} -> {link.work_item_id}: {link.state}; {link.evidence}")
    else:
        print("  - none")
    print()
    print("Evidence path status:")
    if path_statuses:
        for path, status in path_statuses:
            print(f"  - {path}: {status}")
    else:
        print("  - no concrete evidence paths listed")
    print()
    print("Source mentions:")
    if exact_mentions:
        print("  Exact requirement id:")
        for path in exact_mentions:
            print(f"    - {path}")
    else:
        print("  Exact requirement id: none")
    if term_mentions:
        print("  Requirement terms:")
        for path in term_mentions:
            print(f"    - {path}")
    else:
        print("  Requirement terms: none")
    print()
    print("Signals:")
    for signal in signals:
        print(f"  - {signal}")
    print()
    print(f"Verdict: {verdict}")
    print("Scope note: this command checks local traceability and evidence references. It does not prove runtime behavior satisfies the requirement.")

    if args.strict and (blocker_count or review_count):
        return 1
    return 0


