def print_evidence_line(title: str, evidence: list[str], status_if_missing: str, reason: str) -> None:
    if evidence:
        print(f"{title}: FOUND")
        for path in evidence:
            print(f"  - {path}")
        return
    print(f"{title}: {status_if_missing}")
    print(f"  - {reason}")


def limited(paths: list[str], limit: int = 8) -> list[str]:
    if len(paths) <= limit:
        return paths
    remaining = len(paths) - limit
    return [*paths[:limit], f"... {remaining} more"]


def parse_branch_or_work_ref(raw_ref: str) -> tuple[str | None, str]:
    branch_ref = parse_branch_ref(raw_ref)
    return branch_ref.owner, branch_ref.work_id


def parse_branch_ref(raw_ref: str) -> BranchRef:
    match = BRANCH_RE.match(raw_ref)
    if not match:
        raise ValueError(f"invalid branch or work item reference: {raw_ref}")
    return BranchRef(
        raw=raw_ref,
        work_id=match.group("work_id"),
        owner=match.group("owner"),
        is_feature=raw_ref.startswith("feature/"),
    )


def resolve_work_item(model: ManagementModel, raw_ref: str | None) -> tuple[str, WorkItem]:
    ref = raw_ref if raw_ref else current_branch()
    _owner, work_id = parse_branch_or_work_ref(ref)
    if work_id not in model.work_items:
        raise KeyError(f"{work_id} was not found in any backlog")
    return ref, model.work_items[work_id]


def validate_iso_date(raw_date: str) -> str:
    try:
        datetime.strptime(raw_date, "%Y-%m-%d")
    except ValueError as err:
        raise ValueError(f"invalid date {raw_date}; expected YYYY-MM-DD") from err
    return raw_date


def target_state_for(item: WorkItem, raw_state: str | None) -> str:
    if raw_state:
        state = strip_state(raw_state)
        if state not in VALID_STATE_SET:
            valid = ", ".join(VALID_STATES)
            raise ValueError(f"invalid target state {raw_state}; expected one of: {valid}")
        return state

    state = STATE_FLOW.get(item.state)
    if state is None:
        raise ValueError(f"{item.id} is in state {item.state}; no default next state is defined")
    return state


def state_heading(state: str) -> str:
    return STATE_HEADINGS.get(state, f"# {state}")


def backlog_sections(lines: list[str]) -> list[tuple[str, int, int]]:
    starts: list[tuple[str, int]] = []
    for index, line in enumerate(lines):
        match = STATE_HEADING_RE.match(line.rstrip("\n"))
        if match and not line.startswith("##"):
            starts.append((strip_state(match.group("state")), index))

    sections: list[tuple[str, int, int]] = []
    for index, (state, start) in enumerate(starts):
        end = starts[index + 1][1] if index + 1 < len(starts) else len(lines)
        sections.append((state, start, end))
    return sections


def find_work_block(lines: list[str], work_item_id: str) -> tuple[int, int]:
    start: int | None = None
    for index, line in enumerate(lines):
        match = WORK_ITEM_RE.match(line.rstrip("\n"))
        if match and match.group("id") == work_item_id:
            start = index
            break
    if start is None:
        raise ValueError(f"{work_item_id} was not found in its backlog file")

    end = len(lines)
    for index in range(start + 1, len(lines)):
        line = lines[index]
        if line.startswith("# ") or line.startswith("## "):
            end = index
            break
    return start, end


def timeline_entries(item: WorkItem, target_state: str, state_date: str) -> list[tuple[str, str]]:
    entries = list(item.timeline.items())
    if target_state not in item.timeline:
        entries.append((target_state, state_date))
    return entries


def timeline_line(item: WorkItem, target_state: str, state_date: str, engineer: str | None, indent: str = "") -> str:
    owner = engineer or item.owner
    prefix = f"{indent}==> "
    if owner:
        prefix += f"{owner}. "
    states = "; ".join(f"{state}: {entered_at}" for state, entered_at in timeline_entries(item, target_state, state_date))
    return f"{prefix}{states};\n"


def update_work_block_timeline(block: list[str], item: WorkItem, target_state: str, state_date: str, engineer: str | None) -> list[str]:
    updated = list(block)
    timeline_index: int | None = None
    indent = ""

    for index, line in enumerate(updated):
        marker_match = TIMELINE_MARKER_RE.search(line)
        if marker_match:
            timeline_index = index
            indent = line[: marker_match.start()]

    if timeline_index is None:
        insert_index = len(updated)
        while insert_index > 0 and not updated[insert_index - 1].strip():
            insert_index -= 1
        updated.insert(insert_index, timeline_line(item, target_state, state_date, engineer))
        return updated

    updated[timeline_index] = timeline_line(item, target_state, state_date, engineer, indent)
    return updated


def ensure_state_section(lines: list[str], state: str) -> list[str]:
    if any(section_state == state for section_state, _start, _end in backlog_sections(lines)):
        return lines

    heading = f"{state_heading(state)}\n"
    state_order = {value: index for index, value in enumerate(VALID_STATES)}
    target_order = state_order[state]

    insert_index = len(lines)
    for section_state, start, _end in backlog_sections(lines):
        if state_order.get(section_state, 999) > target_order:
            insert_index = start
            break

    section_lines = [heading, "\n"]
    if insert_index == len(lines):
        while lines and not lines[-1].strip():
            lines.pop()
        if lines:
            lines.extend(["\n", "\n", *section_lines])
        else:
            lines.extend(section_lines)
        return lines

    if insert_index > 0 and lines[insert_index - 1].strip():
        section_lines.insert(0, "\n")
    lines[insert_index:insert_index] = section_lines
    return lines


def insertion_index_for_state(lines: list[str], state: str) -> int:
    for section_state, start, end in backlog_sections(lines):
        if section_state != state:
            continue
        insert_index = end
        while insert_index > start + 1 and not lines[insert_index - 1].strip():
            insert_index -= 1
        return insert_index
    raise ValueError(f"missing state section {state}")


def normalize_moved_block(block: list[str]) -> list[str]:
    start = 0
    end = len(block)
    while start < end and not block[start].strip():
        start += 1
    while end > start and not block[end - 1].strip():
        end -= 1
    normalized = block[start:end]
    if normalized and not normalized[-1].endswith("\n"):
        normalized[-1] += "\n"
    return normalized


def replace_or_move_work_item(item: WorkItem, target_state: str, state_date: str, engineer: str | None) -> None:
    lines = item.path.read_text(encoding="utf-8").splitlines(keepends=True)
    start, end = find_work_block(lines, item.id)
    block = update_work_block_timeline(lines[start:end], item, target_state, state_date, engineer)

    if target_state == item.state:
        lines[start:end] = block
        item.path.write_text("".join(lines), encoding="utf-8")
        return

    del lines[start:end]
    lines = ensure_state_section(lines, target_state)
    insert_index = insertion_index_for_state(lines, target_state)
    normalized_block = normalize_moved_block(block)
    insertion = ["\n", *normalized_block, "\n"]
    lines[insert_index:insert_index] = insertion
    item.path.write_text("".join(lines), encoding="utf-8")


def print_requirement(requirement: Requirement) -> None:
    print(f"Requirement: {requirement.id} -- {requirement.title}")
    print(f"Source:      {relative(requirement.path)}:{requirement.line}")
    print(f"Section:     {requirement.section_title} \"{requirement.section}\"")
    if requirement.body:
        print()
        print(requirement.body)


def print_work_item(model: ManagementModel, item: WorkItem) -> None:
    print(f"Work Item:   {item.id} -- {item.title}")
    print(f"State:       {item.state}")
    print(f"Source:      {relative(item.path)}:{item.line}")
    print(f"Requirement: {item.requirement_id}")
    if item.owner:
        print(f"Owner:       {item.owner}")
    if item.timeline:
        timeline = "; ".join(f"{state}: {date}" for state, date in item.timeline.items())
        print(f"Timeline:    {timeline}")
    if item.body:
