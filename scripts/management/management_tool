def traceability_evidence_text(paths: list[str], note: str | None) -> str:
    pieces = [f"`{path}`" for path in paths]
    if note:
        pieces.append(note)
    return "; ".join(pieces)


def append_or_update_traceability(requirement_id_value: str, work_item: WorkItem, paths: list[str], note: str | None, state: str | None) -> str:
    path = MANAGEMENT_DIR / "TRACEABILITY.md"
    with management_write_lock():
        text = path.read_text(encoding="utf-8")
        lines = text.splitlines()
        new_evidence = traceability_evidence_text(paths, note)
        row_state = state or work_item.state
        row = f"| `{requirement_id_value}` | `{work_item.id}` | {row_state} | {new_evidence} |"

        heading_indexes = [
            index
            for index, line in enumerate(lines)
            if line.strip() == TRACEABILITY_CURRENT_LINKS_HEADING
        ]
        if not heading_indexes:
            if any(line.strip().startswith("|") for line in lines):
                raise ValueError(
                    "cannot safely create Current Links while traceability table content exists outside that section"
                )
            while lines and not lines[-1].strip():
                lines.pop()
            lines.extend(
                [
                    "",
                    TRACEABILITY_CURRENT_LINKS_HEADING,
                    "",
                    TRACEABILITY_TABLE_HEADER,
                    TRACEABILITY_TABLE_SEPARATOR,
                    row,
                ]
            )
            atomic_write_text(path, "\n".join(lines).rstrip() + "\n")
            return "appended"
        if len(heading_indexes) != 1:
            raise ValueError("cannot safely update traceability with multiple `## Current Links` sections")

        section = traceability_current_links_section_bounds(lines)
        if section is None:
            raise ValueError("cannot locate the unique `## Current Links` section")
        heading_index, section_end = section
        table = traceability_current_links_table_bounds(lines)
        if table is None:
            nonblank_section_lines = [
                lines[index].strip()
                for index in range(heading_index + 1, section_end)
                if lines[index].strip()
            ]
            repairable = not nonblank_section_lines or all(
                line.startswith("| Requirement") or set(line) <= {"|", " ", "-", ":"}
                for line in nonblank_section_lines
            )
            if not repairable:
                raise ValueError(
                    "cannot safely repair the canonical Current Links table while rows or prose are present"
                )
            lines[heading_index + 1 : section_end] = [
                "",
                TRACEABILITY_TABLE_HEADER,
                TRACEABILITY_TABLE_SEPARATOR,
                row,
                "",
            ]
            atomic_write_text(path, "\n".join(lines).rstrip() + "\n")
            return "appended"

        _, _, separator_index, section_end = table
        current_link_indexes: list[int] = []
        for index in range(separator_index + 1, section_end):
            stripped = lines[index].strip()
            if not stripped:
                continue
            columns = traceability_table_cells(lines[index])
            if (
                columns is None
                or len(columns) != 4
                or re.fullmatch(r"`[^`]+`", columns[0]) is None
                or re.fullmatch(r"`[^`]+`", columns[1]) is None
            ):
                raise ValueError("cannot safely update a malformed Current Links table")
            current_link_indexes.append(index)

        for index in current_link_indexes:
            columns = traceability_table_cells(lines[index])
            if columns is None:
                raise ValueError("cannot safely update a malformed Current Links table")
            if columns[0].strip("`") == requirement_id_value and columns[1].strip("`") == work_item.id:
                existing_evidence = columns[3]
                evidence = existing_evidence
                if new_evidence and new_evidence not in existing_evidence:
                    evidence = f"{existing_evidence}; {new_evidence}" if existing_evidence else new_evidence
                lines[index] = f"| `{requirement_id_value}` | `{work_item.id}` | {row_state} | {evidence} |"
                atomic_write_text(path, "\n".join(lines).rstrip() + "\n")
                return "updated"

        insert_index = current_link_indexes[-1] + 1 if current_link_indexes else separator_index + 1
        lines.insert(insert_index, row)
        atomic_write_text(path, "\n".join(lines).rstrip() + "\n")
        return "appended"


def validate_evidence_paths(paths: list[str], allow_missing: bool) -> tuple[list[str], list[str]]:
    canonical_paths = [canonical_repo_path(path) for path in paths]
    missing = [path for path in canonical_paths if not (REPO_ROOT / path).exists()]
    if missing and not allow_missing:
        raise ValueError(f"evidence paths do not exist: {', '.join(missing)}")
    return canonical_paths, missing


def issue_line(severity: str, message: str) -> str:
    return f"{severity}: {message}"


def branch_reference_is_plain_work_item(branch_ref: BranchRef) -> bool:
    return branch_ref.raw == branch_ref.work_id


def run_git(args: list[str], dry_run: bool) -> None:
    print(f"$ git {' '.join(args)}")
    if not dry_run:
        git_output(args)


def remote_branch_ref(branch: str) -> str:
    return f"origin/{branch}"


def remote_branch_exists(branch: str) -> bool:
    return git_ref_exists(f"refs/remotes/{remote_branch_ref(branch)}")


def ensure_ref_exists(ref: str) -> None:
    if not git_ref_exists(ref):
        raise RuntimeError(f"git ref {ref} does not exist; pass --base or update local refs first")


def create_or_switch_branch(branch: str, base_ref: str, dry_run: bool, assume_base_ref_exists: bool = False) -> None:
    if git_branch_exists(branch):
        run_git(["switch", branch], dry_run)
        return
    if remote_branch_exists(branch):
        run_git(["switch", "-c", branch, remote_branch_ref(branch)], dry_run)
        return
    if not assume_base_ref_exists:
        ensure_ref_exists(base_ref)
    run_git(["switch", "-c", branch, base_ref], dry_run)


def ensure_feature_branch(feature_branch: str, base_ref: str, dry_run: bool) -> None:
    if git_branch_exists(feature_branch):
        return
    if remote_branch_exists(feature_branch):
        run_git(["switch", "-c", feature_branch, remote_branch_ref(feature_branch)], dry_run)
        return
    ensure_ref_exists(base_ref)
    run_git(["switch", "-c", feature_branch, base_ref], dry_run)


def cmd_lint(args: argparse.Namespace) -> int:
    model = load_model()

    print("Checking management requirements and backlogs")
    print(f"Requirements: {len(model.requirements)}")
    print(f"Work items:   {len(model.work_items)}")
    sys.stdout.flush()

    for issue in model.errors:
        print(issue.format(), file=sys.stderr)
    for issue in model.warnings:
        print(issue.format(), file=sys.stderr)

    if model.errors:
        return 1
    if args.strict and model.warnings:
        return 1
    return 0


