def cmd_block_work(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1
    try:
        raw_ref, item = resolve_work_item(model, args.ref)
        event_date = validate_iso_date(args.date or date.today().isoformat())
        reason = args.reason.strip()
        if not reason or any(character in reason for character in "\r\n"):
            raise ValueError("--reason must be one non-empty line")
        action = "Blocked" if args.block_action == "block" else "Unblocked"
        if action == "Blocked" and item.blocked:
            raise ValueError(f"{item.id} is already blocked")
        if action == "Unblocked" and not item.blocked:
            raise ValueError(f"{item.id} is not blocked")
        historical_dates = [*item.timeline.values(), *(event.entered_at for event in item.block_events)]
        if historical_dates and event_date < max(historical_dates):
            raise ValueError(f"block event date {event_date} predates existing history through {max(historical_dates)}")
        require_main_for_mutation(args.dry_run)
    except (KeyError, RuntimeError, ValueError) as err:
        print(f"error: {err}", file=sys.stderr)
        return 1

    print(f"{action} Work")
    print("============" if action == "Blocked" else "==============")
    if raw_ref != item.id:
        print(f"Reference:   {raw_ref}")
    print_work_item(model, item)
    print()
    if args.dry_run:
        print(f"Dry run: would append {action}: {event_date}; Reason: {reason}")
        return 0

    append_block_event(item, action, event_date, reason)
    updated_item = load_model().work_items[item.id]
    print(f"Appended {action}: {event_date}; Reason: {reason}")
    print(f"Blocked now: {'yes' if updated_item.blocked else 'no'}")
    return 0


