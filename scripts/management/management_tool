def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    try:
        with management_write_lock():
            return args.func(args)
    except (OSError, RuntimeError, ValueError) as err:
        print(f"error: {err}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
