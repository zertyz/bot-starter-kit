def cmd_audit_requirements(args: argparse.Namespace) -> int:
    model = load_model()
    if model.errors:
        for issue in model.errors:
            print(issue.format(), file=sys.stderr)
        return 1

    requirements = sorted(model.requirements.values(), key=lambda requirement: requirement.id)
    if args.document:
        requirements = [requirement for requirement in requirements if requirement.document == args.document]

    traceability_path = MANAGEMENT_DIR / "TRACEABILITY.md"
    traceability = traceability_path.read_text(encoding="utf-8") if traceability_path.exists() else ""
    duplicate_titles = duplicate_requirement_groups(requirements, lambda requirement: " ".join(words_in(requirement.title)))
    duplicate_bodies = duplicate_requirement_groups(requirements, lambda requirement: " ".join(words_in(requirement.body)))

    findings: list[AuditFinding] = []
    for requirement in requirements:
        findings.extend(audit_requirement(model, requirement, traceability, duplicate_titles, duplicate_bodies))

    severity_order = {severity: index for index, severity in enumerate(AUDIT_SEVERITIES)}
    findings.sort(key=lambda finding: (severity_order.get(finding.severity, 99), finding.requirement.id, finding.category))
    counts = {severity: sum(1 for finding in findings if finding.severity == severity) for severity in AUDIT_SEVERITIES}

    print("Requirement Audit")
    print("=================")
    if args.document:
        print(f"Document:             {args.document} -- {REQUIREMENT_FILES[args.document]}")
    print(f"Requirements checked: {len(requirements)}")
    print(f"Work items:           {len(model.work_items)}")
    print(f"Traceability source:  {relative(traceability_path)}")
    print()
    print("Summary:")
    for severity in AUDIT_SEVERITIES:
        print(f"  {severity}: {counts[severity]}")
    print()
    print("Findings:")
    if not findings:
        print("  - none")
    else:
        printable = findings if args.limit <= 0 else findings[: args.limit]
        for finding in printable:
            print(f"  - {finding.format()}")
        if args.limit > 0 and len(findings) > args.limit:
            print(f"  - ... {len(findings) - args.limit} more")
    print()
    print("Scope note: this is a local heuristic audit over management files. Market fit, competitor analysis, code-semantic drift, and final requirement wording remain human PM/manager decisions.")

    if args.strict and (counts["BLOCKER"] or counts["REVIEW"]):
        return 1
    return 0


