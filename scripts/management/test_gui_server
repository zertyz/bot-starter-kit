    def test_export_keeps_old_entrypoint_when_dependency_publication_fails(self) -> None:
        with tempfile.TemporaryDirectory() as directory:
            output_dir = Path(directory) / "management"
            index = output_dir / "index.html"
            self.gui.export_management_report(output_dir, stale_days=0)
            old_index = index.read_text(encoding="utf-8")
            old_references = generation_references(old_index)
            old_contents = {reference: (output_dir / reference).read_bytes() for reference in old_references}
            old_generation_ids = {Path(reference).parts[1] for reference in old_references}
            original_replace = self.gui.os.replace
            original_payload = self.gui.static_report_payload

            def changed_payload(*args, **kwargs):
                payload = original_payload(*args, **kwargs)
                payload["generated_at"] = "2099-01-01T00:00:00Z"
                return payload

            def fail_on_new_generation(source, destination):
                destination = Path(destination)
                if destination.parent == output_dir / "generations" and destination.name not in old_generation_ids:
                    raise OSError("injected generation publication failure")
                return original_replace(source, destination)

            with mock.patch.object(self.gui, "static_report_payload", side_effect=changed_payload):
                with mock.patch.object(self.gui.os, "replace", side_effect=fail_on_new_generation):
                    with self.assertRaisesRegex(OSError, "injected generation publication failure"):
                        self.gui.export_management_report(output_dir, stale_days=0)

            self.assertEqual(old_index, index.read_text(encoding="utf-8"))
            for reference, contents in old_contents.items():
                self.assertEqual(contents, (output_dir / reference).read_bytes())
            self.assertEqual([], list(Path(directory).glob(".management-report-stage-*")))

    def test_export_atomically_switches_between_complete_generations(self) -> None:
        with tempfile.TemporaryDirectory() as directory:
            output_dir = Path(directory) / "management"
            index_path = self.gui.export_management_report(output_dir, stale_days=0)
            old_index = index_path.read_text(encoding="utf-8")
            old_references = generation_references(old_index)
            old_contents = {reference: (output_dir / reference).read_bytes() for reference in old_references}
            original_replace = self.gui.os.replace
            original_payload = self.gui.static_report_payload
            observed_switch = []

            def changed_payload(*args, **kwargs):
                payload = original_payload(*args, **kwargs)
                payload["generated_at"] = "2099-01-02T00:00:00Z"
                return payload

            def observe_index_switch(source, destination):
                if Path(destination) == index_path:
                    self.assertEqual(old_index, index_path.read_text(encoding="utf-8"))
                    for reference, contents in old_contents.items():
                        self.assertEqual(contents, (output_dir / reference).read_bytes())
                    new_references = generation_references(Path(source).read_text(encoding="utf-8"))
                    self.assertTrue(new_references)
                    self.assertNotEqual(
                        {Path(reference).parts[1] for reference in old_references},
                        {Path(reference).parts[1] for reference in new_references},
                    )
                    for reference in new_references:
                        self.assertTrue((output_dir / reference).is_file(), reference)
                    observed_switch.append(True)
                return original_replace(source, destination)

            with mock.patch.object(self.gui, "static_report_payload", side_effect=changed_payload):
                with mock.patch.object(self.gui.os, "replace", side_effect=observe_index_switch):
                    self.gui.export_management_report(output_dir, stale_days=0)

            self.assertEqual([True], observed_switch)
            self.assertNotEqual(old_index, index_path.read_text(encoding="utf-8"))
            for reference, contents in old_contents.items():
                self.assertEqual(contents, (output_dir / reference).read_bytes())
            self.assertEqual([], list(Path(directory).glob(".management-report-stage-*")))

