    def test_mutating_actions_are_serialized(self) -> None:
        counter_lock = threading.Lock()
        mutation_lock = threading.Lock()
        start = threading.Barrier(4)
        active = 0
        maximum_active = 0
        results = []

        def fake_run(_args):
            nonlocal active, maximum_active
            with counter_lock:
                active += 1
                maximum_active = max(maximum_active, active)
            time.sleep(0.04)
            with counter_lock:
                active -= 1
            return {"command": "record-risk", "returncode": 0, "stdout": "", "stderr": ""}

        request = {
            "action": "record-risk",
            "payload": {
                "title": "Title",
                "owner": "Owner",
                "risk": "Risk",
                "impact": "Impact",
                "mitigation": "Mitigation",
            },
        }

        def worker():
            start.wait()
            results.append(self.gui.execute_action(request, mutation_lock))

        with mock.patch.object(self.gui, "run_management_command", side_effect=fake_run):
            threads = [threading.Thread(target=worker) for _ in range(4)]
            for thread in threads:
                thread.start()
            for thread in threads:
                thread.join(timeout=5)

        self.assertTrue(all(not thread.is_alive() for thread in threads))
        self.assertEqual(4, len(results))
        self.assertEqual(1, maximum_active)

    def test_diagram_cache_generates_once_and_force_refreshes(self) -> None:
        with tempfile.TemporaryDirectory() as directory:
            diagram_dir = Path(directory) / "diagrams"
            counter_lock = threading.Lock()
            calls = 0

            def fake_generate(output_dir, _loaded_model=None):
                nonlocal calls
                with counter_lock:
                    calls += 1
                time.sleep(0.04)
                output_dir.mkdir(parents=True, exist_ok=True)
                for filename in self.gui.DIAGRAM_FILENAMES:
                    (output_dir / filename).write_text(filename, encoding="utf-8")

            with mock.patch.object(self.gui, "DIAGRAM_DIR", diagram_dir), mock.patch.object(
                self.gui, "generate_diagrams", side_effect=fake_generate
            ):
                self.gui.DIAGRAM_CACHE_READY = False
                start = threading.Barrier(4)

                def worker():
                    start.wait()
                    self.gui.ensure_diagrams()

                threads = [threading.Thread(target=worker) for _ in range(4)]
                for thread in threads:
                    thread.start()
                for thread in threads:
                    thread.join(timeout=5)

                self.assertTrue(all(not thread.is_alive() for thread in threads))
                self.assertEqual(1, calls)
                self.assertTrue(all((diagram_dir / name).is_file() for name in self.gui.DIAGRAM_FILENAMES))
                self.gui.ensure_diagrams(force=True)
                self.assertEqual(2, calls)
