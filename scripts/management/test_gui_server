GENERATION_REFERENCE_RE = re.compile(r'"\./(generations/sha256-[0-9a-f]{64}/[^"<>]+)"')


def generation_references(index_html: str) -> set[str]:
    return set(GENERATION_REFERENCE_RE.findall(index_html))


def load_gui_server():
    loader = importlib.machinery.SourceFileLoader("management_gui_server_test", str(SOURCE_GUI))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    if spec is None:
        raise RuntimeError("cannot load gui_server")
    module = importlib.util.module_from_spec(spec)
    sys.modules[loader.name] = module
    loader.exec_module(module)
    return module


@contextmanager
def running_server(gui):
    try:
        server = gui.bind_server("127.0.0.1", 0, 1, True, capability_token="test-capability")
    except PermissionError as err:
        raise unittest.SkipTest(f"localhost sockets are unavailable: {err}") from err
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()
    try:
        yield server
    finally:
        server.shutdown()
        server.server_close()
        thread.join(timeout=5)


def http_request(server, method: str, path: str, body: bytes = b"", headers: dict[str, str] | None = None):
    connection = http.client.HTTPConnection("127.0.0.1", server.server_port, timeout=5)
    connection.request(method, path, body=body, headers=headers or {})
    response = connection.getresponse()
    response_body = response.read()
    response_headers = dict(response.getheaders())
    connection.close()
    return response.status, response_headers, response_body


def action_headers(server) -> dict[str, str]:
    authority = f"127.0.0.1:{server.server_port}"
    return {
        "Host": authority,
        "Origin": f"http://{authority}",
        "Content-Type": "application/json",
        "X-Management-Capability": "test-capability",
    }


def headless_browser() -> str | None:
    return next(
        (
            executable
            for name in ("google-chrome-stable", "google-chrome", "chromium", "chromium-browser")
            if (executable := shutil.which(name)) is not None
        ),
        None,
    )


def browser_dom(browser: str, url: str, directory: Path) -> tuple[int, str, str]:
    profile = directory / "browser-profile"
    profile.mkdir()
    dom_path = directory / "browser-dom.html"
    stderr_path = directory / "browser-stderr.log"
    command = [
        browser,
        "--headless=new",
        "--disable-background-networking",
        "--disable-breakpad",
        "--disable-crash-reporter",
        "--disable-dev-shm-usage",
        "--disable-gpu",
        "--no-default-browser-check",
        "--no-first-run",
        "--no-sandbox",
        f"--user-data-dir={profile}",
        "--virtual-time-budget=3000",
        "--allow-file-access-from-files",
        "--dump-dom",
        url,
    ]
    environment = dict(os.environ)
    environment.update(
        {
            "HOME": str(profile),
            "XDG_CACHE_HOME": str(profile / "cache"),
            "XDG_CONFIG_HOME": str(profile / "config"),
        }
    )
    with dom_path.open("wb") as dom_file, stderr_path.open("wb") as stderr_file:
        process = subprocess.Popen(
            command,
            cwd=SOURCE_GUI.parents[2],
            env=environment,
            stdout=dom_file,
            stderr=stderr_file,
            start_new_session=True,
        )
        try:
            return_code = process.wait(timeout=60)
        except subprocess.TimeoutExpired:
            os.killpg(process.pid, signal.SIGKILL)
            process.wait(timeout=5)
            raise AssertionError("headless browser did not finish within 30 seconds")
        finally:
            # Chrome may leave crash/reporting helpers in its isolated process
            # group after the headless parent has returned its DOM.
            try:
                os.killpg(process.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
    return (
        return_code,
        dom_path.read_text(encoding="utf-8", errors="replace"),
        stderr_path.read_text(encoding="utf-8", errors="replace"),
    )


