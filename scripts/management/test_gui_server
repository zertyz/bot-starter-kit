    def test_http_action_requires_host_origin_json_token_and_size_limit(self) -> None:
        request_body = json.dumps({"action": "lint", "payload": {}}).encode("utf-8")
        result = {"command": "lint", "returncode": 0, "stdout": "", "stderr": ""}
        with mock.patch.object(self.gui, "execute_action", return_value=result) as execute:
            with running_server(self.gui) as server:
                headers = action_headers(server)
                status, _, body = http_request(server, "POST", "/api/action", request_body, headers)
                self.assertEqual(200, status)
                self.assertEqual(0, json.loads(body)["returncode"])

                adversarial_cases = []
                missing_token = dict(headers)
                missing_token.pop("X-Management-Capability")
                adversarial_cases.append((missing_token, request_body, 403, "invalid capability token"))
                missing_origin = dict(headers)
                missing_origin.pop("Origin")
                adversarial_cases.append((missing_origin, request_body, 403, "invalid Origin header"))
                bad_origin = dict(headers)
                bad_origin["Origin"] = "http://attacker.invalid"
                adversarial_cases.append((bad_origin, request_body, 403, "invalid Origin header"))
                bad_host = dict(headers)
                bad_host["Host"] = "attacker.invalid"
                adversarial_cases.append((bad_host, request_body, 403, "invalid Host header"))
                bad_type = dict(headers)
                bad_type["Content-Type"] = "text/plain"
                adversarial_cases.append((bad_type, request_body, 415, "Content-Type must be application/json"))
                adversarial_cases.append((headers, b"{", 400, "invalid JSON request"))
                adversarial_cases.append(
                    (headers, b"x" * (self.gui.MAX_ACTION_BODY_BYTES + 1), 413, "request body is too large")
                )

                for case_headers, case_body, expected_status, expected_error in adversarial_cases:
                    with self.subTest(expected_error=expected_error):
                        status, _, body = http_request(server, "POST", "/api/action", case_body, case_headers)
                        self.assertEqual(expected_status, status)
                        self.assertEqual(expected_error, json.loads(body)["error"])

                status, _, body = http_request(server, "OPTIONS", "/api/action", headers={"Host": headers["Host"]})
                self.assertEqual(405, status)
                self.assertEqual("method not allowed", json.loads(body)["error"])

        self.assertEqual(1, execute.call_count)

