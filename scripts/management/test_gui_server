#!/usr/bin/env python3
"""Tests for scripts/management/gui_server."""

from __future__ import annotations

import importlib.machinery
import importlib.util
import json
import sys
import tempfile
import unittest
from pathlib import Path


SOURCE_GUI = Path(__file__).resolve().parent / "gui_server"


def load_gui_server():
    loader = importlib.machinery.SourceFileLoader("management_gui_server_test", str(SOURCE_GUI))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    if spec is None:
        raise RuntimeError("cannot load gui_server")
    module = importlib.util.module_from_spec(spec)
    sys.modules[loader.name] = module
    loader.exec_module(module)
    return module


class ManagementGuiServerTest(unittest.TestCase):
    @classmethod
    def setUpClass(cls) -> None:
        cls.gui = load_gui_server()

    def test_model_payload_contains_management_sections(self) -> None:
        payload = self.gui.model_payload()
        self.assertGreater(payload["counts"]["requirements"], 0)
        self.assertIn("requirements", payload)
        self.assertIn("work_items", payload)
        self.assertIn("ledgers", payload)
        self.assertIn("diagrams", payload)
        self.assertIn("audit_findings", payload)
        self.assertIn("tech_debts", payload)
        self.assertIn("audit_blockers", payload["counts"])
        self.assertIn("tech_debt_findings", payload["counts"])

    def test_requirement_payload_contains_proactive_audit_context(self) -> None:
        payload = self.gui.model_payload()
        requirement = payload["requirements"][0]
        self.assertIn("audit_findings", requirement)
        self.assertIn("traceability_status", requirement)
        self.assertIn("edit_hint", requirement)

    def test_work_payload_contains_attention_context(self) -> None:
        payload = self.gui.model_payload()
        item = payload["work_items"][0]
        self.assertIn("attention", item)
        for signal in item["attention"]:
            self.assertIn("severity", signal)
            self.assertIn("message", signal)

    def test_builds_allowlisted_requirement_command(self) -> None:
        args = self.gui.build_management_command("show-requirement", {"requirement_id": "E.MCP.01"})
        self.assertEqual(["show-requirement", "E.MCP.01"], args)

    def test_release_tag_execution_requires_version_confirmation(self) -> None:
        with self.assertRaises(self.gui.ClientError):
            self.gui.build_management_command("create-release-tag", {"version": "1.2.3", "execute": True})
        args = self.gui.build_management_command(
            "create-release-tag",
            {"version": "1.2.3", "execute": True, "confirm": "1.2.3"},
        )
        self.assertIn("--execute", args)

    def test_execute_read_only_status_action(self) -> None:
        result = self.gui.execute_action({"action": "management-status", "payload": {"stale_days": "14"}})
        self.assertEqual(0, result["returncode"])
        self.assertIn("Management Status", result["stdout"])

    def test_export_management_report_writes_static_gui(self) -> None:
        with tempfile.TemporaryDirectory() as directory:
            output_dir = Path(directory) / "management"
            target = self.gui.export_management_report(output_dir, stale_days=0)
            self.assertEqual(output_dir / "index.html", target)
            index = target.read_text(encoding="utf-8")
            model = json.loads((output_dir / "model.json").read_text(encoding="utf-8"))

            self.assertIn("Management Report", index)
            self.assertIn("MANAGEMENT_STATIC_MODE", index)
            self.assertIn('id="management-model"', index)
            self.assertIn('src="./assets/app.js"', index)
            self.assertEqual("static", model["surface"]["mode"])
            self.assertFalse(model["surface"]["actions_enabled"])
            self.assertEqual("./diagrams/architecture-real.svg", model["diagrams"]["architecture_real"])
            self.assertTrue((output_dir / "assets" / "app.css").is_file())
            self.assertTrue((output_dir / "assets" / "app.js").is_file())
            self.assertTrue((output_dir / "diagrams" / "architecture-real.svg").is_file())
            self.assertTrue((output_dir / "diagrams" / "architecture-planned.svg").is_file())
            self.assertTrue((output_dir / "diagrams" / "module-dependencies.svg").is_file())


if __name__ == "__main__":
    unittest.main(verbosity=2)
