    def test_semantic_context_json_schema_and_workflows(self) -> None:
        (self.management / "BUSINESS.md").write_text(
            textwrap.dedent(
                """\
                # Business "Biz"

                ## 01) Per User Routing

                One stream per user.

                ### 01.a) Child routing obligation

                Child behavior.
                """
            ),
            encoding="utf-8",
        )
        workflows = {
            "audit": ["B.Biz.01"],
            "tech-debt": [],
            "estimate": ["B.Biz.01"],
            "sync": ["B.Biz.01"],
            "plan": ["EN.MCP.01-001"],
            "review": ["Luiz/EN.MCP.01-001"],
            "verification": ["Luiz/EN.MCP.01-001"],
        }
        for workflow, reference in workflows.items():
            with self.subTest(workflow=workflow):
                result = self.tool_run("semantic-context", workflow, *reference, "--limit", "5")
                payload = json.loads(result.stdout)
                self.assertEqual(payload["schema_version"], "1.0")
                self.assertEqual(payload["workflow"], workflow)
                self.assertIn("signal_policy", payload)
                self.assertIn("observations", payload)
                self.assertNotIn("verdict", payload)
                if workflow == "audit":
                    self.assertEqual(
                        [item["id"] for item in payload["observations"]["requirements"]],
                        ["B.Biz.01", "B.Biz.01.a"],
                    )
                    self.assertTrue(
                        any(
                            finding["category"] == "redundancy"
                            and "title matches another requirement: E.MCP.01" in finding["message"]
                            for finding in payload["observations"]["quality_findings"]
                        )
                    )
                    self.assertIn("semantic_prompts", payload["observations"])
                    self.assertIn("acknowledged_semantic_prompts", payload["observations"])
                    self.assertIn("work_coverage", payload["observations"])
                    self.assertIn("evidence_coverage", payload["observations"])
                    self.assertFalse(any("title matches another requirement" in signal for signal in payload["candidate_signals"]))
                if workflow in {"estimate", "sync"}:
                    self.assertEqual(payload["focus"]["requirement"]["id"], "B.Biz.01")
                    self.assertEqual(
                        [item["id"] for item in payload["focus"]["descendant_requirements"]],
                        ["B.Biz.01.a"],
                    )

        leaf_audit = json.loads(self.tool_run("semantic-context", "audit", "B.Biz.01.a").stdout)
        self.assertEqual(
            [item["id"] for item in leaf_audit["observations"]["requirements"]],
            ["B.Biz.01.a"],
        )
        leaf_estimate = json.loads(self.tool_run("semantic-context", "estimate", "B.Biz.01.a").stdout)
        self.assertEqual(leaf_estimate["focus"]["requirement"]["id"], "B.Biz.01.a")
        self.assertEqual(leaf_estimate["focus"]["descendant_requirements"], [])

        tech_debt = json.loads(self.tool_run("semantic-context", "tech-debt", "management", "--limit", "5").stdout)
        self.assertEqual(tech_debt["observations"]["path_prefix"], "management")
        ignored = self.tool_run("semantic-context", "tech-debt", "missing-prefix", expected=1)
        self.assertIn("does not exist", json.loads(ignored.stdout)["error"])

