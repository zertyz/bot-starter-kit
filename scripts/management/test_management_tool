    def test_work_and_evidence_coverage_are_structured_and_lifecycle_aware(self) -> None:
        module = self.load_tool_module()
        model = module.load_model()
        parent = module.Requirement(
            id="E.MCP.02",
            document="E",
            section="MCP",
            section_title="Messaging Communications Paradigm",
            number="02",
            subtopics="",
            title="Messaging capabilities",
            path=self.management / "ENGINEERING.md",
            line=7,
            body_lines=["The system exposes messaging capabilities."],
        )
        completed = module.WorkItem(
            id="EN.MCP.02-001",
            requirement_id=parent.id,
            document="E",
            motivation="N",
            section="MCP",
            number="02",
            subtopics="",
            sequence="001",
            title="Implement messaging capabilities",
            state="Merged",
            path=self.management / "ENGINEERING.backlog.md",
            line=1,
        )
        model.requirements[parent.id] = parent
        model.work_items[completed.id] = completed

        work = module.requirement_work_coverage(model, parent)
        self.assertEqual("active", work["status"])
        self.assertEqual(2, work["count"])
        self.assertEqual(1, work["direct_count"])
        self.assertEqual(1, work["descendant_count"])
        self.assertEqual({"Merged": 1, "Planned": 1}, work["by_state"])
        self.assertEqual({"N": 1, "R": 1}, work["by_motivation"])
        self.assertEqual({"direct", "descendant"}, {item["relation"] for item in work["items"]})

        missing_row = module.requirement_evidence_coverage(model, parent, [])
        self.assertEqual("gap", missing_row["status"])
        self.assertEqual([completed.id], missing_row["missing_traceability_work_item_ids"])

        note_only = module.TraceabilityLink(parent.id, completed.id, "Merged", "Review completed", 8)
        missing_evidence = module.requirement_evidence_coverage(model, parent, [note_only])
        self.assertEqual("gap", missing_evidence["status"])
        self.assertEqual([completed.id], missing_evidence["missing_evidence_work_item_ids"])

        source = self.root / "src" / "evidence.rs"
        source.parent.mkdir()
        source.write_text("pub fn evidence() {}\n", encoding="utf-8")
