    def test_review_prints_packet_and_checklist(self) -> None:
        review = self.tool_run("review", "Luiz/EN.MCP.01-001")
        self.assertIn("Review Packet", review.stdout)
        self.assertIn("Review checklist:", review.stdout)
        self.assertIn("AI review prompt:", review.stdout)


if __name__ == "__main__":
