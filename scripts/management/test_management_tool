        release = self.tool_run("prepare-release", "1.2.3-rc.1")
        self.assertIn("Release Packet", release.stdout)
        self.assertIn("release candidate", release.stdout)
        tag = self.tool_run("create-release-tag", "1.2.3-rc.1")
