    def test_backlog_writers_reject_structural_injection_without_changes(self) -> None:
        backlog = self.management / "ENGINEERING.backlog.md"
        original = backlog.read_bytes()
        title = self.tool_run(
            "draft-plan",
            "E.MCP.02.b",
            "--title",
            "Unsafe\n## EN.MCP.02.b-999 -- Injected",
            "--write",
            expected=1,
        )
        self.assertIn("--title must be a single line", title.stderr)
        self.assertEqual(backlog.read_bytes(), original)
        body_heading = self.tool_run(
            "draft-plan",
            "E.MCP.02.b",
            "--body-line",
            "## EN.MCP.02.b-999 -- Injected",
            "--write",
            expected=1,
        )
        self.assertIn("--body-line cannot contain backlog structural syntax", body_heading.stderr)
        self.assertEqual(backlog.read_bytes(), original)
        body_timeline = self.tool_run(
            "draft-plan",
            "E.MCP.02.b",
            "--body-line",
            "==> Merged: 2026-07-08;",
            "--write",
            expected=1,
        )
        self.assertIn("--body-line cannot contain backlog structural syntax", body_timeline.stderr)
        self.assertEqual(backlog.read_bytes(), original)
        engineer = self.tool_run(
            "advance-state",
            "ER.MCP.02.a-001",
            "--to",
            "Started",
            "--date",
            "2026-07-06",
            "--engineer",
            "Unsafe\n## EN.MCP.02.a-999 -- Injected",
            expected=1,
        )
        self.assertIn("--engineer must be a single line", engineer.stderr)
        self.assertEqual(backlog.read_bytes(), original)

