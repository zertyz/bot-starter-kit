    def test_semantic_prompts_acknowledge_single_emphasis_for_the_whole_requirement(self) -> None:
        (self.management / "BUSINESS.md").write_text(
            textwrap.dedent(
                """\
                # Business "Biz"

                ## 01) Feature Scope

                The system must support *all* platform features and all documented extensions.
                It may accept *any* supported payload and use **appropriate** defaults.
                """
            ),
            encoding="utf-8",
        )
        module = self.load_tool_module()
        requirement = module.load_model().requirements["B.Biz.01"]
        prompts = module.requirement_semantic_prompts(requirement)
        active_boundedness = [
            prompt for prompt in prompts if prompt.category == "boundedness" and prompt.status == "active"
        ]
        acknowledged_boundedness = [
            prompt for prompt in prompts if prompt.category == "boundedness" and prompt.status == "acknowledged"
        ]

        self.assertEqual([("appropriate",)], [prompt.terms for prompt in active_boundedness])
        self.assertEqual(1, len(acknowledged_boundedness))
        self.assertEqual(("all", "any"), acknowledged_boundedness[0].terms)
        self.assertEqual(("all",), acknowledged_boundedness[0].mixed_terms)
        self.assertIn("plain occurrences", acknowledged_boundedness[0].message)

        payload = json.loads(self.tool_run("semantic-context", "audit", "B.Biz.01", "--limit", "0").stdout)
        acknowledged = payload["observations"]["acknowledged_semantic_prompts"][0]
        self.assertEqual(["all", "any"], acknowledged["terms"])
        self.assertEqual(["all"], acknowledged["mixed_terms"])
        self.assertFalse(
            any("all" in prompt["terms"] for prompt in payload["observations"]["semantic_prompts"])
        )

