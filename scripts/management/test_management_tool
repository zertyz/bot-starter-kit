    def test_traceability_requires_one_canonical_current_links_table(self) -> None:
        module = self.load_tool_module()
        traceability = self.management / "TRACEABILITY.md"
        legacy = textwrap.dedent(
            """\
            # Traceability

            | Requirement | Work Item | State | Evidence |
            | --- | --- | --- | --- |
            | `E.MCP.01` | `EN.MCP.01-001` | Started | `src/lib.rs` |
            """
        )
        self.assertEqual([], module.traceability_links_from_text(legacy))
        traceability.write_text(legacy, encoding="utf-8")
        missing_section = self.tool_run("lint", "--strict", expected=1)
        self.assertIn("exactly one `## Current Links` section", missing_section.stderr)

        malformed_schema = legacy.replace(
            "| Requirement | Work Item | State | Evidence |",
            "## Current Links\n\n| Requirement | Work Item | State | Proof |",
        )
        traceability.write_text(malformed_schema, encoding="utf-8")
        malformed_table = self.tool_run("lint", "--strict", expected=1)
        self.assertIn("canonical traceability table header and separator", malformed_table.stderr)
        self.assertEqual([], module.traceability_links_from_text(malformed_schema))

        self.write_traceability()
        traceability.write_text(
            traceability.read_text(encoding="utf-8")
            + "\n## Current Links\n\n"
            + "| Requirement | Work Item | State | Evidence |\n"
            + "| --- | --- | --- | --- |\n",
            encoding="utf-8",
        )
        duplicate = self.tool_run("lint", "--strict", expected=1)
        self.assertIn("more than one `## Current Links` section", duplicate.stderr)

        self.write_traceability(
            "| `E.MCP.01` | `EN.MCP.01-001` | Rolled Out | `src/lib.rs`; <placeholder> |"
        )
        placeholder = self.tool_run("lint", "--strict", expected=1)
        self.assertIn("does not match EN.MCP.01-001 backlog state Started", placeholder.stderr)

    def test_traceability_writer_creates_repairs_or_rejects_without_partial_writes(self) -> None:
        module = self.load_tool_module()
        traceability = self.management / "TRACEABILITY.md"
        item = module.load_model().work_items["EN.MCP.01-001"]

        traceability.write_text("# Traceability\n\n## Notes\n\nNo links yet.\n", encoding="utf-8")
        self.assertEqual(
            "appended",
            module.append_or_update_traceability("E.MCP.01", item, ["src/lib.rs"], None, None),
        )
        created = traceability.read_text(encoding="utf-8")
        self.assertIn("## Current Links", created)
        self.assertIn("| Requirement | Work Item | State | Evidence |", created)
        self.assertEqual(["EN.MCP.01-001"], [link.work_item_id for link in module.traceability_links_from_text(created)])

        traceability.write_text(
            "# Traceability\n\n## Current Links\n\n"
            "| Requirement | Work Item | State | Proof |\n"
            "| -- | -- | -- | -- |\n\n"
            "## Notes\n\nKeep this note.\n",
            encoding="utf-8",
        )
        self.assertEqual(
            "appended",
            module.append_or_update_traceability("E.MCP.01", item, ["src/lib.rs"], None, None),
        )
        repaired = traceability.read_text(encoding="utf-8")
        self.assertIn("| Requirement | Work Item | State | Evidence |", repaired)
        self.assertIn("## Notes\n\nKeep this note.", repaired)

        unsafe = repaired.replace(
            "| Requirement | Work Item | State | Evidence |",
            "| Requirement | Work Item | State | Proof |",
        )
        traceability.write_text(unsafe, encoding="utf-8")
        original = traceability.read_bytes()
        with self.assertRaisesRegex(ValueError, "cannot safely repair"):
            module.append_or_update_traceability("E.MCP.01", item, ["src/lib.rs"], None, None)
        self.assertEqual(original, traceability.read_bytes())

