        self.assertIn("Dry run:", tag.stdout)

    def test_record_and_close_supporting_ledgers(self) -> None:
        decision = self.tool_run(
            "record-decision",
            "Use dashboard",
            "--context",
            "Management needs shared status.",
            "--decision",
            "Generate a static dashboard.",
            "--consequence",
            "Pages carries management status.",
            "--related",
            "management/TOOLING.md",
            "--date",
            "2026-07-08",
        )
        self.assertIn("Recorded decision DEC-0001", decision.stdout)
        risk = self.tool_run(
            "record-risk",
            "Dashboard drift",
            "--owner",
            "Manager",
            "--risk",
            "Dashboard can lag source files.",
            "--impact",
            "Humans may read stale status.",
            "--mitigation",
            "Regenerate on Pages.",
            "--review-date",
            "2026-08-01",
        )
        self.assertIn("Recorded risk RISK-0001", risk.stdout)
        close_risk = self.tool_run("close-risk", "RISK-0001", "--evidence", "Dashboard generation verified.", "--date", "2026-07-09")
        self.assertIn("Closed risk RISK-0001", close_risk.stdout)
        incident = self.tool_run(
            "record-incident",
            "Staging failure",
            "--environment",
            "Staging",
            "--impact",
            "Deploy failed.",
            "--timeline",
            "CI reported failure.",
            "--mitigation",
            "Rollback deployment.",
        )
        self.assertIn("Recorded incident INCIDENT-0001", incident.stdout)
        close_incident = self.tool_run("close-incident", "INCIDENT-0001", "--evidence", "Rollback completed.")
        self.assertIn("Closed incident INCIDENT-0001", close_incident.stdout)
        experiment = self.tool_run(
            "record-experiment",
            "Try cache",
            "--branch",
            "Luiz/EX.MCP.02.b-001",
            "--hypothesis",
            "A cache helps platform inquiry.",
            "--expires",
            "2026-08-01",
            "--success",
            "Latency improves.",
            "--failure",
            "Complexity increases.",
        )
        self.assertIn("Recorded experiment EXP-0001", experiment.stdout)
        close_experiment = self.tool_run("close-experiment", "EXP-0001", "--status", "Rejected", "--result", "Complexity was not worth it.")
        self.assertIn("Closed experiment EXP-0001 as Rejected", close_experiment.stdout)

    def test_stale_meeting_and_acceptance_packets(self) -> None:
        stale = self.tool_run("stale-work", "--days", "0")
        self.assertIn("Stale Work", stale.stdout)
        self.assertIn("ER.MCP.02.a-001", stale.stdout)
        meeting = self.tool_run("meeting-packet", "--stale-days", "0")
        self.assertIn("Meeting Packet", meeting.stdout)
        self.assertIn("Suggested agenda:", meeting.stdout)
        acceptance = self.tool_run("acceptance-packet", "EN.MCP.01-001")
        self.assertIn("Acceptance Packet", acceptance.stdout)
        self.assertIn("Acceptance checklist:", acceptance.stdout)

    def test_verification_check_reports_existing_evidence(self) -> None:
        src = self.root / "src"
        src.mkdir()
        (src / "lib.rs").write_text("#[cfg(test)]\nmod tests { #[test] fn it_works() {} }\n", encoding="utf-8")
        run(self.root, ["git", "add", "src/lib.rs"])
        check = self.tool_run("verification-check", "Luiz/EN.MCP.01-001")
        self.assertIn("Verification Check", check.stdout)
        self.assertIn("Functional behavior: FOUND", check.stdout)
