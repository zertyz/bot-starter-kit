def evidence_coverage_payload(model, requirement, links: list[object]) -> dict[str, object]:
    coverage = tool.requirement_evidence_coverage(model, requirement, links)
    work_coverage = tool.requirement_work_coverage(model, requirement)
    status = coverage["status"]
    missing_rows = list(coverage["missing_traceability_work_item_ids"])
    missing_evidence = list(coverage["missing_evidence_work_item_ids"])
    if status == "not_applicable":
        if work_coverage["status"] == "abandoned":
            detail = "All mapped work is abandoned, so delivery evidence is not applicable."
        else:
            detail = "No backlog work is mapped, so delivery evidence is not applicable yet."
    elif status == "pending":
        if coverage["completed_work_item_ids"]:
            detail = "Active mapped work remains; completed work may already have evidence. Overall evidence coverage remains pending until the active work is completed or abandoned."
        else:
            detail = "Mapped work has not reached Merged or Rolled Out; evidence may be linked during delivery but is not required yet."
    elif status == "evidenced":
        detail = "Every completed work item has a parsed traceability row with an existing concrete evidence path."
    else:
        details = []
        if missing_rows:
            details.append(f"missing traceability rows for {', '.join(missing_rows)}")
        if missing_evidence:
            details.append(f"missing existing concrete evidence for {', '.join(missing_evidence)}")
        detail = "Completed work has an evidence gap: " + "; ".join(details) + "."
    return {
        "status": status,
        "detail": detail,
        "completed_work_items": list(coverage["completed_work_item_ids"]),
        "pending_work_items": list(coverage["pending_work_item_ids"]),
        "missing_rows": missing_rows,
        "missing_evidence": missing_evidence,
        "links": [
            traceability_payload(link, model)
            for link in tool.traceability_links_for(requirement, links)
        ],
    }


def work_coverage_payload(model, requirement) -> dict[str, object]:
    coverage = dict(tool.requirement_work_coverage(model, requirement))
    by_motivation = dict(coverage["by_motivation"])
    coverage["by_motivation"] = {
        motivation: int(by_motivation.get(motivation, 0))
        for motivation in ("N", "R", "F", "X")
    }
    return coverage


def requirement_payload(
    model,
    requirement,
    links,
    findings: list[object],
    semantic_prompts: list[dict[str, object]],
    coverage_acknowledgements: list[dict[str, object]],
) -> dict[str, object]:
    work_items = tool.requirement_work_items(model, requirement)
    requirement_links = tool.traceability_links_for(requirement, links)
    traceability = traceability_reason(requirement, links)
    return {
        "id": requirement.id,
        "document": requirement.document,
        "section": requirement.section,
        "section_title": requirement.section_title,
        "number": requirement.number,
        "subtopics": requirement.subtopics,
        "title": requirement.title,
        "path": path_text(requirement.path),
        "line": requirement.line,
        "body": requirement.body,
        "work_items": [item.id for item in work_items],
        "work_coverage": work_coverage_payload(model, requirement),
        "traceability": [link.line for link in requirement_links],
        "traceability_status": traceability["status"],
        "traceability_detail": traceability["detail"],
        "traceability_lines": traceability["lines"],
        "audit_findings": [audit_finding_payload(finding) for finding in findings],
        "quality_findings": [audit_finding_payload(finding) for finding in findings],
        "semantic_prompts": semantic_prompts,
        "coverage_acknowledgements": coverage_acknowledgements,
        "evidence_coverage": evidence_coverage_payload(model, requirement, links),
        "edit_hint": f"{path_text(requirement.path)}:{requirement.line}",
    }


