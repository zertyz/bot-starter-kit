def model_payload(stale_days: int = DEFAULT_STALE_DAYS, loaded_model=None) -> dict[str, object]:
    model = loaded_model or tool.load_model()
    links = tool.traceability_links()
    traceability_path = tool.MANAGEMENT_DIR / "TRACEABILITY.md"
    traceability_text = traceability_path.read_text(encoding="utf-8") if traceability_path.exists() else ""
    audit = audit_findings(model, traceability_text) if not model.errors else []
    quality = list(audit)
    audit_by_requirement: dict[str, list[object]] = {}
    quality_by_requirement: dict[str, list[object]] = {}
    for finding in audit:
        audit_by_requirement.setdefault(finding.requirement.id, []).append(finding)
        quality_by_requirement.setdefault(finding.requirement.id, []).append(finding)
    semantic_by_requirement: dict[str, list[dict[str, object]]] = {}
    for requirement in sorted(model.requirements.values(), key=lambda candidate: candidate.id):
        prompts = [semantic_prompt_payload(prompt) for prompt in tool.requirement_semantic_prompts(requirement)]
        semantic_by_requirement[requirement.id] = prompts
    coverage_notes = tool.unmapped_requirement_area_acknowledgements()
    coverage_notes_by_requirement = {
        requirement.id: [
            coverage_acknowledgement_payload(item)
            for item in tool.requirement_coverage_acknowledgements(requirement, coverage_notes)
        ]
        for requirement in sorted(model.requirements.values(), key=lambda candidate: candidate.id)
    }
    tech_debt = tool.chase_tech_debts(0, 500)
    confirmed_tech_debt = confirmed_tech_debt_payload(model)
    risks = tool.open_ledger_entries(tool.MANAGEMENT_DIR / "RISKS.md")
    incidents = tool.open_ledger_entries(tool.MANAGEMENT_DIR / "INCIDENTS.md")
    experiments = tool.open_ledger_entries(tool.MANAGEMENT_DIR / "EXPERIMENTS.md")
    decisions = tool.ledger_entries(tool.MANAGEMENT_DIR / "DECISIONS.md")[-10:]
    gaps = tool.traceability_gaps(model) if not model.errors else []
    unmapped = tool.unmapped_requirements(model) if not model.errors else []
    stale = tool.stale_work_items(model, stale_days) if not model.errors else []
    counts = tool.state_counts(model)
    requirements = [
        requirement_payload(
            model,
            requirement,
            links,
            audit_by_requirement.get(requirement.id, []),
            semantic_by_requirement.get(requirement.id, []),
            coverage_notes_by_requirement.get(requirement.id, []),
        )
        for requirement in sorted(model.requirements.values(), key=lambda candidate: candidate.id)
    ]
    semantic_prompts = [
        prompt
        for requirement_prompts in semantic_by_requirement.values()
        for prompt in requirement_prompts
    ]

    return {
        "generated_at": time.strftime("%Y-%m-%d %H:%M:%S"),
        "repo_root": str(REPO_ROOT),
        "errors": [issue_payload(issue) for issue in model.errors],
        "warnings": [issue_payload(issue) for issue in model.warnings],
        "counts": {
            "requirements": len(model.requirements),
            "work_items": len(model.work_items),
            "traceability_gaps": len(gaps),
            "unmapped_requirements": len(unmapped),
            "stale_work": len(stale),
            "open_risks": len(risks),
            "open_incidents": len(incidents),
            "active_experiments": len(experiments),
            "audit_blockers": sum(1 for finding in audit if finding.severity == "BLOCKER"),
            "audit_reviews": sum(1 for finding in audit if finding.severity == "REVIEW"),
            "quality_blockers": sum(1 for finding in quality if finding.severity == "BLOCKER"),
            "quality_findings": len(quality),
            "quality_reviews": sum(1 for finding in quality if finding.severity == "REVIEW"),
            "unplanned_requirements": sum(1 for requirement in requirements if requirement["work_coverage"]["count"] == 0),
            "evidence_gaps": sum(1 for requirement in requirements if requirement["evidence_coverage"]["status"] == "gap"),
            "evidence_pending": sum(1 for requirement in requirements if requirement["evidence_coverage"]["status"] == "pending"),
            "evidenced_requirements": sum(1 for requirement in requirements if requirement["evidence_coverage"]["status"] == "evidenced"),
            "active_semantic_prompts": sum(1 for prompt in semantic_prompts if prompt["status"] == "active"),
            "acknowledged_semantic_prompts": sum(1 for prompt in semantic_prompts if prompt["status"] == "acknowledged"),
            "tech_debt_findings": len(tech_debt),
            "confirmed_tech_debts": len(confirmed_tech_debt),
        },
        "state_counts": counts,
        "audit_findings": [audit_finding_payload(finding) for finding in audit],
        "quality_findings": [audit_finding_payload(finding) for finding in quality],
        "semantic_prompts": semantic_prompts,
        "requirements": requirements,
        "work_items": [
            work_item_payload(item, model, quality_by_requirement, links)
            for item in sorted(model.work_items.values(), key=lambda candidate: candidate.id)
        ],
        "traceability": [traceability_payload(link, model) for link in links],
        "traceability_gaps": [requirement.id for requirement in gaps],
        "unmapped_requirements": [requirement.id for requirement in unmapped],
        "stale_work": [stale_payload(item) for item in stale],
        "ledgers": {
            "decisions": [ledger_payload(entry) for entry in decisions],
            "risks": [ledger_payload(entry) for entry in risks],
            "incidents": [ledger_payload(entry) for entry in incidents],
            "experiments": [ledger_payload(entry) for entry in experiments],
            "tech_debts": {
                "auto_detected": [tech_debt_payload(finding) for finding in tech_debt],
                "confirmed": confirmed_tech_debt,
            },
        },
        "tech_debts": {
            "auto_detected": [tech_debt_payload(finding) for finding in tech_debt],
            "confirmed": confirmed_tech_debt,
        },
        "diagrams": {
            "architecture_real": "/diagrams/architecture-real.svg",
            "architecture_planned": "/diagrams/architecture-planned.svg",
            "module_dependencies": "/diagrams/module-dependencies.svg",
        },
        "surface": {
            "mode": "local",
            "actions_enabled": True,
        },
    }


def generate_diagrams(output_dir: Path, loaded_model=None) -> None:
    model = loaded_model or tool.load_model()
    real_nodes, real_edges = tool.real_architecture_graph()
    planned_nodes, planned_edges = tool.planned_architecture_graph(model)
    module_nodes, module_edges = tool.module_dependency_graph()
    tool.write_diagram(
        output_dir,
        "architecture-real.svg",
        "Current Architecture",
        real_nodes,
        real_edges,
        [tool.GraphNode("legend:source", "Current source module", "", "#f6f8fa", "#57606a")],
    )
    tool.write_diagram(
        output_dir,
        "architecture-planned.svg",
        "Architecture Plan Overlay",
        planned_nodes,
        planned_edges,
        [
            tool.GraphNode("legend:source", "Current source module", "", "#f6f8fa", "#57606a"),
            tool.GraphNode("legend:work", "Planned or ongoing work", "", "#dbeafe", "#2563eb"),
            tool.GraphNode("legend:unplanned", "Unplanned requirement", "", "#fff7ed", "#ea580c"),
        ],
    )
    tool.write_diagram(
        output_dir,
        "module-dependencies.svg",
        "Rust Module Dependencies",
        module_nodes,
        module_edges,
        [
            tool.GraphNode("legend:bin", "Executable", "", "#fef3c7", "#92400e"),
            tool.GraphNode("legend:logic", "Logic", "", "#dcfce7", "#15803d"),
            tool.GraphNode("legend:messaging", "Messaging", "", "#dbeafe", "#1d4ed8"),
            tool.GraphNode("legend:db", "Persistence", "", "#ede9fe", "#6d28d9"),
        ],
    )


def publish_staged_files(staging_dir: Path, output_dir: Path, entrypoint_last: str | None = None) -> None:
    output_dir.mkdir(parents=True, exist_ok=True)
    sources = sorted(source for source in staging_dir.rglob("*") if source.is_file())
    if entrypoint_last:
        entrypoint = staging_dir / entrypoint_last
        if entrypoint not in sources:
            raise RuntimeError(f"staged entrypoint is missing: {entrypoint_last}")
        sources.remove(entrypoint)
        sources.append(entrypoint)
    for source in sources:
        destination = output_dir / source.relative_to(staging_dir)
        destination.parent.mkdir(parents=True, exist_ok=True)
        os.replace(source, destination)


def invalidate_diagram_cache() -> None:
    global DIAGRAM_CACHE_READY
    with DIAGRAM_LOCK:
        DIAGRAM_CACHE_READY = False


def ensure_diagrams(force: bool = False) -> None:
    global DIAGRAM_CACHE_READY
    with DIAGRAM_LOCK:
        if not force and DIAGRAM_CACHE_READY and all((DIAGRAM_DIR / name).is_file() for name in DIAGRAM_FILENAMES):
            return
        DIAGRAM_DIR.parent.mkdir(parents=True, exist_ok=True)
        with tempfile.TemporaryDirectory(prefix="diagram-stage-", dir=DIAGRAM_DIR.parent) as directory:
            staging_dir = Path(directory)
            with tool.management_write_lock():
                generate_diagrams(staging_dir)
            publish_staged_files(staging_dir, DIAGRAM_DIR)
        DIAGRAM_CACHE_READY = True


def static_script_json(payload: object) -> str:
    return json.dumps(payload, indent=2, sort_keys=True).replace("</", "<\\/")


def render_index_html(
    title: str,
    capability_token: str,
    bootstrap: str,
    stylesheet_url: str = "./assets/app.css",
    script_url: str = "./assets/app.js",
) -> str:
    index = (STATIC_DIR / "index.html").read_text(encoding="utf-8")
    expected_markers = {
        INDEX_TITLE_MARKER: 2,
        INDEX_CAPABILITY_MARKER: 1,
        INDEX_BOOTSTRAP_MARKER: 1,
        INDEX_STYLESHEET_MARKER: 1,
        INDEX_SCRIPT_MARKER: 1,
    }
    for marker, expected_count in expected_markers.items():
        actual_count = index.count(marker)
        if actual_count != expected_count:
            raise RuntimeError(f"expected {expected_count} {marker} marker(s), found {actual_count}")
    index = index.replace(INDEX_TITLE_MARKER, html.escape(title))
    index = index.replace(INDEX_CAPABILITY_MARKER, html.escape(capability_token, quote=True))
    index = index.replace(INDEX_STYLESHEET_MARKER, html.escape(stylesheet_url, quote=True))
    index = index.replace(INDEX_SCRIPT_MARKER, html.escape(script_url, quote=True))
    return index.replace(INDEX_BOOTSTRAP_MARKER, bootstrap)


def local_index_html(capability_token: str) -> str:
    return render_index_html("Management Console", capability_token, "")


def static_index_html(payload: dict[str, object], generation_url: str) -> str:
