    }


def static_report_payload(
    stale_days: int,
    loaded_model=None,
    diagram_base_url: str = "./diagrams",
) -> dict[str, object]:
    payload = model_payload(stale_days, loaded_model)
    payload["repo_root"] = f"{REPO_ROOT.name} (static export)"
    payload["diagrams"] = static_diagram_payload(diagram_base_url)
    payload["surface"] = {
        "mode": "static",
        "actions_enabled": False,
    }
    return payload


def snapshot_id_for(staging_dir: Path) -> str:
    digest = hashlib.sha256()
    for source in sorted(source for source in staging_dir.rglob("*") if source.is_file()):
        relative = source.relative_to(staging_dir).as_posix().encode("utf-8")
        contents = source.read_bytes()
        digest.update(len(relative).to_bytes(8, "big"))
        digest.update(relative)
        digest.update(len(contents).to_bytes(8, "big"))
        digest.update(contents)
    return f"sha256-{digest.hexdigest()}"


def directory_contents(root: Path) -> dict[str, bytes]:
    return {
        source.relative_to(root).as_posix(): source.read_bytes()
        for source in sorted(source for source in root.rglob("*") if source.is_file())
    }


def publish_immutable_generation(staging_dir: Path, output_dir: Path, generation_id: str) -> Path:
    generations_dir = output_dir / STATIC_GENERATIONS_DIR
    generations_dir.mkdir(parents=True, exist_ok=True)
    destination = generations_dir / generation_id
    if destination.exists():
        if not destination.is_dir() or directory_contents(destination) != directory_contents(staging_dir):
            raise RuntimeError(f"static report generation collision: {generation_id}")
        return destination
    os.replace(staging_dir, destination)
    return destination


def export_management_report(output_dir: Path, stale_days: int = DEFAULT_STALE_DAYS) -> Path:
    output_dir.parent.mkdir(parents=True, exist_ok=True)
    with tool.management_write_lock():
        loaded_model = tool.load_model()
        payload = static_report_payload(stale_days, loaded_model)
        with tempfile.TemporaryDirectory(prefix=".management-report-stage-", dir=output_dir.parent) as directory:
            staging_dir = Path(directory) / "report"
            generation_dir = staging_dir / "generation"
            compatibility_dir = staging_dir / "compatibility"
            assets_dir = generation_dir / "assets"
            diagrams_dir = generation_dir / "diagrams"
            assets_dir.mkdir(parents=True, exist_ok=True)
            generate_diagrams(diagrams_dir, loaded_model)
            shutil.copy2(STATIC_DIR / "app.css", assets_dir / "app.css")
            shutil.copy2(STATIC_DIR / "app.js", assets_dir / "app.js")
            (generation_dir / "model.json").write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")

            # Hash the logical snapshot before deriving its self-referential generation URLs.
            generation_id = snapshot_id_for(generation_dir)
            generation_url = f"./{STATIC_GENERATIONS_DIR}/{generation_id}"
            payload["diagrams"] = static_diagram_payload(f"{generation_url}/diagrams")
            (generation_dir / "model.json").write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
            (staging_dir / "index.html").write_text(static_index_html(payload, generation_url), encoding="utf-8")

            shutil.copytree(generation_dir, compatibility_dir)
            publish_immutable_generation(generation_dir, output_dir, generation_id)
            os.replace(staging_dir / "index.html", output_dir / "index.html")
            publish_staged_files(compatibility_dir, output_dir)
    return output_dir / "index.html"


def required(payload: dict[str, object], name: str) -> str:
    value = str(payload.get(name, "")).strip()
    if not value:
        raise ClientError(f"{name} is required")
    return value


def optional(payload: dict[str, object], name: str) -> str | None:
    value = str(payload.get(name, "")).strip()
    return value or None


def flag(payload: dict[str, object], name: str) -> bool:
    return bool(payload.get(name))


def list_value(payload: dict[str, object], name: str) -> list[str]:
    raw = payload.get(name, [])
    if isinstance(raw, list):
        values = [str(item).strip() for item in raw]
    else:
        values = [item.strip() for item in str(raw).replace(",", "\n").splitlines()]
    return [item for item in values if item]


def add_option(args: list[str], name: str | None, value: str | None) -> None:
    if value:
        args.extend([name, value])


def build_management_command(action: str, payload: dict[str, object]) -> list[str]:
    args: list[str]
    if action == "lint":
        args = ["lint"]
        if flag(payload, "strict"):
            args.append("--strict")
    elif action == "management-status":
        args = ["management-status"]
        add_option(args, "--stale-days", optional(payload, "stale_days"))
    elif action == "show-requirement":
        args = ["show-requirement", required(payload, "requirement_id")]
    elif action == "show-work":
        args = ["show-work", required(payload, "ref")]
        if flag(payload, "chat_prompt"):
            args.append("--chat-prompt")
    elif action == "chat-about":
        args = ["chat-about"]
        add_option(args, None, optional(payload, "ref"))
    elif action == "verify-branch":
        args = ["verify-branch"]
        add_option(args, None, optional(payload, "branch"))
    elif action == "evaluate-plan":
        args = ["evaluate-plan", required(payload, "ref")]
        add_option(args, "--user", optional(payload, "user"))
    elif action == "draft-plan":
        args = ["draft-plan", required(payload, "requirement_id")]
        add_option(args, "--motivation", optional(payload, "motivation"))
        add_option(args, "--sequence", optional(payload, "sequence"))
        add_option(args, "--title", optional(payload, "title"))
        add_option(args, "--date", optional(payload, "date"))
        for body_line in list_value(payload, "body_lines"):
            args.extend(["--body-line", body_line])
        if flag(payload, "write"):
            args.append("--write")
        if flag(payload, "allow_existing_open"):
            args.append("--allow-existing-open")
    elif action == "advance-state":
        args = ["advance-state", required(payload, "ref")]
        add_option(args, "--to", optional(payload, "to"))
        add_option(args, "--date", optional(payload, "date"))
        add_option(args, "--engineer", optional(payload, "engineer"))
        add_option(args, "--override-gate", optional(payload, "override_gate"))
        if flag(payload, "dry_run"):
            args.append("--dry-run")
    elif action in {"block-work", "unblock-work"}:
        args = [action, required(payload, "ref"), "--reason", required(payload, "reason")]
        add_option(args, "--date", optional(payload, "date"))
        if flag(payload, "dry_run"):
            args.append("--dry-run")
    elif action == "start-work":
        args = ["start-work", required(payload, "branch")]
        add_option(args, "--base", optional(payload, "base"))
        add_option(args, "--user", optional(payload, "user"))
        add_option(args, "--feature-branch", optional(payload, "feature_branch"))
        if flag(payload, "from_feature"):
            args.append("--from-feature")
        if flag(payload, "allow_dirty"):
            args.append("--allow-dirty")
        if flag(payload, "dry_run"):
            args.append("--dry-run")
    elif action == "audit-requirements":
        args = ["audit-requirements"]
        add_option(args, "--document", optional(payload, "document"))
        add_option(args, "--limit", optional(payload, "limit"))
        if flag(payload, "strict"):
            args.append("--strict")
    elif action == "estimate-requirement":
        args = ["estimate-requirement", required(payload, "requirement_id")]
    elif action == "sync-requirement":
        args = ["sync-requirement", required(payload, "requirement_id")]
        add_option(args, "--limit", optional(payload, "limit"))
        if flag(payload, "strict"):
            args.append("--strict")
    elif action == "trace-requirement":
        args = ["trace-requirement", required(payload, "requirement_id")]
        add_option(args, "--limit", optional(payload, "limit"))
    elif action == "link-evidence":
        args = ["link-evidence", required(payload, "requirement_id"), required(payload, "work_item_id")]
        paths = list_value(payload, "paths")
        if not paths:
            raise ClientError("paths is required")
        args.extend(paths)
        add_option(args, "--note", optional(payload, "note"))
        add_option(args, "--state", optional(payload, "state"))
        if flag(payload, "allow_missing"):
            args.append("--allow-missing")
    elif action == "prepare-release":
        args = ["prepare-release", required(payload, "version")]
        add_option(args, "--stale-days", optional(payload, "stale_days"))
        if flag(payload, "strict"):
            args.append("--strict")
    elif action == "create-release-tag":
        version = required(payload, "version")
        args = ["create-release-tag", version]
        add_option(args, "--message", optional(payload, "message"))
        if flag(payload, "execute"):
            if optional(payload, "confirm") != version:
                raise ClientError("confirm must match the release version before creating a tag")
            args.append("--execute")
    elif action == "chase-techdebts":
        args = ["chase-techdebts"]
        add_option(args, "--limit", optional(payload, "limit"))
        add_option(args, "--long-file-lines", optional(payload, "long_file_lines"))
        if flag(payload, "strict"):
            args.append("--strict")
    elif action == "record-decision":
        args = [
            "record-decision",
            required(payload, "title"),
            "--context",
            required(payload, "context"),
            "--decision",
            required(payload, "decision"),
            "--consequence",
            required(payload, "consequence"),
        ]
        add_option(args, "--status", optional(payload, "status"))
        add_option(args, "--date", optional(payload, "date"))
        for related in list_value(payload, "related"):
            args.extend(["--related", related])
    elif action == "record-risk":
        args = [
            "record-risk",
            required(payload, "title"),
            "--owner",
            required(payload, "owner"),
            "--risk",
            required(payload, "risk"),
            "--impact",
            required(payload, "impact"),
            "--mitigation",
            required(payload, "mitigation"),
        ]
        add_option(args, "--review-date", optional(payload, "review_date"))
        for related in list_value(payload, "related"):
            args.extend(["--related", related])
    elif action == "close-risk":
        args = ["close-risk", required(payload, "risk_id"), "--evidence", required(payload, "evidence")]
        add_option(args, "--date", optional(payload, "date"))
    elif action == "record-incident":
        args = [
            "record-incident",
            required(payload, "title"),
            "--environment",
            required(payload, "environment"),
            "--impact",
            required(payload, "impact"),
            "--timeline",
            required(payload, "timeline"),
            "--mitigation",
            required(payload, "mitigation"),
        ]
        add_option(args, "--detected", optional(payload, "detected"))
    elif action == "close-incident":
        args = ["close-incident", required(payload, "incident_id"), "--evidence", required(payload, "evidence")]
        add_option(args, "--closed", optional(payload, "closed"))
    elif action == "record-experiment":
        args = [
            "record-experiment",
            required(payload, "title"),
            "--branch",
            required(payload, "branch"),
            "--hypothesis",
            required(payload, "hypothesis"),
            "--expires",
            required(payload, "expires"),
            "--success",
            required(payload, "success"),
            "--failure",
            required(payload, "failure"),
        ]
        for follow_up in list_value(payload, "follow_up"):
            args.extend(["--follow-up", follow_up])
    elif action == "close-experiment":
        args = [
            "close-experiment",
            required(payload, "experiment_id"),
            "--status",
            required(payload, "status"),
            "--result",
            required(payload, "result"),
        ]
        add_option(args, "--date", optional(payload, "date"))
    elif action == "stale-work":
        args = ["stale-work"]
        add_option(args, "--days", optional(payload, "days"))
        if flag(payload, "strict"):
            args.append("--strict")
    elif action == "meeting-packet":
        args = ["meeting-packet"]
        add_option(args, "--stale-days", optional(payload, "stale_days"))
    elif action == "acceptance-packet":
        args = ["acceptance-packet", required(payload, "ref")]
    elif action == "verification-check":
        args = ["verification-check"]
        add_option(args, None, optional(payload, "ref"))
        add_option(args, "--base", optional(payload, "base"))
        add_option(args, "--limit", optional(payload, "limit"))
    elif action == "review":
        args = ["review"]
        add_option(args, None, optional(payload, "ref"))
        add_option(args, "--base", optional(payload, "base"))
        add_option(args, "--limit", optional(payload, "limit"))
    elif action == "diagram-architecture-real":
        args = ["diagram-architecture-real", "--html", str(DIAGRAM_DIR)]
    elif action == "diagram-architecture-planned":
        args = ["diagram-architecture-planned", "--html", str(DIAGRAM_DIR)]
    elif action == "diagram-module-dependencies":
        args = ["diagram-module-dependencies", "--html", str(DIAGRAM_DIR)]
        add_option(args, "--scope", optional(payload, "scope"))
        if flag(payload, "include_tests"):
            args.append("--include-tests")
    else:
        raise ClientError(f"unknown action: {action}")
    return [part for part in args if part is not None]


def run_management_command(args: list[str]) -> dict[str, object]:
    command = [sys.executable, str(MANAGEMENT_TOOL), *args]
    result = subprocess.run(
        command,
        cwd=REPO_ROOT,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        timeout=COMMAND_TIMEOUT_SECONDS,
    )
    return {
        "command": " ".join(["scripts/management/management_tool", *args]),
        "returncode": result.returncode,
        "stdout": result.stdout,
        "stderr": result.stderr,
    }


def action_mutates_repository(action: str, payload: dict[str, object]) -> bool:
    if action in ALWAYS_MUTATING_ACTIONS:
        return True
    if action == "draft-plan":
        return flag(payload, "write")
    if action in {"advance-state", "start-work", "block-work", "unblock-work"}:
        return not flag(payload, "dry_run")
    if action == "create-release-tag":
        return flag(payload, "execute")
    return False


def execute_action(request: dict[str, object], mutation_lock=None) -> dict[str, object]:
    global DIAGRAM_CACHE_READY
    action = str(request.get("action", "")).strip()
    payload = request.get("payload", {})
    if not isinstance(payload, dict):
        raise ClientError("payload must be an object")
    args = build_management_command(action, payload)
    if action in DIAGRAM_ACTIONS:
        with DIAGRAM_LOCK:
            result = run_management_command(args)
            DIAGRAM_CACHE_READY = False
            return result
    if action_mutates_repository(action, payload):
        with mutation_lock or MUTATION_LOCK:
            return run_management_command(args)
    return run_management_command(args)


def json_bytes(payload: object) -> bytes:
    return json.dumps(payload, indent=2, sort_keys=True).encode("utf-8")


def normalize_host_name(value: str) -> str:
    normalized = value.strip().lower().rstrip(".")
    if normalized.startswith("[") and normalized.endswith("]"):
        normalized = normalized[1:-1]
    try:
        return ipaddress.ip_address(normalized).compressed
    except ValueError:
        return normalized


def is_loopback_host(host: str) -> bool:
    normalized = normalize_host_name(host)
    if normalized == "localhost":
        return True
    try:
        return ipaddress.ip_address(normalized).is_loopback
    except ValueError:
        return False


def parse_http_authority(value: str | None, default_port: int) -> tuple[str, int] | None:
    if not value or any(character.isspace() or ord(character) < 32 for character in value):
        return None
    parsed = urlparse(f"//{value}")
    if parsed.username is not None or parsed.password is not None or parsed.path or parsed.params or parsed.query or parsed.fragment:
        return None
    try:
        port = parsed.port or default_port
    except ValueError:
        return None
    if parsed.hostname is None:
        return None
    return normalize_host_name(parsed.hostname), port


def request_host_is_valid(host_header: str | None, allowed_hosts: set[str] | frozenset[str], server_port: int) -> bool:
    authority = parse_http_authority(host_header, 80)
    return authority is not None and authority[0] in allowed_hosts and authority[1] == server_port


def request_origin_is_valid(
    origin_header: str | None,
    host_header: str | None,
    allowed_hosts: set[str] | frozenset[str],
    server_port: int,
) -> bool:
    if not origin_header:
        return False
    parsed = urlparse(origin_header)
    if (
        parsed.scheme != "http"
        or parsed.username is not None
        or parsed.password is not None
        or parsed.path not in {"", "/"}
        or parsed.params
        or parsed.query
        or parsed.fragment
    ):
        return False
    origin = parse_http_authority(parsed.netloc, 80)
    request_host = parse_http_authority(host_header, 80)
    return (
        origin is not None
        and request_host is not None
        and origin == request_host
        and origin[0] in allowed_hosts
        and origin[1] == server_port
    )


def allowed_host_names(bind_host: str, additional_hosts: list[str] | None = None) -> set[str]:
    hosts = {normalize_host_name(bind_host)}
    hosts.update(normalize_host_name(host) for host in additional_hosts or [])
    if is_loopback_host(bind_host):
        hosts.update({"127.0.0.1", "::1", "localhost"})
    return hosts


class ManagementGuiHandler(BaseHTTPRequestHandler):
    server_version = "ManagementGui/1.0"

    def version_string(self) -> str:
        return self.server_version

    def log_message(self, format: str, *args) -> None:
        if not getattr(self.server, "quiet", False):
            super().log_message(format, *args)

    def send_bytes(self, status: int, body: bytes, content_type: str) -> None:
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        for name, value in SECURITY_HEADERS.items():
            self.send_header(name, value)
        self.end_headers()
        self.wfile.write(body)

    def send_json(self, status: int, payload: object) -> None:
        self.send_bytes(status, json_bytes(payload), "application/json; charset=utf-8")

    def send_error_json(self, status: int, message: str) -> None:
        self.send_json(status, {"error": message})

    def serve_static(self, path: Path) -> None:
        if not path.is_file():
            self.send_error_json(404, "not found")
            return
        content_type = mimetypes.guess_type(path.name)[0] or "application/octet-stream"
        self.send_bytes(200, path.read_bytes(), content_type)

    def valid_request_host(self) -> bool:
        return request_host_is_valid(
            self.headers.get("Host"),
            getattr(self.server, "allowed_hosts", frozenset()),
            self.server.server_port,
        )

    def do_GET(self) -> None:
        if not self.valid_request_host():
            self.send_error_json(403, "invalid Host header")
            return
        parsed = urlparse(self.path)
        if parsed.path == "/":
            body = local_index_html(getattr(self.server, "capability_token", "")).encode("utf-8")
            self.send_bytes(200, body, "text/html; charset=utf-8")
            return
        if parsed.path.startswith("/assets/"):
            requested = (STATIC_DIR / parsed.path.removeprefix("/assets/")).resolve()
            if STATIC_DIR.resolve() not in requested.parents:
                self.send_error_json(403, "forbidden")
                return
            self.serve_static(requested)
            return
        if parsed.path == "/api/model":
            try:
                query = parse_qs(parsed.query)
                stale_days = int(query.get("stale_days", [str(DEFAULT_STALE_DAYS)])[0])
                with tool.management_write_lock():
                    payload = model_payload(stale_days)
            except ValueError:
                self.send_error_json(400, "stale_days must be an integer")
                return
            except Exception as err:  # noqa: BLE001
                self.log_error("model generation failed: %s", err)
                self.send_error_json(500, "management model generation failed")
                return
            invalidate_diagram_cache()
            self.send_json(200, payload)
            return
        if parsed.path.startswith("/diagrams/"):
            requested = (DIAGRAM_DIR / parsed.path.removeprefix("/diagrams/")).resolve()
            if DIAGRAM_DIR.resolve() not in requested.parents:
                self.send_error_json(403, "forbidden")
                return
            try:
                with DIAGRAM_LOCK:
                    ensure_diagrams()
                    self.serve_static(requested)
            except Exception as err:  # noqa: BLE001
                self.log_error("diagram generation failed: %s", err)
                self.send_error_json(500, "diagram generation failed")
                return
            return
        self.send_error_json(404, "not found")

    def do_POST(self) -> None:
        parsed = urlparse(self.path)
        if parsed.path != "/api/action":
            self.send_error_json(404, "not found")
            return
        try:
            host_header = self.headers.get("Host")
            allowed_hosts = getattr(self.server, "allowed_hosts", frozenset())
            if not request_host_is_valid(host_header, allowed_hosts, self.server.server_port):
                self.send_error_json(403, "invalid Host header")
                return
            if not request_origin_is_valid(self.headers.get("Origin"), host_header, allowed_hosts, self.server.server_port):
                self.send_error_json(403, "invalid Origin header")
                return
            if self.headers.get_content_type() != "application/json":
                self.send_error_json(415, "Content-Type must be application/json")
                return
            expected_token = getattr(self.server, "capability_token", "")
            provided_token = self.headers.get(CAPABILITY_HEADER, "")
            if not expected_token or not secrets.compare_digest(provided_token, expected_token):
                self.send_error_json(403, "invalid capability token")
                return
            raw_length = self.headers.get("Content-Length")
            if raw_length is None:
                self.send_error_json(411, "Content-Length is required")
                return
            try:
                length = int(raw_length)
            except ValueError:
                self.send_error_json(400, "invalid Content-Length")
                return
            if length < 0:
                self.send_error_json(400, "invalid Content-Length")
                return
            if length > MAX_ACTION_BODY_BYTES:
                self.send_error_json(413, "request body is too large")
                return
            body = self.rfile.read(length)
            if len(body) != length:
                self.send_error_json(400, "incomplete request body")
                return
            try:
                request = json.loads(body.decode("utf-8") or "{}")
            except (UnicodeDecodeError, json.JSONDecodeError):
                self.send_error_json(400, "invalid JSON request")
                return
            if not isinstance(request, dict):
                raise ClientError("request must be an object")
            mutation_lock = getattr(self.server, "mutation_lock", MUTATION_LOCK)
            self.send_json(200, execute_action(request, mutation_lock))
        except ClientError as err:
            self.send_error_json(400, str(err))
        except subprocess.TimeoutExpired:
            self.send_error_json(504, "management command timed out")
        except Exception as err:  # noqa: BLE001
            self.log_error("action failed: %s", err)
            self.send_error_json(500, "management action failed")

    def do_OPTIONS(self) -> None:
        self.send_error_json(405, "method not allowed")


def validate_bind_host(host: str, unsafe_allow_non_loopback: bool) -> None:
    if not is_loopback_host(host) and not unsafe_allow_non_loopback:
        raise ClientError("non-loopback --host requires --unsafe-allow-non-loopback")


def bind_server(
    host: str,
    port: int,
    attempts: int,
    quiet: bool,
    additional_hosts: list[str] | None = None,
    capability_token: str | None = None,
) -> ThreadingHTTPServer:
    token = capability_token or secrets.token_urlsafe(32)
    for offset in range(max(attempts, 1)):
        candidate = port + offset if port else 0
        try:
            server = ThreadingHTTPServer((host, candidate), ManagementGuiHandler)
            server.quiet = quiet  # type: ignore[attr-defined]
            server.daemon_threads = True
            server.capability_token = token  # type: ignore[attr-defined]
            server.mutation_lock = threading.Lock()  # type: ignore[attr-defined]
            hosts = allowed_host_names(host, additional_hosts)
            hosts.add(normalize_host_name(str(server.server_address[0])))
            server.allowed_hosts = frozenset(hosts)  # type: ignore[attr-defined]
            return server
        except OSError:
            if port == 0 or offset + 1 >= attempts:
                raise
    raise RuntimeError("could not bind server")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Run the local management GUI or export the static Management Report.")
    parser.add_argument("--host", default="127.0.0.1", help="Bind host. Default: 127.0.0.1.")
    parser.add_argument(
        "--unsafe-allow-non-loopback",
        action="store_true",
        help="Allow binding the action-capable GUI to a non-loopback host.",
    )
    parser.add_argument(
        "--allowed-host",
        action="append",
        default=[],
        help="Allow an additional HTTP Host name. Repeat for multiple names.",
    )
    parser.add_argument("--port", type=int, default=8765, help="Bind port. Default: 8765.")
    parser.add_argument("--port-attempts", type=int, default=20, help="Try this many consecutive ports before failing.")
    parser.add_argument("--no-browser", action="store_true", help="Do not ask the OS to open a browser.")
    parser.add_argument("--quiet", action="store_true", help="Suppress request logging.")
    parser.add_argument("--check", action="store_true", help="Validate the GUI data path and exit.")
    parser.add_argument("--html", "--export-report", dest="export_report", help="Write the static Management Report to this directory and exit.")
    parser.add_argument("--stale-days", type=int, default=DEFAULT_STALE_DAYS, help="Age threshold for stale work. Default: 14.")
    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    if args.check:
        payload = model_payload(args.stale_days)
        print(json.dumps({"requirements": payload["counts"]["requirements"], "work_items": payload["counts"]["work_items"]}, sort_keys=True))
        return 0
    if args.export_report:
        target = export_management_report(Path(args.export_report), args.stale_days)
        print(f"Management Report: {target}")
        return 0

    try:
        validate_bind_host(args.host, args.unsafe_allow_non_loopback)
    except ClientError as err:
        parser.error(str(err))
    server = bind_server(args.host, args.port, args.port_attempts, args.quiet, args.allowed_host)
    host, port = server.server_address
    url = f"http://{host}:{port}/"
    print(f"Management GUI: {url}", flush=True)
    if not args.no_browser:
        webbrowser.open(url)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nManagement GUI stopped.", file=sys.stderr)
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    sys.exit(main())
