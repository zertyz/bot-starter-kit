def load_management_tool():
    loader = importlib.machinery.SourceFileLoader("management_tool_runtime", str(MANAGEMENT_TOOL))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    if spec is None:
        raise RuntimeError("cannot load management_tool")
    module = importlib.util.module_from_spec(spec)
    sys.modules[loader.name] = module
    loader.exec_module(module)
    return module


